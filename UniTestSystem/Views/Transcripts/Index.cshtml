@model List<UniTestSystem.Domain.Transcript>
@{
    ViewData["Title"] = "Student Transcripts Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-people me-2"></i>Student Transcripts</h2>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Student Name</th>
                        <th>Student ID</th>
                        <th class="text-center">Total Credits</th>
                        <th class="text-center">Cumulative GPA (4.0)</th>
                        <th class="text-center">Last Calculated</th>
                        <th class="text-end pe-4">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-file-earmark-text fs-2 d-block mb-2"></i>
                                No calculated transcripts found.
                            </td>
                        </tr>
                    }
                    @foreach (var t in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold">@t.Student?.Name</td>
                            <td>@t.StudentId</td>
                            <td class="text-center">@t.TotalCredits</td>
                            <td class="text-center">
                                <span class="fs-5 fw-bold @(t.GPA >= 3.5m ? "text-success" : t.GPA < 2.0m ? "text-danger" : "text-primary")">
                                    @t.GPA.ToString("0.00")
                                </span>
                            </td>
                            <td class="text-center">@t.CalculatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="text-end pe-4">
                                <a asp-action="Details" asp-route-id="@t.StudentId" class="btn btn-sm btn-outline-primary px-3">
                                    <i class="bi bi-eye me-1"></i> View Details
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
