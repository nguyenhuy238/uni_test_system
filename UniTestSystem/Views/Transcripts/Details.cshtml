@model List<UniTestSystem.Domain.Enrollment>
@{
    ViewData["Title"] = "Student Transcript Details";
    var studentId = (string?)ViewBag.StudentId ?? "";
    var studentName = (string?)ViewBag.StudentName ?? studentId;
    var summary = ViewBag.Summary as UniTestSystem.Domain.Transcript;
    var selectedSemester = (string?)ViewBag.Semester;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1"><i class="bi bi-journal-check me-2"></i>Transcript Details</h2>
        <div class="text-muted">@studentName (@studentId)</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-success" href="/transcripts/@studentId/export/xlsx?semester=@selectedSemester">Export Excel</a>
        <a class="btn btn-outline-danger" href="/transcripts/@studentId/export/pdf?semester=@selectedSemester">Export PDF</a>
        <a class="btn btn-outline-secondary" href="/Transcripts/Index">Back</a>
    </div>
</div>

<div class="card mb-3 border-0 shadow-sm">
    <div class="card-body d-flex gap-4">
        <div><span class="text-muted">Cumulative GPA:</span> <b>@(summary?.GPA.ToString("0.00") ?? "0.00")</b></div>
        <div><span class="text-muted">Total Credits:</span> <b>@(summary?.TotalCredits ?? 0)</b></div>
    </div>
</div>

<form method="get" class="row g-2 mb-3">
    <input type="hidden" name="id" value="@studentId" />
    <div class="col-md-4">
        <label class="form-label">Semester</label>
        <select class="form-select" name="semester" asp-items="ViewBag.Semesters">
            <option value="">All</option>
        </select>
    </div>
    <div class="col-md-4 d-flex align-items-end gap-2">
        <button class="btn btn-primary">Filter</button>
        <a class="btn btn-outline-secondary" href="/Transcripts/Details/@studentId">Reset</a>
    </div>
</form>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Semester</th>
                        <th>Course</th>
                        <th class="text-center">Credits</th>
                        <th class="text-center">Final Score</th>
                        <th class="text-center">Grade</th>
                        <th class="text-center">Grade Point</th>
                        <th class="text-end pe-4">Finalize</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                No enrollments found for this filter.
                            </td>
                        </tr>
                    }
                    @foreach (var e in Model.OrderBy(x => x.Semester).ThenBy(x => x.Course?.Code))
                    {
                        <tr>
                            <td class="ps-4">@e.Semester</td>
                            <td>@e.Course?.Code - @e.Course?.Name</td>
                            <td class="text-center">@e.Course?.Credits</td>
                            <td class="text-center">@(e.FinalScore?.ToString("0.0") ?? "-")</td>
                            <td class="text-center">@(e.Grade ?? "-")</td>
                            <td class="text-center">@(e.GradePoint?.ToString("0.0") ?? "-")</td>
                            <td class="text-end pe-4">
                                <form asp-action="FinalizeGrade" method="post" class="d-flex justify-content-end gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="enrollmentId" value="@e.Id" />
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                    <input type="number" name="finalScore" step="0.1" min="0" max="10" value="@(e.FinalScore?.ToString("0.0") ?? "0")" class="form-control form-control-sm" style="width:90px;" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary">Save</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
