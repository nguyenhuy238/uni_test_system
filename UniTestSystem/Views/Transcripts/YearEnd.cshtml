@model UniTestSystem.Application.Interfaces.YearEndPreviewResult
@{
    ViewData["Title"] = "Year-End GPA Finalization";
    var selectedFacultyId = (string?)ViewBag.SelectedFacultyId;
    var selectedAcademicYear = (string?)ViewBag.SelectedAcademicYear ?? Model.AcademicYear;
    var canFinalize = Model.Prerequisites.IsReady && Model.TotalStudents > 0;
    var currentUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<partial name="~/Views/Shared/_Flash.cshtml" />

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1"><i class="bi bi-calendar-check me-2"></i>Year-End Finalization</h2>
        <div class="text-muted small">Preview is dry-run only. Finalization will lock year-end transcript data.</div>
    </div>
    <a class="btn btn-outline-secondary" href="/Transcripts/Index">Back To Transcripts</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <label class="form-label">Academic Year</label>
        <input name="academicYear" class="form-control" value="@selectedAcademicYear" placeholder="e.g. 2025-2026" />
    </div>
    <div class="col-md-4">
        <label class="form-label">Faculty</label>
        <select name="facultyId" class="form-select" asp-items="ViewBag.Faculties">
            <option value="">All Faculties</option>
        </select>
    </div>
    <div class="col-md-4 d-flex align-items-end gap-2">
        <button class="btn btn-primary">Preview</button>
        <a class="btn btn-outline-secondary" href="/transcripts/year-end">Reset</a>
    </div>
</form>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
            <span class="badge @(Model.Prerequisites.IsReady ? "bg-success" : "bg-danger")">
                Prerequisites: @(Model.Prerequisites.IsReady ? "Ready" : "Not Ready")
            </span>
            <span class="badge @(Model.Prerequisites.AllExamSchedulesCompleted ? "bg-success" : "bg-warning text-dark")">
                Exam Schedules: @(Model.Prerequisites.AllExamSchedulesCompleted ? "Completed" : $"Pending ({Model.Prerequisites.IncompleteExamScheduleCount})")
            </span>
            <span class="badge @(Model.Prerequisites.AllEssaysGraded ? "bg-success" : "bg-warning text-dark")">
                Essay Grading: @(Model.Prerequisites.AllEssaysGraded ? "Completed" : $"Pending ({Model.Prerequisites.PendingEssayCount})")
            </span>
            <span class="badge @(Model.Prerequisites.SemesterTranscriptsLocked ? "bg-success" : "bg-warning text-dark")">
                Semester Lock: @(Model.Prerequisites.SemesterTranscriptsLocked ? "Locked" : $"Unlocked ({Model.Prerequisites.UnlockedSemesterTranscriptCount})")
            </span>
        </div>

        @if (Model.Prerequisites.MissingItems.Any())
        {
            <div class="alert alert-warning mb-0">
                <div class="fw-semibold mb-1">Cannot finalize yet:</div>
                <ul class="mb-0">
                    @foreach (var item in Model.Prerequisites.MissingItems)
                    {
                        <li>@item</li>
                    }
                </ul>
            </div>
        }
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body d-flex flex-wrap gap-2 justify-content-between align-items-center">
        <div class="small text-muted">
            Scope: <strong>@(string.IsNullOrWhiteSpace(Model.FacultyName) ? "All Faculties" : Model.FacultyName)</strong> |
            Academic Year: <strong>@Model.AcademicYear</strong> |
            Students: <strong>@Model.TotalStudents</strong> |
            Warning/Fail: <strong>@Model.WarningStudents.Count</strong>
        </div>
        <form method="post" action="/transcripts/year-end/finalize">
            @Html.AntiForgeryToken()
            <input type="hidden" name="academicYear" value="@Model.AcademicYear" />
            <input type="hidden" name="facultyId" value="@selectedFacultyId" />
            <input type="hidden" name="returnUrl" value="@currentUrl" />
            <button class="btn btn-danger" type="submit" @(canFinalize ? null : "disabled")
                    onclick="return confirm('Confirm finalizing year-end GPA? This action will lock year-end transcript records and cannot be undone without explicit unlock operation.')">
                Finalize Year-End
            </button>
        </form>
    </div>
</div>

<div class="row g-3">
    <div class="col-12 col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header fw-semibold">Preview Result</div>
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Student</th>
                            <th>Faculty</th>
                            <th>Class</th>
                            <th class="text-center">GPA 4.0</th>
                            <th class="text-center">GPA 10</th>
                            <th class="text-center">Credits</th>
                            <th class="text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Students.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted">No student records for selected scope.</td>
                            </tr>
                        }
                        @foreach (var item in Model.Students)
                        {
                            var statusClass = item.AcademicStatus == "Fail" ? "bg-danger" : item.AcademicStatus == "Warning" ? "bg-warning text-dark" : "bg-success";
                            <tr>
                                <td>@item.StudentName <span class="text-muted">(@item.StudentId)</span></td>
                                <td>@item.FacultyName</td>
                                <td>@item.ClassName</td>
                                <td class="text-center">@item.YearEndGpa4.ToString("0.00")</td>
                                <td class="text-center">@item.YearEndGpa10.ToString("0.00")</td>
                                <td class="text-center">@item.TotalCreditsEarned</td>
                                <td class="text-center">
                                    <span class="badge @statusClass">@item.AcademicStatus</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-12 col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header fw-semibold">Academic Warnings</div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    @if (!Model.WarningStudents.Any())
                    {
                        <li class="list-group-item text-muted">No warning/fail students in preview.</li>
                    }
                    @foreach (var warning in Model.WarningStudents)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <div class="fw-semibold">@warning.StudentName</div>
                                <div class="small text-muted">@warning.StudentId • GPA @warning.YearEndGpa4.ToString("0.00")</div>
                            </div>
                            <span class="badge @(warning.AcademicStatus == "Fail" ? "bg-danger" : "bg-warning text-dark")">@warning.AcademicStatus</span>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>
