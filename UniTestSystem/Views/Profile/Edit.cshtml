@model UniTestSystem.ViewModels.Profile.ProfileViewModel
@{
    ViewData["Title"] = "Chỉnh sửa hồ sơ";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3 class="card-title mb-0"><i class="bi bi-person-circle me-2"></i>Chỉnh sửa hồ sơ</h3>
                </div>
                <div class="card-body p-4">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="Edit" asp-controller="Profile" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <div class="text-center mb-4">
                            @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                            {
                                <img src="@Model.AvatarUrl" class="rounded-circle img-thumbnail" style="width: 150px; height: 150px; object-fit: cover;" alt="Avatar" />
                            }
                            else
                            {
                                <i class="bi bi-person-circle" style="font-size: 150px; color: #6c757d;"></i>
                            }
                            <div class="mt-2">
                                <label for="AvatarFile" class="form-label d-block">Ảnh đại diện</label>
                                <input id="AvatarFile" name="avatarFile" type="file" class="form-control d-inline-block w-auto" accept="image/*" />
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Họ và tên</label>
                                <input asp-for="Name" class="form-control" placeholder="Nhập họ tên" />
                                <span class="text-danger" asp-validation-for="Name"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Email</label>
                                <input asp-for="Email" class="form-control" placeholder="email@example.com" />
                                <span class="text-danger" asp-validation-for="Email"></span>
                                <div class="form-text">Dùng để đăng nhập hệ thống.</div>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label">Năm học</label>
                                <select asp-for="AcademicYear" class="form-select">
                                    <option value="Năm 1">Năm 1</option>
                                    <option value="Năm 2">Năm 2</option>
                                    <option value="Năm 3">Năm 3</option>
                                    <option value="Năm 4">Năm 4</option>
                                    <option value="Khác">Khác</option>
                                </select>
                                <span class="text-danger" asp-validation-for="AcademicYear"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label">Mã lớp</label>
                                <input asp-for="StudentClassId" class="form-control" readonly />
                                <div class="form-text">Liên hệ Giáo vụ để đổi lớp.</div>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label">Khoa</label>
                                <input asp-for="FacultyName" class="form-control" readonly />
                            </div>

                            <div class="col-12 mb-3">
                                <label class="form-label">Chuyên ngành</label>
                                <input asp-for="Major" class="form-control" readonly />
                            </div>
                            
                            <div class="col-12 mb-3">
                                <label class="form-label">Vai trò</label>
                                <input class="form-control" value="@Model.RoleName" readonly disabled />
                                <div class="form-text">Phân quyền do Admin quản lý.</div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <div>
                                <button type="submit" class="btn btn-primary px-4">
                                    <i class="bi bi-save me-1"></i> Lưu thay đổi
                                </button>
                                <a class="btn btn-outline-secondary ms-2" asp-action="Index" asp-controller="UserDashboard">Hủy</a>
                            </div>
                            <a class="btn btn-link text-decoration-none" asp-action="ChangePassword" asp-controller="Profile">
                                <i class="bi bi-key me-1"></i> Đổi mật khẩu
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
