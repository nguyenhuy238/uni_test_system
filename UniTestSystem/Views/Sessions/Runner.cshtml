@model UniTestSystem.Domain.Session
@using UniTestSystem.Domain
@{
    var duration = (int)ViewBag.Duration;
    var testTitle = (string)(ViewBag.TestTitle ?? "Test Runner");
    var remainingSeconds = (int)(ViewBag.RemainingSeconds ?? (duration * 60));

    var ts = TimeSpan.FromSeconds(remainingSeconds);
    var initialMinutesTotal = Math.Max(0, (int)Math.Floor(ts.TotalMinutes));
    var initialSecondsOnly = Math.Max(0, ts.Seconds);
    var initialText = $"{initialMinutesTotal:D2}:{initialSecondsOnly:D2}";

    var snapshot = Model.StudentAnswers?.OrderBy(a => a.QuestionId).Select(a => a.Question).Where(q => q != null).Cast<Question>().ToList() ?? new List<UniTestSystem.Domain.Question>();
    var questionCount = snapshot.Count;

    ViewData["Title"] = testTitle;
}

@section HeadScripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
}

<style>
    /* Header */
    .runner-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: #fff;
        border-bottom: 1px solid #e5e7eb;
    }

        .runner-header .bar {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: .75rem 0;
        }

    .badge {
        border-radius: 999px;
        padding: .25rem .6rem;
        font-size: .85rem
    }

    .badge-info {
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe
    }

    .actions {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap
    }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        border: 1px solid transparent;
        border-radius: .5rem;
        padding: .5rem .9rem;
        font-weight: 600;
        cursor: pointer
    }

    .btn-primary {
        background: #2563eb;
        color: #fff
    }

    .btn-secondary {
        background: #f3f4f6
    }

    .btn-danger {
        background: #dc2626;
        color: #fff
    }

    .btn:disabled {
        opacity: .7;
        cursor: not-allowed
    }

    .progress-wrap {
        display: flex;
        align-items: center;
        gap: .5rem
    }

    .progress {
        height: 10px;
        background: #e5e7eb;
        border-radius: 999px;
        overflow: hidden;
        min-width: 200px
    }

        .progress > span {
            display: block;
            height: 100%;
            background: #22c55e;
            width: 0%
        }

    .hint {
        font-size: .9rem;
        color: #6b7280
    }

    /* Layout: sidebar nhỏ, main rộng */
    .layout {
        display: grid;
        grid-template-columns: 220px 1fr;
        gap: 1.5rem;
        max-width: 1300px;
        margin: 0 auto;
        padding: 1rem 1rem 2rem;
    }

    @@media (max-width: 900px) {
        .layout {
            grid-template-columns: 1fr;
        }
    }

    .sidebar {
        position: sticky;
        top: 72px;
        align-self: start;
        border: 1px solid #e5e7eb;
        border-radius: .9rem;
        padding: .85rem;
        background: #fff;
        box-shadow: 0 2px 8px rgba(0,0,0,.04);
    }

    .side-sec-title {
        font-weight: 800;
        font-size: .95rem;
        margin: .25rem 0 .5rem;
    }

    .timer-box {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        border-radius: .7rem;
        padding: .55rem .7rem;
        margin-bottom: .7rem;
        font-weight: 800;
        color: #1d4ed8;
    }

    /* Legend */
    .legend {
        display: flex;
        gap: .6rem;
        align-items: center;
        flex-wrap: wrap;
        margin: .4rem 0 .9rem;
    }

        .legend .item {
            display: flex;
            align-items: center;
            gap: .35rem;
            font-size: .85rem;
            color: #475569;
        }

        .legend .box {
            width: 18px;
            height: 18px;
            border-radius: 6px;
        }

    .box-ans {
        background: #22c55e;
    }

    .box-un {
        background: #f87171;
    }

    .box-flag {
        background: #7c3aed;
    }

    .filter-row {
        display: flex;
        gap: .5rem;
        align-items: center;
        justify-content: space-between;
        margin-bottom: .6rem;
    }

    .small {
        font-size: .85rem;
        color: #64748b;
    }

    /* Navigator: lưới chip to, màu rõ ràng */
    .qnav {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(42px,1fr));
        gap: .5rem;
    }

    .qchip {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        cursor: pointer;
        user-select: none;
        transition: all .15s;
        border: 2px solid transparent;
        background: #f1f5f9;
        color: #0f172a;
    }

        .qchip:hover {
            transform: translateY(-1px);
            box-shadow: 0 2px 10px rgba(0,0,0,.06);
        }

        .qchip.unanswered {
            background: #fef2f2;
            border-color: #fca5a5;
            color: #991b1b;
        }

        .qchip.answered {
            background: #dcfce7;
            border-color: #22c55e;
            color: #065f46;
        }

        .qchip.flagged {
            background: #ede9fe;
            border-color: #7c3aed;
            color: #4c1d95;
        }

        .qchip.active {
            box-shadow: 0 0 0 3px #60a5fa;
        }

    /* Main: rộng, thưa, dễ đọc */
    .main {
        min-width: 0;
    }

    .question {
        padding: 1.25rem;
        border: 1px solid #e5e7eb;
        border-radius: .9rem;
        margin-bottom: 1.6rem;
        background: #fff;
        box-shadow: 0 2px 8px rgba(0,0,0,.04);
        scroll-margin-top: 100px;
    }

    .q-title {
        font-size: 1.05rem;
        font-weight: 800;
        margin-bottom: .8rem;
        display: flex;
        align-items: center;
        gap: .6rem;
        flex-wrap: wrap;
    }

    .q-options > div {
        margin: .4rem 0
    }

    .matching-board, .dragdrop-board {
        display: grid;
        gap: .7rem;
    }

    .match-row {
        display: grid;
        grid-template-columns: minmax(160px, 1fr) minmax(220px, 1.2fr);
        gap: .7rem;
        align-items: center;
    }

    .match-left {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: .6rem;
        padding: .5rem .65rem;
        font-weight: 600;
        color: #0f172a;
    }

    .dd-help {
        font-size: .85rem;
        color: #475569;
    }

    .dd-token-pool {
        display: flex;
        flex-wrap: wrap;
        gap: .5rem;
    }

    .dd-token {
        border: 1px solid #93c5fd;
        background: #eff6ff;
        color: #1d4ed8;
        border-radius: 999px;
        padding: .35rem .75rem;
        font-weight: 700;
        cursor: grab;
    }

    .dd-token.active {
        border-color: #2563eb;
        background: #dbeafe;
        box-shadow: 0 0 0 2px rgba(37, 99, 235, .25);
    }

    .dd-token.used {
        opacity: .55;
    }

    .dd-slot-list {
        display: grid;
        gap: .55rem;
    }

    .dd-slot-row {
        display: grid;
        grid-template-columns: minmax(130px, 1fr) minmax(220px, 1.5fr) auto;
        gap: .6rem;
        align-items: center;
    }

    .dd-slot-label {
        font-weight: 700;
        color: #334155;
    }

    .dd-slot {
        border: 1px dashed #94a3b8;
        background: #f8fafc;
        color: #334155;
        border-radius: .6rem;
        padding: .5rem .65rem;
        text-align: left;
        min-height: 40px;
    }

    .dd-slot.filled {
        border-style: solid;
        border-color: #22c55e;
        background: #f0fdf4;
        color: #14532d;
        font-weight: 700;
    }

    .dd-slot.drag-over {
        border-color: #2563eb;
        background: #dbeafe;
    }

    .dd-slot-clear {
        border: 1px solid #cbd5e1;
        background: #fff;
        color: #334155;
        border-radius: .45rem;
        padding: .35rem .55rem;
        font-size: .82rem;
    }

    @@media (max-width: 900px) {
        .match-row, .dd-slot-row {
            grid-template-columns: 1fr;
        }
    }

    .flag-btn {
        background: #f5f3ff;
        color: #6d28d9;
        border: 1px solid #ddd6fe;
        border-radius: 10px;
        padding: .28rem .6rem;
        font-weight: 800;
        cursor: pointer;
    }

        .flag-btn.active {
            background: #c7d2fe;
            color: #1e3a8a;
            border-color: #93c5fd;
        }

    .unanswered {
        outline: 2px dashed #f59e0b;
        outline-offset: 4px
    }

    .sync-indicator {
        position: fixed;
        right: 16px;
        top: 16px;
        z-index: 1200;
        border-radius: 999px;
        padding: .45rem .8rem;
        font-size: .85rem;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        border: 1px solid transparent;
        background: #ecfeff;
        color: #155e75;
        box-shadow: 0 6px 16px rgba(0, 0, 0, .12);
    }

    .sync-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        display: inline-block;
        flex: 0 0 8px;
    }

    .sync-ok {
        background: #f0fdf4;
        border-color: #bbf7d0;
        color: #166534;
    }

    .sync-pending {
        background: #fffbeb;
        border-color: #fde68a;
        color: #92400e;
    }

    .sync-error {
        background: #fef2f2;
        border-color: #fecaca;
        color: #991b1b;
    }

    .sync-ok .sync-dot {
        background: #16a34a;
    }

    .sync-pending .sync-dot {
        background: #f59e0b;
    }

    .sync-error .sync-dot {
        background: #dc2626;
    }

    .hub-indicator {
        position: fixed;
        right: 16px;
        top: 62px;
        z-index: 1200;
        border-radius: 999px;
        padding: .45rem .8rem;
        font-size: .85rem;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        border: 1px solid transparent;
        box-shadow: 0 6px 16px rgba(0, 0, 0, .12);
    }

    .hub-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        display: inline-block;
        flex: 0 0 8px;
    }

    .hub-connected {
        background: #f0fdf4;
        border-color: #bbf7d0;
        color: #166534;
    }

    .hub-connected .hub-dot {
        background: #16a34a;
    }

    .hub-reconnecting {
        background: #fffbeb;
        border-color: #fde68a;
        color: #92400e;
    }

    .hub-reconnecting .hub-dot {
        background: #f59e0b;
    }

    .hub-disconnected {
        background: #fef2f2;
        border-color: #fecaca;
        color: #991b1b;
    }

    .hub-disconnected .hub-dot {
        background: #dc2626;
    }
</style>

<div class="runner-header">
    <div class="bar container" style="max-width:1300px; margin:0 auto;">
        <div style="flex:1 1 auto">
            <div style="font-size:1.1rem;font-weight:800">@testTitle</div>
            <div class="hint">Session: <b>@Model.Id</b></div>
        </div>
        <div class="progress-wrap">
            <div class="progress" aria-label="Progress"><span id="pg"></span></div>
            <div><span id="pgtext">0</span>/<span id="pgtotal">@questionCount</span> answered</div>
        </div>
        <div><span class="badge badge-info">Time left: <span id="t">@initialText</span></span></div>
        <div class="actions">
            <button type="button" class="btn btn-secondary" id="saveLocalBtn" title="Save draft to this device">Save draft</button>
            <button type="button" class="btn btn-danger" id="clearLocalBtn" title="Clear local draft">Clear draft</button>
            <button type="button" class="btn btn-primary" id="submitBtn">Submit & Finish</button>
        </div>
    </div>
</div>

<div id="syncIndicator" class="sync-indicator sync-ok" role="status" aria-live="polite">
    <span class="sync-dot"></span>
    <span id="syncIndicatorText">Đã lưu</span>
</div>

<div id="hubIndicator" class="hub-indicator hub-reconnecting" role="status" aria-live="polite">
    <span class="hub-dot"></span>
    <span id="hubIndicatorText">Đang kết nối realtime...</span>
</div>

<div class="layout">
    <aside class="sidebar" id="sidebar">
        <div class="timer-box">
            <span>Time left</span>
            <span id="t_side">@initialText</span>
        </div>

        <div class="filter-row">
            <div class="side-sec-title">Questions</div>
            <label class="small"><input type="checkbox" id="onlyFlaggedChk" /> Only flagged</label>
        </div>

        <div class="legend">
            <span class="item"><span class="box box-ans"></span> Answered</span>
            <span class="item"><span class="box box-un"></span> Unanswered</span>
            <span class="item"><span class="box box-flag"></span> Flagged</span>
        </div>

        <div class="qnav" id="qnav">
            @for (int i = 0; i < questionCount; i++)
            {
                var q = snapshot[i];
                <div class="qchip unanswered" data-qindex="@i" data-qid="@q.Id" tabindex="0">@((i + 1).ToString())</div>
            }
        </div>
    </aside>

    <main class="main">
        <form id="f" autocomplete="off">
            @for (int qi = 0; qi < questionCount; qi++)
            {
                var q = snapshot[qi];
                var qAnchor = $"q-{q.Id}";
                <div class="question" id="@qAnchor" data-qid="@q.Id" data-qindex="@qi" data-qtype="@q.Type">
                    <div class="q-title">
                        @(qi + 1). @q.Content
                        <button type="button" class="flag-btn" data-flag-qid="@q.Id">★ Flag</button>
                    </div>

                    @if (q.Media?.Any() ?? false)
                    {
                        <div class="mb-2">
                            <partial name="~/Views/Shared/_MediaViewer.cshtml" model="q.Media" />
                        </div>
                    }

                    @{
                        var opts = q.Options.Where(o => !o.IsDeleted).OrderBy(o => o.Id).ToList();
                    }
                    @if (q.Type == QType.MCQ)
                    {
                        <div class="q-options">
                            @for (int i = 0; i < opts.Count; i++)
                            {
                                var label = ((char)('A' + i)).ToString();
                                var rid = $"r_{q.Id}_{label}";
                                <div>
                                    <input id="@rid" type="radio" name="@q.Id" value="@opts[i].Id" />
                                    <label for="@rid">@label) @opts[i].Content</label>
                                </div>
                            }
                        </div>
                    }
                    else if (q.Type == QType.TrueFalse)
                    {
                        if (opts.Count > 0)
                        {
                            <div class="q-options">
                                @for (int i = 0; i < opts.Count; i++)
                                {
                                    var rid = $"r_{q.Id}_{i}";
                                    <div>
                                        <input id="@rid" type="radio" name="@q.Id" value="@opts[i].Id" />
                                        <label for="@rid">@opts[i].Content</label>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="hint text-danger">True/False question is missing options.</div>
                        }
                    }
                    else if (q.Type == QType.Matching)
                    {
                        var pairs = (q.MatchingPairs ?? new List<MatchPair>())
                            .Where(p => !string.IsNullOrWhiteSpace(p.L) && !string.IsNullOrWhiteSpace(p.R))
                            .ToList();
                        var rightOptions = pairs
                            .Select(p => p.R.Trim())
                            .Where(v => !string.IsNullOrWhiteSpace(v))
                            .Distinct(StringComparer.OrdinalIgnoreCase)
                            .OrderBy(v => v, StringComparer.OrdinalIgnoreCase)
                            .ToList();
                        <div class="matching-board" data-match-question="@q.Id">
                            <input type="hidden" class="structured-answer" name="@q.Id" />
                            @if (pairs.Count == 0)
                            {
                                <div class="hint text-danger">Matching question has no configured pairs.</div>
                            }
                            else
                            {
                                @foreach (var pair in pairs)
                                {
                                    <div class="match-row">
                                        <div class="match-left">@pair.L</div>
                                        <select class="form-select match-select" data-left="@pair.L">
                                            <option value="">-- Select match --</option>
                                            @foreach (var option in rightOptions)
                                            {
                                                <option value="@option">@option</option>
                                            }
                                        </select>
                                    </div>
                                }
                            }
                        </div>
                    }
                    else if (q.Type == QType.DragDrop)
                    {
                        var tokens = (q.DragDrop?.Tokens ?? new List<string>())
                            .Select(t => t?.Trim())
                            .Where(t => !string.IsNullOrWhiteSpace(t))
                            .Select(t => t!)
                            .Distinct(StringComparer.OrdinalIgnoreCase)
                            .OrderBy(t => t, StringComparer.OrdinalIgnoreCase)
                            .ToList();
                        var slots = (q.DragDrop?.Slots ?? new List<DragSlot>())
                            .Where(s => !string.IsNullOrWhiteSpace(s.Name))
                            .ToList();
                        <div class="dragdrop-board" data-dd-question="@q.Id">
                            <input type="hidden" class="structured-answer" name="@q.Id" />
                            @if (tokens.Count == 0 || slots.Count == 0)
                            {
                                <div class="hint text-danger">DragDrop question is missing tokens or slots.</div>
                            }
                            else
                            {
                                <div class="dd-help">Drag token to slot, or click a token then click slot.</div>
                                <div class="dd-token-pool">
                                    @foreach (var token in tokens)
                                    {
                                        <button type="button" class="dd-token" draggable="true" data-token="@token">@token</button>
                                    }
                                </div>
                                <div class="dd-slot-list">
                                    @foreach (var slot in slots)
                                    {
                                        <div class="dd-slot-row">
                                            <div class="dd-slot-label">@slot.Name</div>
                                            <button type="button" class="dd-slot" data-slot="@slot.Name" data-assigned="">Drop token here</button>
                                            <button type="button" class="dd-slot-clear">Clear</button>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <textarea class="form-control essay-answer" name="@q.Id" rows="4" placeholder="Type your answer here..."></textarea>
                    }
                    <div class="hint">Question ID: @q.Id • Type: @q.Type</div>
                </div>
            }
        </form>

        <div class="actions" style="margin:1rem 0 2rem">
            <button type="button" class="btn btn-secondary" id="saveLocalBtn2">Save draft</button>
            <button type="button" class="btn btn-primary" id="submitBtn2">Submit & Finish</button>
        </div>

        <p class="hint">Answers are auto-saved to server and this device. You can still press <i>Submit &amp; Finish</i> to finalize grading.</p>
    </main>
</div>

<script>
    /* ===== Timer with pause/resume ===== */
    let secs = @remainingSeconds;
    let running = true;
    let timer = null;
    let examHubConnection = null;
    let timeUpNoticeShown = false;

    const elTimeTop = document.getElementById('t');
    const elTimeSide = document.getElementById('t_side');
    const sid = "@Model.Id";
    const totalQs = @questionCount;
    const DEVICE_FP_KEY = 'unitest_device_fp';
    const hubIndicatorEl = document.getElementById('hubIndicator');
    const hubIndicatorTextEl = document.getElementById('hubIndicatorText');

    function setHubStatus(cssClass, message){
        if(!hubIndicatorEl || !hubIndicatorTextEl) return;
        hubIndicatorEl.classList.remove('hub-connected', 'hub-reconnecting', 'hub-disconnected');
        hubIndicatorEl.classList.add(cssClass);
        hubIndicatorTextEl.textContent = message;
    }

    function isHubConnected(){
        return !!(examHubConnection && window.signalR && examHubConnection.state === signalR.HubConnectionState.Connected);
    }

    function payloadValue(obj, camel, pascal){
        if(!obj || typeof obj !== 'object') return undefined;
        if(Object.prototype.hasOwnProperty.call(obj, camel)) return obj[camel];
        if(Object.prototype.hasOwnProperty.call(obj, pascal)) return obj[pascal];
        return undefined;
    }

    function getDeviceFingerprint(){
        let fp = localStorage.getItem(DEVICE_FP_KEY);
        if(!fp){
            fp = (crypto?.randomUUID?.() ?? `${Date.now()}_${Math.random()}`).toString();
            localStorage.setItem(DEVICE_FP_KEY, fp);
        }
        return fp;
    }

    function authFetch(url, options){
        const opts = options || {};
        opts.headers = Object.assign({}, opts.headers || {}, { 'X-Device-Fingerprint': getDeviceFingerprint() });
        return fetch(url, opts);
    }

    function fmt(ss){ const m = Math.floor(ss/60).toString().padStart(2,'0'); const s = (ss%60).toString().padStart(2,'0'); return `${m}:${s}`; }
    function renderTime(){ const t = fmt(secs); elTimeTop.textContent = t; elTimeSide.textContent = t; }

    function startTimer(){
        if(timer) return;
        timer = setInterval(()=>{
            if(!running) return;
            secs = Math.max(0, secs - 1);
            renderTime();
            if(secs === 120){ toast("Only 2 minutes left. Please submit soon.", "warn"); }
            if(secs <= 0){
                stopTimer();
                if(!timeUpNoticeShown){
                    timeUpNoticeShown = true;
                    toast("Time is up. Waiting for server auto-submit...", "warn");
                }
            }
        }, 1000);
    }
    function stopTimer(){
        running = false;
        if(timer){
            clearInterval(timer);
            timer = null;
        }
    }

    function applyTimerSync(data){
        const remainingRaw = payloadValue(data, 'remainingSeconds', 'RemainingSeconds');
        const runningRaw = payloadValue(data, 'running', 'Running');
        if(typeof remainingRaw === 'number' && Number.isFinite(remainingRaw)){
            secs = Math.max(0, Math.floor(remainingRaw));
            if(secs > 0) timeUpNoticeShown = false;
        }
        if(typeof runningRaw === 'boolean'){
            running = runningRaw;
        }

        renderTime();
        if(running){
            startTimer();
        }else{
            stopTimer();
        }
    }

    async function connectExamHub(){
        if(!window.signalR){
            setHubStatus('hub-disconnected', 'Realtime unavailable - using REST fallback');
            return;
        }

        examHubConnection = new signalR.HubConnectionBuilder()
            .withUrl('/hubs/exam-session')
            .withAutomaticReconnect()
            .build();

        examHubConnection.on('TimerSync', (data)=>{
            applyTimerSync(data);
        });

        examHubConnection.on('SessionAutoSubmitted', ()=>{
            toast('Session auto-submitted by server.', 'warn');
            submitNow(true);
        });

        examHubConnection.on('SessionTerminated', ()=>{
            submitted = true;
            toast('Session was terminated by proctor. Redirecting...', 'warn');
            window.location = '/mytests';
        });

        examHubConnection.onreconnecting(()=>{
            setHubStatus('hub-reconnecting', 'Đang kết nối lại...');
        });

        examHubConnection.onreconnected(async ()=>{
            setHubStatus('hub-connected', 'Realtime connected');
            try{
                await examHubConnection.invoke('JoinSession', sid);
            }catch(e){}
        });

        examHubConnection.onclose(()=>{
            setHubStatus('hub-disconnected', 'Realtime disconnected - using REST fallback');
        });

        try{
            setHubStatus('hub-reconnecting', 'Đang kết nối realtime...');
            await examHubConnection.start();
            await examHubConnection.invoke('JoinSession', sid);
            setHubStatus('hub-connected', 'Realtime connected');
        }catch(e){
            setHubStatus('hub-disconnected', 'Realtime disconnected - using REST fallback');
        }
    }

    async function callResume(){
        if(isHubConnected()){
            try{
                await examHubConnection.invoke('ResumeTimer', sid);
                running = true;
                startTimer();
                return;
            }catch(e){}
        }

        try{
            const r = await authFetch(`/api/tests/sessions/${sid}/resume`, { method:'POST' });
            if(r.ok){
                const data = await r.json();
                secs = data.remainingSeconds ?? secs;
                running = !!data.running;
                renderTime();
                if(running){
                    startTimer();
                }else{
                    stopTimer();
                }
            }
        }catch(e){}
    }

    async function callPause(){
        if(isHubConnected()){
            try{
                await examHubConnection.invoke('PauseTimer', sid);
                running = false;
                stopTimer();
                return;
            }catch(e){}
        }

        try{
            const r = await authFetch(`/api/tests/sessions/${sid}/pause`, { method:'POST' });
            if(r.ok){
                const data = await r.json();
                secs = data.remainingSeconds ?? secs;
                running = !!data.running;
                renderTime();
                if(running){
                    startTimer();
                }else{
                    stopTimer();
                }
            }
        }catch(e){}
    }

        function logSessionEvent(actionType, detail){
            authFetch(`/api/tests/sessions/${sid}/log`, {
                method: 'POST',
                headers: { 'Content-Type':'application/json' },
                body: JSON.stringify({ actionType, detail })
            }).catch(()=>{});
        }

        renderTime();
        startTimer();
        callResume();
        connectExamHub();

        document.addEventListener('visibilitychange', ()=>{
            if(document.hidden){
                callPause();
                logSessionEvent('Blur', 'Document hidden');
            } else {
                callResume();
                logSessionEvent('Focus', 'Document visible');
            }
        });
        window.addEventListener('beforeunload', ()=>{
            try{
                const payload = JSON.stringify({
                    answers: collect(),
                    clientTimestamp: new Date().toISOString()
                });
                navigator.sendBeacon?.(`/api/tests/sessions/${sid}/save-answer`, new Blob([payload], { type: 'application/json' }));
            }catch(e){}
            if(examHubConnection){
                try{ examHubConnection.invoke('LeaveSession', sid); }catch(e){}
            }
            navigator.sendBeacon?.(`/api/tests/sessions/${sid}/pause`);
        });

    /* ===== Draft / Flags / Navigator ===== */
    const KEY = `runner_${sid}`;
    const KEY_FLAGS = `runner_flags_${sid}`;
    const KEY_SYNC_QUEUE = `runner_sync_queue_${sid}`;
    const MAX_SAVE_RETRY = 5;
    const SAVE_TIMEOUT_MS = 8000;
    const formEl = document.getElementById('f');
    const navEl = document.getElementById('qnav');
    const onlyFlaggedChk = document.getElementById('onlyFlaggedChk');
    const pgBar = document.getElementById('pg');
    const pgText = document.getElementById('pgtext');
    const syncIndicatorEl = document.getElementById('syncIndicator');
    const syncIndicatorTextEl = document.getElementById('syncIndicatorText');
    let saveSyncDebounceTO = null;
    let syncingQueue = false;
    let syncQueued = false;
    let submittedConflictNotified = false;

    function normalizeToken(value){
      return String(value ?? '').trim();
    }

    function parsePairAnswer(raw){
      const map = {};
      if(!raw) return map;

      const normalized = String(raw).replaceAll('||', '\n');
      normalized.split(/\r?\n/).forEach(line => {
        const idx = line.indexOf('=');
        if(idx <= 0) return;
        const key = normalizeToken(line.slice(0, idx));
        const val = normalizeToken(line.slice(idx + 1));
        if(!key) return;
        map[key.toLowerCase()] = val;
      });
      return map;
    }

    function resolveQuestionById(qid){
      return document.querySelector(`.question[data-qid="${CSS.escape(qid)}"]`);
    }

    function getQuestionTypeById(qid){
      const questionEl = resolveQuestionById(qid);
      return questionEl?.getAttribute('data-qtype') || '';
    }

    function getStructuredInput(questionEl, qid){
      return questionEl?.querySelector(`input.structured-answer[name="${CSS.escape(qid)}"]`);
    }

    function buildMatchingAnswer(questionEl){
      const parts = [];
      questionEl.querySelectorAll('.match-select').forEach(selectEl => {
        const left = normalizeToken(selectEl.getAttribute('data-left'));
        const right = normalizeToken(selectEl.value);
        if(left && right){
          parts.push(`${left}=${right}`);
        }
      });
      return parts.join('\n');
    }

    function applyMatchingAnswer(questionEl, raw){
      const answerMap = parsePairAnswer(raw);
      questionEl.querySelectorAll('.match-select').forEach(selectEl => {
        const left = normalizeToken(selectEl.getAttribute('data-left')).toLowerCase();
        const selectedRaw = answerMap[left] || '';
        if(!selectedRaw){
          selectEl.value = '';
          return;
        }

        const matched = Array.from(selectEl.options).find(opt =>
          normalizeToken(opt.value).toLowerCase() === selectedRaw.toLowerCase());
        selectEl.value = matched ? matched.value : '';
      });
    }

    function refreshDragDropBoard(boardEl){
      if(!boardEl) return;
      const usedTokens = new Set();
      boardEl.querySelectorAll('.dd-slot').forEach(slotEl => {
        const assigned = normalizeToken(slotEl.getAttribute('data-assigned'));
        slotEl.textContent = assigned || 'Drop token here';
        slotEl.classList.toggle('filled', !!assigned);
        if(assigned){
          usedTokens.add(assigned.toLowerCase());
        }
      });

      boardEl.querySelectorAll('.dd-token').forEach(tokenEl => {
        const token = normalizeToken(tokenEl.getAttribute('data-token')).toLowerCase();
        tokenEl.classList.toggle('used', usedTokens.has(token));
      });
    }

    function setActiveDragToken(boardEl, token){
      const active = normalizeToken(token);
      boardEl.setAttribute('data-active-token', active);
      boardEl.querySelectorAll('.dd-token').forEach(tokenEl => {
        tokenEl.classList.toggle('active', normalizeToken(tokenEl.getAttribute('data-token')) === active);
      });
    }

    function assignDragDropToken(boardEl, slotEl, token){
      if(!boardEl || !slotEl) return;
      const normalizedToken = normalizeToken(token);
      if(normalizedToken){
        boardEl.querySelectorAll('.dd-slot').forEach(otherSlot => {
          if(otherSlot !== slotEl && normalizeToken(otherSlot.getAttribute('data-assigned')).toLowerCase() === normalizedToken.toLowerCase()){
            otherSlot.setAttribute('data-assigned', '');
          }
        });
      }

      slotEl.setAttribute('data-assigned', normalizedToken);
      refreshDragDropBoard(boardEl);
    }

    function buildDragDropAnswer(questionEl){
      const parts = [];
      questionEl.querySelectorAll('.dd-slot').forEach(slotEl => {
        const slotName = normalizeToken(slotEl.getAttribute('data-slot'));
        const token = normalizeToken(slotEl.getAttribute('data-assigned'));
        if(slotName && token){
          parts.push(`${slotName}=${token}`);
        }
      });
      return parts.join('\n');
    }

    function applyDragDropAnswer(questionEl, raw){
      const answerMap = parsePairAnswer(raw);
      questionEl.querySelectorAll('.dd-slot').forEach(slotEl => {
        const slotName = normalizeToken(slotEl.getAttribute('data-slot')).toLowerCase();
        const assigned = answerMap[slotName] || '';
        slotEl.setAttribute('data-assigned', assigned);
      });

      const boardEl = questionEl.querySelector('.dragdrop-board');
      if(boardEl){
        setActiveDragToken(boardEl, '');
      }
      refreshDragDropBoard(boardEl);
    }

    function syncStructuredAnswerForQuestion(questionEl){
      if(!questionEl) return;
      const qid = questionEl.getAttribute('data-qid');
      const qtype = questionEl.getAttribute('data-qtype');
      const hidden = getStructuredInput(questionEl, qid);
      if(!hidden) return;

      if(qtype === 'Matching'){
        hidden.value = buildMatchingAnswer(questionEl);
      }else if(qtype === 'DragDrop'){
        hidden.value = buildDragDropAnswer(questionEl);
      }
    }

    function syncAllStructuredAnswers(){
      document.querySelectorAll('.question[data-qtype="Matching"], .question[data-qtype="DragDrop"]').forEach(syncStructuredAnswerForQuestion);
    }

    function applyStructuredAnswerToQuestion(questionEl, raw){
      if(!questionEl) return;
      const qtype = questionEl.getAttribute('data-qtype');
      if(qtype === 'Matching'){
        applyMatchingAnswer(questionEl, raw);
      }else if(qtype === 'DragDrop'){
        applyDragDropAnswer(questionEl, raw);
      }
      syncStructuredAnswerForQuestion(questionEl);
    }

    function collect(){
      syncAllStructuredAnswers();
      const data = {};
      formEl.querySelectorAll('[name]').forEach(e=>{
        if(e.type==='radio'){
          if(e.checked) data[e.name] = e.value;
        }else{
          data[e.name] = e.value ?? '';
        }
      });
      return data;
    }

    function applyDraft(draft){
      if(!draft) return;
      Object.entries(draft).forEach(([k,v])=>{
        const qtype = getQuestionTypeById(k);
        const questionEl = resolveQuestionById(k);
        if(qtype === 'Matching' || qtype === 'DragDrop'){
          const hidden = getStructuredInput(questionEl, k);
          if(hidden){
            hidden.value = v ?? '';
            applyStructuredAnswerToQuestion(questionEl, hidden.value);
          }
          return;
        }

        const els = formEl.querySelectorAll(`[name="${CSS.escape(k)}"]`);
        if(!els.length) return;
        const anyRadio = Array.from(els).some(e=>e.type==='radio');
        if(anyRadio){
          const target = formEl.querySelector(`[name="${CSS.escape(k)}"][value="${CSS.escape(v)}"]`);
          if(target){ target.checked = true; }
        }else{
          els[0].value = v ?? '';
        }
      });
      syncAllStructuredAnswers();
    }

    function saveDraft(silent=false){
      localStorage.setItem(KEY, JSON.stringify(collect()));
      if(!silent) toast("Draft saved on this device.");
    }

    function clearDraft(){
      localStorage.removeItem(KEY);
      toast("Local draft cleared.");
    }

    function getAnswerValueByQuestionId(qid){
      const qtype = getQuestionTypeById(qid);
      const questionEl = resolveQuestionById(qid);
      if(qtype === 'Matching' || qtype === 'DragDrop'){
        syncStructuredAnswerForQuestion(questionEl);
        const hidden = getStructuredInput(questionEl, qid);
        return hidden ? (hidden.value ?? '') : '';
      }

      const radios = formEl.querySelectorAll(`[name="${CSS.escape(qid)}"][type="radio"]`);
      if(radios.length){
        const checked = Array.from(radios).find(r => r.checked);
        return checked ? checked.value : '';
      }

      const field = formEl.querySelector(`[name="${CSS.escape(qid)}"]:not([type="radio"])`);
      return field ? (field.value ?? '') : '';
    }

    function resolveQuestionIdFromTarget(target){
      if(!target) return '';
      if(target.name) return target.name;
      const questionEl = target.closest('.question');
      return questionEl ? (questionEl.getAttribute('data-qid') || '') : '';
    }

    function handleQuestionAnswerChanged(qid){
      if(!qid) return;
      updateOneQuestion(qid);
      saveDraft(true);
      enqueueAnswerForSync(qid, getAnswerValueByQuestionId(qid), new Date().toISOString());
      scheduleQueueSync();
    }

    function loadSyncQueue(){
      try{
        const raw = localStorage.getItem(KEY_SYNC_QUEUE);
        const parsed = raw ? JSON.parse(raw) : [];
        return Array.isArray(parsed) ? parsed : [];
      }catch(e){
        return [];
      }
    }

    function saveSyncQueue(queue){
      localStorage.setItem(KEY_SYNC_QUEUE, JSON.stringify(queue || []));
    }

    function getQueueStats(){
      const queue = loadSyncQueue();
      const pendingCount = queue.filter(x => !x.failed).length;
      const failedCount = queue.filter(x => !!x.failed).length;
      return { queue, pendingCount, failedCount };
    }

    function setSyncIndicatorState(cssClass, message){
      if(!syncIndicatorEl || !syncIndicatorTextEl) return;
      syncIndicatorEl.classList.remove('sync-ok', 'sync-pending', 'sync-error');
      syncIndicatorEl.classList.add(cssClass);
      syncIndicatorTextEl.textContent = message;
    }

    function updateSyncIndicator(){
      const { pendingCount, failedCount } = getQueueStats();

      if(failedCount > 0){
        setSyncIndicatorState('sync-error', `Lỗi đồng bộ: ${failedCount} câu cần kiểm tra`);
        return;
      }

      if(!navigator.onLine && pendingCount > 0){
        setSyncIndicatorState('sync-error', `Mất kết nối - ${pendingCount} câu chưa lưu`);
        return;
      }

      if(pendingCount > 0){
        setSyncIndicatorState('sync-pending', `Đang lưu offline... (${pendingCount} câu chưa đồng bộ)`);
        return;
      }

      if(!navigator.onLine){
        setSyncIndicatorState('sync-pending', 'Mất kết nối - chờ mạng để đồng bộ');
        return;
      }

      setSyncIndicatorState('sync-ok', 'Đã lưu');
    }

    function enqueueAnswerForSync(questionId, answerValue, timestampIso){
      if(!questionId) return;
      const queue = loadSyncQueue().filter(x => x.questionId !== questionId);
      queue.push({
        sessionId: sid,
        questionId: questionId,
        answerId: answerValue ?? '',
        timestamp: timestampIso ?? new Date().toISOString(),
        retryCount: 0
      });
      saveSyncQueue(queue);
      updateSyncIndicator();
    }

    function enqueueAllAnswersForSync(){
      const answers = collect();
      let queue = loadSyncQueue().filter(x => !!x.failed);
      const timestampIso = new Date().toISOString();
      Object.entries(answers).forEach(([questionId, answerValue])=>{
        queue = queue.filter(x => x.questionId !== questionId);
        queue.push({
          sessionId: sid,
          questionId: questionId,
          answerId: answerValue ?? '',
          timestamp: timestampIso,
          retryCount: 0
        });
      });
      saveSyncQueue(queue);
      updateSyncIndicator();
    }

    function findQueueEntryIndex(queue, entry){
      return queue.findIndex(x =>
        x.sessionId === entry.sessionId &&
        x.questionId === entry.questionId &&
        x.timestamp === entry.timestamp &&
        !x.failed
      );
    }

    function markQueueEntryRetry(entry, forceFail){
      const queue = loadSyncQueue();
      const idx = findQueueEntryIndex(queue, entry);
      if(idx < 0){
        updateSyncIndicator();
        return;
      }

      const item = queue[idx];
      item.retryCount = Number(item.retryCount || 0) + 1;
      if(forceFail || item.retryCount >= MAX_SAVE_RETRY){
        item.failed = true;
        toast(`Câu ${item.questionId} chưa thể đồng bộ sau ${item.retryCount} lần thử.`, 'warn');
      }

      queue[idx] = item;
      saveSyncQueue(queue);
      updateSyncIndicator();
    }

    function markAllPendingAsFailed(){
      const queue = loadSyncQueue().map(x => x.failed ? x : { ...x, failed: true, retryCount: Math.max(Number(x.retryCount || 0), MAX_SAVE_RETRY) });
      saveSyncQueue(queue);
      updateSyncIndicator();
    }

    function removeQueueEntry(entry){
      const queue = loadSyncQueue();
      const idx = findQueueEntryIndex(queue, entry);
      if(idx >= 0){
        queue.splice(idx, 1);
        saveSyncQueue(queue);
      }
      updateSyncIndicator();
    }

    async function saveQueueEntryToServer(entry){
      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), SAVE_TIMEOUT_MS);
      try{
        return await authFetch(`/api/tests/sessions/${sid}/save-answer`, {
          method: 'POST',
          headers: { 'Content-Type':'application/json' },
          body: JSON.stringify({
            answers: { [entry.questionId]: entry.answerId ?? '' },
            clientTimestamp: entry.timestamp,
            questionClientTimestamps: { [entry.questionId]: entry.timestamp }
          }),
          signal: controller.signal
        });
      }finally{
        clearTimeout(timeoutId);
      }
    }

    async function processSingleQueueEntry(entry){
      try{
        const r = await saveQueueEntryToServer(entry);
        if(r.ok){
          removeQueueEntry(entry);
          return 'success';
        }

        if(r.status === 409){
          let code = '';
          let message = 'Phiên làm bài đã được nộp ở thiết bị khác.';
          try{
            const payload = await r.json();
            code = payload?.code ?? '';
            message = payload?.message ?? message;
          }catch(e){}

          markQueueEntryRetry(entry, true);
          if(code === 'SESSION_ALREADY_SUBMITTED'){
            markAllPendingAsFailed();
          }
          if(!submittedConflictNotified){
            submittedConflictNotified = true;
            toast(message, 'warn');
          }
          return 'stop';
        }

        const nonRetryable = r.status >= 400 && r.status < 500;
        markQueueEntryRetry(entry, nonRetryable);
        return 'stop';
      }catch(e){
        markQueueEntryRetry(entry, false);
        return 'stop';
      }
    }

    async function syncOfflineQueue(){
      if(syncingQueue){
        syncQueued = true;
        return;
      }

      if(!navigator.onLine){
        updateSyncIndicator();
        return;
      }

      syncingQueue = true;
      try{
        while(navigator.onLine){
          const next = loadSyncQueue().find(x => !x.failed);
          if(!next){
            break;
          }

          const state = await processSingleQueueEntry(next);
          if(state !== 'success'){
            break;
          }
        }
      }finally{
        syncingQueue = false;
        updateSyncIndicator();
        if(syncQueued){
          syncQueued = false;
          setTimeout(syncOfflineQueue, 250);
        }
      }
    }

    function scheduleQueueSync(){
      if(saveSyncDebounceTO) clearTimeout(saveSyncDebounceTO);
      saveSyncDebounceTO = setTimeout(syncOfflineQueue, 1200);
    }

    async function ensureQueueSyncedBeforeSubmit(){
      await syncOfflineQueue();
      const { pendingCount, failedCount } = getQueueStats();
      if(pendingCount > 0 || failedCount > 0){
        toast('Còn câu trả lời chưa đồng bộ. Vui lòng chờ có mạng rồi thử nộp lại.', 'warn');
        return false;
      }

      return true;
    }

    function loadFlags(){ try{ return JSON.parse(localStorage.getItem(KEY_FLAGS) || '{}'); }catch(e){ return {}; } }
    function saveFlags(flags){ localStorage.setItem(KEY_FLAGS, JSON.stringify(flags||{})); }

    function isAnsweredById(qid){
      const qtype = getQuestionTypeById(qid);
      const questionEl = resolveQuestionById(qid);
      if(qtype === 'Matching'){
        const selects = questionEl?.querySelectorAll('.match-select') || [];
        return selects.length > 0 && Array.from(selects).every(selectEl => normalizeToken(selectEl.value).length > 0);
      }
      if(qtype === 'DragDrop'){
        const slots = questionEl?.querySelectorAll('.dd-slot') || [];
        return slots.length > 0 && Array.from(slots).every(slotEl => normalizeToken(slotEl.getAttribute('data-assigned')).length > 0);
      }

      const radios = formEl.querySelectorAll(`[name="${CSS.escape(qid)}"][type="radio"]`);
      if(radios.length){ return Array.from(radios).some(r=>r.checked); }
      const ta = formEl.querySelector(`[name="${CSS.escape(qid)}"]:not([type])`);
      return !!(ta && String(ta.value||'').trim().length>0);
    }

    /* Cập nhật 1 câu hỏi ngay lập tức */
    function updateOneQuestion(qid){
      const ok = isAnsweredById(qid);
      const qb = document.querySelector(`.question[data-qid="${CSS.escape(qid)}"]`);
      if(qb){ qb.classList.toggle('unanswered', !ok); }

      const chip = navEl.querySelector(`.qchip[data-qid="${CSS.escape(qid)}"]`);
      if(chip){
        chip.classList.toggle('answered', ok);
        chip.classList.toggle('unanswered', !ok);
        // không động vào flagged ở đây
        if(onlyFlaggedChk?.checked){
          const flags = loadFlags();
          chip.style.display = flags[qid] ? '' : 'none';
        }
      }
      refreshProgress();
    }

    /* Cập nhật progress nhanh */
    function refreshProgress(){
      const answered = navEl.querySelectorAll('.qchip.answered').length;
      pgText.textContent = answered.toString();
      const pct = Math.max(0, Math.min(100, Math.round(answered * 100 / totalQs)));
      pgBar.style.width = pct + '%';
    }

    /* Refresh toàn bộ navigator (khi bật tắt filter hoặc sync flags) */
    function refreshNavigatorFull(){
      const flags = loadFlags();
      let answered = 0;
      document.querySelectorAll('.question').forEach(qb=>{
        const qid = qb.getAttribute('data-qid');
        const ok = isAnsweredById(qid);
        qb.classList.toggle('unanswered', !ok);
        if(ok) answered++;

        const chip = navEl.querySelector(`.qchip[data-qid="${CSS.escape(qid)}"]`);
        if(chip){
          chip.classList.toggle('answered', ok);
          chip.classList.toggle('unanswered', !ok);
          chip.classList.toggle('flagged', !!flags[qid]);
          chip.style.display = (!onlyFlaggedChk?.checked || flags[qid]) ? '' : 'none';
        }
      });
      pgText.textContent = answered.toString();
      const pct = Math.max(0, Math.min(100, Math.round(answered * 100 / totalQs)));
      pgBar.style.width = pct + '%';
    }

    /* DragDrop interactions */
    formEl.addEventListener('click', (e)=>{
      const tokenBtn = e.target.closest('.dd-token');
      if(tokenBtn){
        const boardEl = tokenBtn.closest('.dragdrop-board');
        if(!boardEl) return;
        const token = normalizeToken(tokenBtn.getAttribute('data-token'));
        const current = normalizeToken(boardEl.getAttribute('data-active-token'));
        setActiveDragToken(boardEl, current === token ? '' : token);
        return;
      }

      const slotEl = e.target.closest('.dd-slot');
      if(slotEl){
        const boardEl = slotEl.closest('.dragdrop-board');
        const active = normalizeToken(boardEl?.getAttribute('data-active-token'));
        if(active){
          assignDragDropToken(boardEl, slotEl, active);
          setActiveDragToken(boardEl, '');
          const qid = resolveQuestionIdFromTarget(slotEl);
          handleQuestionAnswerChanged(qid);
        }
        return;
      }

      const clearBtn = e.target.closest('.dd-slot-clear');
      if(clearBtn){
        const slotRow = clearBtn.closest('.dd-slot-row');
        const slot = slotRow?.querySelector('.dd-slot');
        const boardEl = clearBtn.closest('.dragdrop-board');
        if(slot){
          assignDragDropToken(boardEl, slot, '');
          const qid = resolveQuestionIdFromTarget(clearBtn);
          handleQuestionAnswerChanged(qid);
        }
      }
    });

    formEl.addEventListener('dragstart', (e)=>{
      const tokenBtn = e.target.closest('.dd-token');
      if(!tokenBtn || !e.dataTransfer) return;
      e.dataTransfer.effectAllowed = 'move';
      e.dataTransfer.setData('text/plain', normalizeToken(tokenBtn.getAttribute('data-token')));
    });

    formEl.addEventListener('dragover', (e)=>{
      const slotEl = e.target.closest('.dd-slot');
      if(!slotEl) return;
      e.preventDefault();
      slotEl.classList.add('drag-over');
    });

    formEl.addEventListener('dragleave', (e)=>{
      const slotEl = e.target.closest('.dd-slot');
      if(!slotEl) return;
      slotEl.classList.remove('drag-over');
    });

    formEl.addEventListener('drop', (e)=>{
      const slotEl = e.target.closest('.dd-slot');
      if(!slotEl) return;
      e.preventDefault();
      slotEl.classList.remove('drag-over');
      const token = normalizeToken(e.dataTransfer?.getData('text/plain'));
      if(!token) return;
      const boardEl = slotEl.closest('.dragdrop-board');
      assignDragDropToken(boardEl, slotEl, token);
      const qid = resolveQuestionIdFromTarget(slotEl);
      handleQuestionAnswerChanged(qid);
    });

    /* Sự kiện input/change -> cập nhật tức thì */
    formEl.addEventListener('change', (e)=>{
      const qid = resolveQuestionIdFromTarget(e.target);
      if(qid){
        handleQuestionAnswerChanged(qid);
      }
    });
    formEl.addEventListener('input', (e)=>{
      const qid = resolveQuestionIdFromTarget(e.target);
      if(qid){
        handleQuestionAnswerChanged(qid);
      }
    });

    /* Bật filter chỉ flagged */
    if(onlyFlaggedChk){ onlyFlaggedChk.addEventListener('change', refreshNavigatorFull); }

    /* Click chip để nhảy */
    navEl.addEventListener('click', (e)=>{
      const chip = e.target.closest('.qchip');
      if(!chip) return;
      const idx = parseInt(chip.getAttribute('data-qindex'),10);
      const qb = document.querySelector(`.question[data-qindex="${idx}"]`);
      if(qb){ qb.scrollIntoView({behavior:'smooth', block:'start'}); setActiveChip(idx); }
    });
    function setActiveChip(index){
      navEl.querySelectorAll('.qchip').forEach(c=>c.classList.remove('active'));
      const chip = navEl.querySelector(`.qchip[data-qindex="${index}"]`);
      if(chip){ chip.classList.add('active'); }
    }

    /* Sync active chip theo cuộn */
    let tAdminottleTO=null;
    window.addEventListener('scroll', ()=>{
      if(tAdminottleTO) return;
      tAdminottleTO = setTimeout(()=>{
        tAdminottleTO=null;
        const qs = Array.from(document.querySelectorAll('.question'));
        let bestIdx = 0, bestTop = Infinity;
        qs.forEach(q=>{
          const rect = q.getBoundingClientRect();
          const top = Math.abs(rect.top - 120);
          const idx = parseInt(q.getAttribute('data-qindex'),10);
          if(top < bestTop){ bestTop=top; bestIdx=idx; }
        });
        setActiveChip(bestIdx);
      }, 120);
    });

    /* Flag buttons */
    document.addEventListener('click', (e)=>{
      const btn = e.target.closest('.flag-btn');
      if(!btn) return;
      const qid = btn.getAttribute('data-flag-qid');
      const flags = loadFlags();
      flags[qid] = !flags[qid];
      saveFlags(flags);
      btn.classList.toggle('active', !!flags[qid]);

      const chip = navEl.querySelector(`.qchip[data-qid="${CSS.escape(qid)}"]`);
      if(chip){
        chip.classList.toggle('flagged', !!flags[qid]);
        if(onlyFlaggedChk?.checked){
          chip.style.display = flags[qid] ? '' : 'none';
        }
      }
    });

    /* Leave warning */
    let submitted = false;
    window.addEventListener('beforeunload', (e)=>{ if(!submitted){ e.preventDefault(); e.returnValue = ''; } });

    /* Submit */
    const submitBtn = document.getElementById('submitBtn');
    const submitBtn2 = document.getElementById('submitBtn2');
    const saveLocalBtn = document.getElementById('saveLocalBtn');
    const saveLocalBtn2 = document.getElementById('saveLocalBtn2');
    const clearLocalBtn = document.getElementById('clearLocalBtn');

    saveLocalBtn.addEventListener('click', async ()=>{
      saveDraft(true);
      enqueueAllAnswersForSync();
      await syncOfflineQueue();
      const { pendingCount, failedCount } = getQueueStats();
      if(pendingCount === 0 && failedCount === 0){
        toast('Đã lưu lên thiết bị và đồng bộ lên máy chủ.');
      }else{
        toast('Đã lưu cục bộ. Sẽ tự đồng bộ khi có mạng.', 'warn');
      }
    });
    saveLocalBtn2.addEventListener('click', async ()=>{
      saveDraft(true);
      enqueueAllAnswersForSync();
      await syncOfflineQueue();
      const { pendingCount, failedCount } = getQueueStats();
      if(pendingCount === 0 && failedCount === 0){
        toast('Đã lưu lên thiết bị và đồng bộ lên máy chủ.');
      }else{
        toast('Đã lưu cục bộ. Sẽ tự đồng bộ khi có mạng.', 'warn');
      }
    });
    clearLocalBtn.addEventListener('click', ()=>{ if(confirm("Clear local draft on this device?")) clearDraft(); });

    submitBtn.addEventListener('click', ()=> trySubmit(false));
    submitBtn2.addEventListener('click', ()=> trySubmit(false));

    let submitting = false;

    function highlightUnanswered(){
      let firstUn = null;
      document.querySelectorAll('.question').forEach(qb=>{
        const qid = qb.getAttribute('data-qid');
        const ok = isAnsweredById(qid);
        qb.classList.toggle('unanswered', !ok);
        if(!ok && !firstUn) firstUn = qb;
      });
      if(firstUn) firstUn.scrollIntoView({behavior:'smooth', block:'center'});
      return !firstUn;
    }

    function trySubmit(auto=false){
      if(!auto){
        const allAnswered = highlightUnanswered();
        if(!allAnswered){
          toast("Some questions are unanswered. They will be graded as 0 if you continue.", "warn");
          if(!confirm("Submit now with unanswered questions?")) return;
        }
        if(secs > 0){
          if(!confirm("Submit and finish the test? You cannot change answers after submitting.")) return;
        }
      }
      submitNow(auto);
    }

    async function submitNow(auto=false){
      if(submitting) return;
      submitting = true;
      submitBtn.disabled = true; submitBtn2.disabled = true;

      if(auto){
        submitted = true;
        stopTimer();
        try{
          localStorage.removeItem(KEY);
          localStorage.removeItem(KEY_FLAGS);
          localStorage.removeItem(KEY_SYNC_QUEUE);
        }catch(e){}
        setTimeout(()=>{
          window.location = `/mytests/result/${sid}`;
        }, 350);
        return;
      }

      saveDraft(true);
      enqueueAllAnswersForSync();
      const queueSynced = await ensureQueueSyncedBeforeSubmit();
      if(!queueSynced){
        submitBtn.disabled = false; submitBtn2.disabled = false; submitting = false;
        return;
      }

      stopTimer(); await callPause();

      const payload = { answers: collect() };
      try{
        const r = await authFetch(`/api/tests/sessions/${sid}/submit`,{
          method:'POST',
          headers:{'Content-Type':'application/json'},
          body: JSON.stringify(payload)
        });
        if(!r.ok){
          toast("Submit failed. Please try again.", "warn");
          submitBtn.disabled = false; submitBtn2.disabled = false; submitting = false;
          return;
        }
        submitted = true;
        try{
          localStorage.removeItem(KEY);
          localStorage.removeItem(KEY_FLAGS);
          localStorage.removeItem(KEY_SYNC_QUEUE);
        }catch(e){}
        window.location = `/mytests/result/${sid}`;
      }catch(err){
        console.error(err);
        toast("Network error. Please try again.", "warn");
        submitBtn.disabled = false; submitBtn2.disabled = false; submitting = false;
      }
    }

    function toast(msg, type="info"){
      const el = document.createElement('div');
      el.textContent = msg;
      el.style.position='fixed'; el.style.right='16px'; el.style.bottom='16px';
      el.style.background = type==='warn' ? '#fef3c7' : '#e0f2fe';
      el.style.color = '#111827'; el.style.border = '1px solid ' + (type==='warn' ? '#fcd34d' : '#93c5fd');
      el.style.padding='10px 14px'; el.style.borderRadius='8px'; el.style.boxShadow='0 6px 20px rgba(0,0,0,.15)';
      el.style.zIndex='9999'; el.style.maxWidth='60ch';
      document.body.appendChild(el);
      setTimeout(()=>{ el.remove(); }, 3500);
    }

    function initializeStructuredBoards(){
      document.querySelectorAll('.question[data-qtype="Matching"], .question[data-qtype="DragDrop"]').forEach(questionEl => {
        const qid = questionEl.getAttribute('data-qid');
        const hidden = getStructuredInput(questionEl, qid);
        applyStructuredAnswerToQuestion(questionEl, hidden?.value || '');
      });
    }

    /* Initial */
    initializeStructuredBoards();
    try{ const raw = localStorage.getItem(KEY); if(raw){ applyDraft(JSON.parse(raw)); } }catch(e){}
    syncAllStructuredAnswers();
    updateSyncIndicator();
    syncOfflineQueue();
    (function syncFlagButtons(){
      const flags = loadFlags();
      document.querySelectorAll('.flag-btn').forEach(btn=>{
        const qid = btn.getAttribute('data-flag-qid');
        btn.classList.toggle('active', !!flags[qid]);
      });
    })();

    // Đánh dấu trạng thái ban đầu rõ ràng
    refreshNavigatorFull();
    setActiveChip(0);

    window.addEventListener('online', ()=>{
      toast('Đã có kết nối mạng. Đang đồng bộ câu trả lời...', 'info');
      updateSyncIndicator();
      syncOfflineQueue();
    });
    window.addEventListener('offline', ()=>{
      updateSyncIndicator();
    });

    // Auto save
    setInterval(()=>{
      try{
        saveDraft(true);
        syncOfflineQueue();
      }catch(e){}
    }, 20000);

        // Anti-cheat event logging and key blocking
        let antiCheatNoticeAt = 0;
        function warnAntiCheat(msg){
            const now = Date.now();
            if(now - antiCheatNoticeAt > 2500){
                antiCheatNoticeAt = now;
                toast(msg, 'warn');
            }
        }

        document.addEventListener('copy', (e)=>{
            e.preventDefault();
            logSessionEvent('CopyBlocked', 'Copy action blocked');
            warnAntiCheat('Copy is disabled during exam session.');
        });

        document.addEventListener('cut', (e)=>{
            e.preventDefault();
            logSessionEvent('CutBlocked', 'Cut action blocked');
            warnAntiCheat('Cut is disabled during exam session.');
        });

        document.addEventListener('paste', (e)=>{
            const t = e.target;
            const isEssay = t && t.tagName === 'TEXTAREA';
            if(isEssay) return;
            e.preventDefault();
            logSessionEvent('PasteBlocked', 'Paste action blocked outside essay area');
            warnAntiCheat('Paste is disabled for objective questions.');
        });

        document.addEventListener('contextmenu', (e)=>{
            e.preventDefault();
            logSessionEvent('ContextMenuBlocked', 'Context menu blocked');
        });

        document.addEventListener('keydown', (e)=>{
            const key = (e.key || '').toLowerCase();
            const ctrl = e.ctrlKey || e.metaKey;
            const blocked =
                e.key === 'F12' ||
                (ctrl && ['c', 'x', 'v', 'u', 's', 'p'].includes(key)) ||
                (ctrl && e.shiftKey && ['i', 'j', 'c'].includes(key));

            if(!blocked) return;

            e.preventDefault();
            logSessionEvent('ShortcutBlocked', `Blocked shortcut: ${e.key} (ctrl=${ctrl}, shift=${e.shiftKey})`);
            warnAntiCheat('Shortcut is blocked during exam session.');
        });
</script>
