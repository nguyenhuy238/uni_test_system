@model UniTestSystem.Domain.Session
@using UniTestSystem.Domain
@{
    ViewData["Title"] = "Kết quả bài test";
    var passClass = Model.IsPassed ? "badge bg-success" : "badge bg-danger";
    bool hasPendingRegrade = (bool)(ViewBag.HasPendingRegrade ?? false);
}

@functions {
    private static Dictionary<string, string> ParseKeyValueAnswer(string? raw)
    {
        var result = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        if (string.IsNullOrWhiteSpace(raw)) return result;

        var normalized = raw.Replace("||", Environment.NewLine, StringComparison.Ordinal);
        var lines = normalized.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        foreach (var line in lines)
        {
            var idx = line.IndexOf('=');
            if (idx <= 0) continue;
            var key = line[..idx].Trim();
            var val = line[(idx + 1)..].Trim();
            if (string.IsNullOrWhiteSpace(key) || string.IsNullOrWhiteSpace(val)) continue;
            result[key] = val;
        }

        return result;
    }

    private static string TypeLabel(QType type) => type switch
    {
        QType.MCQ => "Trac nghiem (MCQ)",
        QType.TrueFalse => "Dung/Sai",
        QType.Essay => "Tu luan",
        QType.Matching => "Noi cap (Matching)",
        QType.DragDrop => "Keo tha (DragDrop)",
        _ => type.ToString()
    };
}

<h2 class="mb-3">Kết quả bài test</h2>

<div class="card mb-4">
    <div class="card-body">
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <div><strong>Session ID:</strong> @Model.Id</div>
            <div><strong>Bắt đầu:</strong> @Model.StartAt.ToLocalTime()</div>
            <div><strong>Kết thúc:</strong> @(Model.EndAt?.ToLocalTime().ToString() ?? "-")</div>
            <div><strong>Trạng thái:</strong> @Model.Status</div>
        </div>
        <hr />
        <div class="d-flex align-items-center gap-4 flex-wrap">
            <div><strong>Điểm:</strong> @Model.TotalScore / @Model.MaxScore</div>
            <div><strong>Tỷ lệ đúng:</strong> @Model.Percent %</div>
            <div><span class="@passClass">@((Model.IsPassed) ? "DAT" : "KHONG DAT")</span></div>
        </div>
    </div>
</div>

<table class="table table-bordered table-hover">
    <thead class="table-light">
        <tr>
            <th style="width:60px;">#</th>
            <th>Nội dung</th>
            <th style="width:160px;">Loại</th>
            <th style="width:260px;">Bạn chọn / Trả lời</th>
            <th style="width:260px;">Đáp án đúng</th>
            <th style="width:120px;">Điểm</th>
        </tr>
    </thead>
    <tbody>
        @{
            var snapshot = Model.StudentAnswers?.OrderBy(a => a.QuestionId).Select(a => a.Question).Where(q => q != null).Cast<Question>().ToList() ?? new List<Question>();
            var mapAns = Model.StudentAnswers?.ToDictionary(a => a.QuestionId, a => a) ?? new Dictionary<string, StudentAnswer>();

            for (int i = 0; i < snapshot.Count; i++)
            {
                var q = snapshot[i];
                mapAns.TryGetValue(q.Id, out var a);
                var typeLabel = TypeLabel(q.Type);
                var orderedOptions = q.Options.Where(o => !o.IsDeleted).OrderBy(o => o.Id, StringComparer.Ordinal).ToList();

                string yourAnswer;
                if (q.Type == QType.MCQ || q.Type == QType.TrueFalse)
                {
                    var selectedRaw = a?.SelectedOptionId?.Trim();
                    if (string.IsNullOrWhiteSpace(selectedRaw))
                    {
                        yourAnswer = "(chua chon)";
                    }
                    else
                    {
                        var selectedOption = orderedOptions.FirstOrDefault(o =>
                            string.Equals(o.Id, selectedRaw, StringComparison.OrdinalIgnoreCase));

                        if (selectedOption == null &&
                            selectedRaw.Length == 1 &&
                            char.IsLetter(selectedRaw[0]))
                        {
                            var idx = char.ToUpperInvariant(selectedRaw[0]) - 'A';
                            if (idx >= 0 && idx < orderedOptions.Count)
                            {
                                selectedOption = orderedOptions[idx];
                            }
                        }

                        if (selectedOption == null)
                        {
                            selectedOption = orderedOptions.FirstOrDefault(o =>
                                string.Equals(o.Content?.Trim(), selectedRaw, StringComparison.OrdinalIgnoreCase));
                        }

                        if (selectedOption == null)
                        {
                            yourAnswer = selectedRaw;
                        }
                        else if (q.Type == QType.MCQ)
                        {
                            var selectedIndex = orderedOptions.FindIndex(o => o.Id == selectedOption.Id);
                            var selectedLabel = selectedIndex >= 0 ? ((char)('A' + selectedIndex)).ToString() : "";
                            yourAnswer = $"{selectedLabel}) {selectedOption.Content}";
                        }
                        else
                        {
                            yourAnswer = selectedOption.Content;
                        }
                    }
                }
                else if (q.Type == QType.Essay)
                {
                    yourAnswer = string.IsNullOrWhiteSpace(a?.EssayAnswer) ? "(chua tra loi)" : a!.EssayAnswer!;
                }
                else
                {
                    var pairs = ParseKeyValueAnswer(a?.EssayAnswer ?? a?.SelectedOptionId);
                    yourAnswer = pairs.Count == 0
                        ? "(chua tra loi)"
                        : string.Join(Environment.NewLine, pairs.Select(p => $"{p.Key} -> {p.Value}"));
                }

                string correct;
                if (q.Type == QType.MCQ || q.Type == QType.TrueFalse)
                {
                    var correctParts = new List<string>();
                    for (int optionIndex = 0; optionIndex < orderedOptions.Count; optionIndex++)
                    {
                        var option = orderedOptions[optionIndex];
                        if (!option.IsCorrect) continue;

                        if (q.Type == QType.MCQ)
                        {
                            var label = ((char)('A' + optionIndex)).ToString();
                            correctParts.Add($"{label}) {option.Content}");
                        }
                        else
                        {
                            correctParts.Add(option.Content);
                        }
                    }

                    correct = correctParts.Any() ? string.Join(Environment.NewLine, correctParts) : "(khong xac dinh)";
                }
                else if (q.Type == QType.Essay)
                {
                    correct = "(cham tay)";
                }
                else if (q.Type == QType.Matching)
                {
                    var pairs = (q.MatchingPairs ?? new List<MatchPair>())
                        .Where(p => !string.IsNullOrWhiteSpace(p.L) && !string.IsNullOrWhiteSpace(p.R))
                        .Select(p => $"{p.L} -> {p.R}")
                        .ToList();
                    correct = pairs.Count == 0 ? "(khong xac dinh)" : string.Join(Environment.NewLine, pairs);
                }
                else
                {
                    var slots = (q.DragDrop?.Slots ?? new List<DragSlot>())
                        .Where(s => !string.IsNullOrWhiteSpace(s.Name))
                        .Select(s => $"{s.Name} -> {s.Answer}")
                        .ToList();
                    correct = slots.Count == 0 ? "(khong xac dinh)" : string.Join(Environment.NewLine, slots);
                }

                var rowClass = (q.Type != QType.Essay)
                    ? ((a?.Score ?? 0m) > 0m ? "table-success" : "table-danger")
                    : "";

                <tr class="@rowClass">
                    <td>@(i + 1)</td>
                    <td>@q.Content</td>
                    <td>@typeLabel</td>
                    <td style="white-space: pre-wrap;">@yourAnswer</td>
                    <td style="white-space: pre-wrap;">@correct</td>
                    <td>@(a?.Score ?? 0m)</td>
                </tr>
            }
        }
    </tbody>
</table>

<div class="mt-3">
    <a class="btn btn-secondary" href="/mytests">Quay về danh sách bài test</a>
    <a class="btn btn-outline-primary" href="/Feedback/Create?sessionId=@Model.Id">
        Gửi feedback cho bài test này
    </a>
</div>

@if (TempData["Msg"] != null)
{
    <div class="alert alert-success mt-3">@TempData["Msg"]</div>
}
@if (TempData["Err"] != null)
{
    <div class="alert alert-danger mt-3">@TempData["Err"]</div>
}

@if (Model.Status == SessionStatus.Graded)
{
    <div class="card mt-3 border-0 shadow-sm">
        <div class="card-body">
            <h5 class="mb-3">Phúc khảo (Regrade)</h5>
            @if (hasPendingRegrade)
            {
                <div class="alert alert-warning mb-0">
                    Yêu cầu phúc khảo của bạn đang chờ xử lý.
                </div>
            }
            else
            {
                <form method="post" action="/mytests/regrade/request">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="sessionId" value="@Model.Id" />
                    <div class="mb-2">
                        <label class="form-label">Lý do yêu cầu phúc khảo</label>
                        <textarea class="form-control" name="reason" rows="3" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-outline-warning">Gửi yêu cầu phúc khảo</button>
                </form>
            }
        </div>
    </div>
}
