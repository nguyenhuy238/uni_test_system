@model UniTestSystem.Domain.Session
@using UniTestSystem.Domain
@{
    ViewData["Title"] = "Kết quả bài test";
    var passClass = Model.IsPassed ? "badge bg-success" : "badge bg-danger";
    bool hasPendingRegrade = (bool)(ViewBag.HasPendingRegrade ?? false);
}

<h2 class="mb-3">Kết quả bài test</h2>

<div class="card mb-4">
    <div class="card-body">
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <div><strong>Session ID:</strong> @Model.Id</div>
            <div><strong>Bắt đầu:</strong> @Model.StartAt.ToLocalTime()</div>
            <div><strong>Kết thúc:</strong> @(Model.EndAt?.ToLocalTime().ToString() ?? "-")</div>
            <div><strong>Trạng thái:</strong> @Model.Status</div>
        </div>
        <hr />
        <div class="d-flex align-items-center gap-4 flex-wrap">
            <div><strong>Điểm:</strong> @Model.TotalScore / @Model.MaxScore</div>
            <div><strong>Tỷ lệ đúng:</strong> @Model.Percent %</div>
            <div><span class="@passClass">@((Model.IsPassed) ? "ĐẠT" : "KHÔNG ĐẠT")</span></div>
        </div>
    </div>
</div>

<table class="table table-bordered table-hover">
    <thead class="table-light">
        <tr>
            <th style="width:60px;">#</th>
            <th>Nội dung</th>
            <th style="width:160px;">Loại</th>
            <th style="width:220px;">Bạn chọn / Trả lời</th>
            <th style="width:220px;">Đáp án đúng</th>
            <th style="width:100px;">Điểm</th>
        </tr>
    </thead>
    <tbody>
        @{
            var snapshot = Model.StudentAnswers?.OrderBy(a => a.QuestionId).Select(a => a.Question).Where(q => q != null).Cast<Question>().ToList() ?? new List<UniTestSystem.Domain.Question>();
            var mapAns = Model.StudentAnswers?.ToDictionary(a => a.QuestionId, a => a) ?? new Dictionary<string, UniTestSystem.Domain.StudentAnswer>();
            for (int i = 0; i < snapshot.Count; i++)
            {
                var q = snapshot[i];
                mapAns.TryGetValue(q.Id, out var a);
                string typeLabel = q.Type switch
                {
                    QType.MCQ => "Trắc nghiệm (MCQ)",
                    QType.TrueFalse => "Đúng/Sai",
                    QType.Essay => "Tự luận",
                    _ => q.Type.ToString()
                };

                string yourAnswer = q.Type switch
                {
                    QType.MCQ or QType.TrueFalse => a?.SelectedOptionId ?? "(chưa chọn)",
                    QType.Essay => string.IsNullOrWhiteSpace(a?.EssayAnswer) ? "(chưa trả lời)" : a!.EssayAnswer!,
                    _ => a?.SelectedOptionId ?? ""
                };

                string correct = (q.Type == QType.MCQ || q.Type == QType.TrueFalse)
                ? string.Join(", ", q.Options.Where(o => o.IsCorrect).Select(o => o.Content))
                : "(chấm tay)";

                var rowClass = (q.Type == QType.MCQ || q.Type == QType.TrueFalse)
                ? ((a?.Score ?? 0) > 0 ? "table-success" : "table-danger")
                : "";
                <tr class="@rowClass">
                    <td>@(i + 1)</td>
                    <td>@q.Content</td>
                    <td>@typeLabel</td>
                    <td>@yourAnswer</td>
                    <td>@correct</td>
                    <td>@(a?.Score ?? 0)</td>
                </tr>
            }
        }
    </tbody>
</table>

<div class="mt-3">
    <a class="btn btn-secondary" href="/mytests">Quay về danh sách bài test</a>
    <a class="btn btn-outline-primary" href="/Feedback/Create?sessionId=@Model.Id">
        Gửi feedback cho bài test này
    </a>
</div>

@if (TempData["Msg"] != null)
{
    <div class="alert alert-success mt-3">@TempData["Msg"]</div>
}
@if (TempData["Err"] != null)
{
    <div class="alert alert-danger mt-3">@TempData["Err"]</div>
}

@if (Model.Status == SessionStatus.Graded)
{
    <div class="card mt-3 border-0 shadow-sm">
        <div class="card-body">
            <h5 class="mb-3">Phúc khảo (Regrade)</h5>
            @if (hasPendingRegrade)
            {
                <div class="alert alert-warning mb-0">
                    Yêu cầu phúc khảo của bạn đang chờ xử lý.
                </div>
            }
            else
            {
                <form method="post" action="/mytests/regrade/request">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="sessionId" value="@Model.Id" />
                    <div class="mb-2">
                        <label class="form-label">Lý do yêu cầu phúc khảo</label>
                        <textarea class="form-control" name="reason" rows="3" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-outline-warning">Gửi yêu cầu phúc khảo</button>
                </form>
            }
        </div>
    </div>
}
