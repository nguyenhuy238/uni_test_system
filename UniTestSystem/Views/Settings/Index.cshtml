@model UniTestSystem.Domain.SystemSettings
@{
    ViewData["Title"] = "System Settings";
}
<h2>System Settings</h2>

<partial name="~/Views/Shared/_Flash.cshtml" />

<form method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div class="mb-3">
        <label class="form-label">System Name</label>
        <input class="form-control" name="SystemName" value="@Model.SystemName" />
    </div>

    <div class="row g-3 mb-3">
        <div class="col-md-6">
            <label class="form-label">Current Semester</label>
            <input class="form-control" name="CurrentSemester" value="@Model.CurrentSemester" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Current Academic Year</label>
            <input class="form-control" name="CurrentAcademicYear" value="@Model.CurrentAcademicYear" />
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-md-4">
            <label class="form-label">Warning GPA Threshold</label>
            <input type="number" min="0" max="4" step="0.1" class="form-control" name="WarningGpaThreshold" value="@Model.WarningGpaThreshold" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Fail GPA Threshold</label>
            <input type="number" min="0" max="4" step="0.1" class="form-control" name="FailGpaThreshold" value="@Model.FailGpaThreshold" />
        </div>
        <div class="col-md-4 d-flex align-items-end">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" name="TreatOutstandingDebtAsFail" value="true" @(Model.TreatOutstandingDebtAsFail ? "checked" : null) />
                <input type="hidden" name="TreatOutstandingDebtAsFail" value="false" />
                <label class="form-check-label">Treat Outstanding Debt As Fail</label>
            </div>
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">Logo (PNG/JPG)</label>
        <input type="file" name="logo" class="form-control" accept="image/*" />
        @if (!string.IsNullOrWhiteSpace(Model.LogoUrl))
        {
            <div class="mt-2">
                <img src="@Model.LogoUrl" alt="logo" style="max-height:60px" />
            </div>
        }
    </div>

    <button class="btn btn-primary">Save</button>
</form>
