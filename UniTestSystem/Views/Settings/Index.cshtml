@model UniTestSystem.Domain.SystemSettings
@{
    ViewData["Title"] = "System Settings";
}
<h2>System Settings</h2>

<partial name="~/Views/Shared/_Flash.cshtml" />

<form method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div class="mb-3">
        <label class="form-label">System Name</label>
        <input class="form-control" name="SystemName" value="@Model.SystemName" />
    </div>

    <div class="mb-3">
        <label class="form-label">Logo (PNG/JPG)</label>
        <input type="file" name="logo" class="form-control" accept="image/*" />
        @if (!string.IsNullOrWhiteSpace(Model.LogoUrl))
        {
            <div class="mt-2">
                <img src="@Model.LogoUrl" alt="logo" style="max-height:60px" />
            </div>
        }
    </div>

    <button class="btn btn-primary">Save</button>
</form>
