@using UniTestSystem.Domain
@{
    ViewData["Title"] = "Examination in Progress";
    Layout = "_ExamLayout";
    var testId = ViewBag.TestId as string;
}

<div class="exam-room-shell">
    <div class="exam-room-main">
        <section class="exam-question-panel ui-surface">
            <header class="exam-question-header">
                <h5 class="mb-0 fw-bold" id="testTitle">Loading test...</h5>
                <div class="exam-header-badges">
                    <div id="syncStatusBadge" class="exam-sync-pill sync-ok">
                        <span class="sync-dot"></span>
                        <span id="syncStatusText">Đã lưu</span>
                    </div>
                    <div class="exam-progress-pill">
                        Question <span id="currentQNum">0</span> / <span id="totalQNum">0</span>
                    </div>
                </div>
            </header>
            <div id="offlineBanner" class="exam-offline-banner d-none">
                Bạn đang offline. Câu trả lời được lưu tạm và sẽ tự động đồng bộ khi có mạng.
            </div>

            <div class="exam-question-body" id="questionContainer">
                <div class="text-center py-5" id="loader">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-3 text-muted">Preparing your examination questions...</p>
                </div>
            </div>

            <footer class="exam-question-footer">
                <button id="prevBtn" class="btn btn-outline-secondary" onclick="prevQuestion()" disabled>
                    <i class="bi bi-arrow-left me-1"></i> Previous
                </button>
                <div class="d-flex gap-2">
                    <button id="nextBtn" class="btn ui-btn-primary text-white" onclick="nextQuestion()" disabled>
                        Next <i class="bi bi-arrow-right ms-1"></i>
                    </button>
                    <button id="submitBtn" class="btn btn-success d-none" onclick="confirmSubmit()">
                        <i class="bi bi-check2-circle me-1"></i> Submit Test
                    </button>
                </div>
            </footer>
        </section>
    </div>

    <aside class="exam-room-sidebar">
        <section class="ui-surface exam-right-panel sticky-top">
            <div class="exam-timer-wrap" id="timerWrap">
                <span class="text-uppercase small fw-semibold">Time Remaining</span>
                <div class="exam-timer" id="timer">--:--</div>
            </div>

            <div class="exam-nav-header">
                <span class="fw-semibold">Question Navigator</span>
            </div>
            <div id="qPalette" class="exam-q-grid"></div>

            <div class="exam-security-note mt-3">
                <strong>Secure Mode Active</strong>
                <div class="small mt-1">Tab switching, copy/paste, and shortcuts are monitored.</div>
            </div>

            <button class="btn btn-danger w-100 mt-3" onclick="confirmSubmit()">
                <i class="bi bi-send-check me-1"></i> Submit Test
            </button>
        </section>
    </aside>
</div>

<!-- Anti-cheat Alert Modal -->
<div class="modal fade" id="cheatModal" data-bs-backdrop="static" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-body text-center p-5">
                <i class="bi bi-exclamation-triangle-fill text-danger fs-1 mb-3"></i>
                <h4 class="fw-bold mb-3">Security Violation Detected</h4>
                <p class="text-muted mb-4">You have switched away from the examination tab. This event has been logged and reported to the system administrator.</p>
                <button type="button" class="btn btn-primary px-5" data-bs-dismiss="modal">I Understand</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const TEST_ID = '@testId';
        const AUTO_SAVE_INTERVAL_MS = 30000;
        const SAVE_TIMEOUT_MS = 8000;
        const MAX_RETRY_COUNT = 5;
        const DEVICE_FP_KEY = 'unitest_device_fp';

        let sessionId = '';
        let questions = [];
        let currentIndex = 0;
        let userAnswers = {};
        let dirtyAnswerTimestamps = {};
        let timerSeconds = 0;
        let timerInterval;
        let autoSaveInterval;
        let isSubmitting = false;
        let isDrainingQueue = false;
        let queueSyncRequested = false;
        let submittedConflictNotified = false;

        $(document).ready(function() {
            initAntiCheat();
            bindConnectivityEvents();
            startTest();
        });

        function getDeviceFingerprint() {
            let fp = localStorage.getItem(DEVICE_FP_KEY);
            if (!fp) {
                fp = (crypto?.randomUUID?.() ?? `${Date.now()}_${Math.random()}`).toString();
                localStorage.setItem(DEVICE_FP_KEY, fp);
            }
            return fp;
        }

        function authFetch(url, options = {}) {
            const headers = Object.assign({}, options.headers || {}, {
                'X-Device-Fingerprint': getDeviceFingerprint()
            });
            return fetch(url, { ...options, headers });
        }

        function getDraftStorageKey() {
            return sessionId ? `examDraft_${sessionId}` : '';
        }

        function getQueueStorageKey() {
            return sessionId ? `offlineQueue_${sessionId}` : '';
        }

        function parseSafeJson(raw, fallback) {
            try {
                const parsed = JSON.parse(raw);
                return parsed ?? fallback;
            } catch (_) {
                return fallback;
            }
        }

        const DraftStore = {
            save() {
                const key = getDraftStorageKey();
                if (!key) return;

                const payload = {
                    sessionId,
                    answers: { ...userAnswers },
                    questionTimestamps: { ...dirtyAnswerTimestamps },
                    lastUpdated: new Date().toISOString()
                };
                localStorage.setItem(key, JSON.stringify(payload));
            },
            load() {
                const key = getDraftStorageKey();
                if (!key) return null;
                return parseSafeJson(localStorage.getItem(key), null);
            },
            clear() {
                const key = getDraftStorageKey();
                if (!key) return;
                localStorage.removeItem(key);
            }
        };

        const OfflineQueue = {
            load() {
                const key = getQueueStorageKey();
                if (!key) return [];
                const queue = parseSafeJson(localStorage.getItem(key), []);
                if (!Array.isArray(queue)) return [];
                return queue.filter(x => x && x.sessionId === sessionId && x.questionId);
            },
            save(queue) {
                const key = getQueueStorageKey();
                if (!key) return;
                localStorage.setItem(key, JSON.stringify(queue || []));
            },
            clear() {
                const key = getQueueStorageKey();
                if (!key) return;
                localStorage.removeItem(key);
            }
        };

        function getQueueStats() {
            const queue = OfflineQueue.load();
            const pendingCount = queue.filter(x => !x.failed).length;
            const failedCount = queue.filter(x => !!x.failed).length;
            return { queue, pendingCount, failedCount };
        }

        function setSyncStatus(cssClass, text) {
            const badge = $('#syncStatusBadge');
            badge.removeClass('sync-ok sync-pending sync-error').addClass(cssClass);
            $('#syncStatusText').text(text);
        }

        function updateSyncStatusIndicator() {
            const { pendingCount, failedCount } = getQueueStats();
            const offline = !navigator.onLine;

            if (failedCount > 0) {
                setSyncStatus('sync-error', `Đồng bộ lỗi - ${failedCount} câu cần kiểm tra`);
            } else if (offline && pendingCount > 0) {
                setSyncStatus('sync-error', `Mất kết nối - ${pendingCount} câu chưa lưu`);
            } else if (pendingCount > 0) {
                setSyncStatus('sync-pending', `Đang lưu offline... (${pendingCount} câu chưa đồng bộ)`);
            } else if (offline) {
                setSyncStatus('sync-pending', 'Đang offline');
            } else {
                setSyncStatus('sync-ok', 'Đã lưu');
            }

            $('#offlineBanner').toggleClass('d-none', !offline);
        }

        function showToast(message, type = 'info') {
            const toast = document.createElement('div');
            toast.textContent = message;
            toast.style.position = 'fixed';
            toast.style.right = '16px';
            toast.style.bottom = '16px';
            toast.style.zIndex = '9999';
            toast.style.padding = '10px 14px';
            toast.style.borderRadius = '8px';
            toast.style.boxShadow = '0 6px 20px rgba(0,0,0,.15)';
            toast.style.maxWidth = '56ch';
            toast.style.border = type === 'warn' ? '1px solid #fca5a5' : '1px solid #93c5fd';
            toast.style.background = type === 'warn' ? '#fef2f2' : '#eff6ff';
            toast.style.color = type === 'warn' ? '#991b1b' : '#1e3a8a';
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3800);
        }

        function escapeHtml(value) {
            return String(value ?? '')
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;')
                .replaceAll('"', '&quot;')
                .replaceAll("'", '&#39;');
        }

        function bindConnectivityEvents() {
            window.addEventListener('online', async () => {
                updateSyncStatusIndicator();
                showToast('Đã có kết nối. Hệ thống đang đồng bộ câu trả lời.');
                await flushDirtyAnswers();
                await drainOfflineQueue();
            });

            window.addEventListener('offline', () => {
                updateSyncStatusIndicator();
                showToast('Mất kết nối. Câu trả lời sẽ được lưu tạm trên trình duyệt.', 'warn');
            });

            window.addEventListener('beforeunload', () => {
                if (!sessionId) return;
                DraftStore.save();
            });
        }

        function restoreDraftAndQueue() {
            const draft = DraftStore.load();
            let restored = false;

            if (draft && draft.answers && typeof draft.answers === 'object') {
                userAnswers = { ...userAnswers, ...draft.answers };
                restored = Object.keys(draft.answers).length > 0;
            }

            if (draft && draft.questionTimestamps && typeof draft.questionTimestamps === 'object') {
                dirtyAnswerTimestamps = { ...dirtyAnswerTimestamps, ...draft.questionTimestamps };
            }

            const queue = OfflineQueue.load();
            queue
                .sort((a, b) => String(a.timestamp || '').localeCompare(String(b.timestamp || '')))
                .forEach(entry => {
                    userAnswers[entry.questionId] = entry.answerId ?? '';
                    dirtyAnswerTimestamps[entry.questionId] = entry.timestamp ?? new Date().toISOString();
                });

            if (restored) {
                showToast('Đã khôi phục câu trả lời từ lần làm trước.');
            }
        }

        function startTest() {
            $.ajax({
                url: `/api/tests/${TEST_ID}/start`,
                method: 'POST',
                success: async function(res) {
                    sessionId = res.sessionId;
                    questions = res.questions || [];
                    timerSeconds = Math.max(0, (res.remainingMinutes || 0) * 60);

                    restoreDraftAndQueue();

                    $('#testTitle').text('Online Examination');
                    $('#totalQNum').text(questions.length);
                    $('#loader').remove();

                    renderPalette();
                    if (questions.length > 0) {
                        showQuestion(0);
                    } else {
                        $('#questionContainer').html('<div class="alert alert-warning">No questions found for this session.</div>');
                    }
                    startTimer();
                    startAutoSave();
                    updateSyncStatusIndicator();

                    if (navigator.onLine) {
                        await flushDirtyAnswers();
                        await drainOfflineQueue();
                    }
                },
                error: function(err) {
                    $('#questionContainer').html(`
                        <div class="alert alert-danger">
                            <i class="bi bi-x-circle me-2"></i>
                            Failed to start test: ${err.responseText || 'Unauthorized or session error'}
                        </div>
                    `);
                }
            });
        }

        function showQuestion(index) {
            if (!questions.length) return;
            currentIndex = index;
            const q = questions[index];

            $('#currentQNum').text(index + 1);
            $('#prevBtn').prop('disabled', index === 0);

            if (index === questions.length - 1) {
                $('#nextBtn').addClass('d-none');
                $('#submitBtn').removeClass('d-none');
            } else {
                $('#nextBtn').removeClass('d-none');
                $('#submitBtn').addClass('d-none');
                $('#nextBtn').prop('disabled', false);
            }

            let html = `<div class="mb-4"><h4 class="fw-bold exam-question">${q.content}</h4></div>`;

            if (q.type === 'MCQ' || q.type === 'TrueFalse') {
                const options = Array.isArray(q.options) ? q.options : [];
                html += '<div class="exam-option-list">';
                options.forEach(opt => {
                    const isChecked = userAnswers[q.id] === opt.content ? 'checked' : '';
                    html += `
                        <label class="exam-option-item cursor-pointer">
                            <input class="form-check-input me-3 mt-0" type="radio" name="q_${q.id}" value="${opt.content}" ${isChecked} onchange="saveAnswer('${q.id}', this.value)">
                            <span>${opt.content}</span>
                        </label>`;
                });
                html += '</div>';
            } else if (q.type === 'Essay') {
                const val = escapeHtml(userAnswers[q.id] || '');
                html += `<textarea class="form-control shadow-sm exam-essay" rows="10" placeholder="Type your answer here..." oninput="saveAnswer('${q.id}', this.value)">${val}</textarea>`;
            }

            $('#questionContainer').html(html);
            updatePaletteActive();
        }

        function saveAnswer(qid, val) {
            userAnswers[qid] = val;
            dirtyAnswerTimestamps[qid] = new Date().toISOString();
            DraftStore.save();

            if (!navigator.onLine) {
                enqueueAnswerForSync(qid, val, dirtyAnswerTimestamps[qid]);
            }

            updatePaletteActive();
            updateSyncStatusIndicator();
        }

        function nextQuestion() {
            if (currentIndex < questions.length - 1) showQuestion(currentIndex + 1);
        }

        function prevQuestion() {
            if (currentIndex > 0) showQuestion(currentIndex - 1);
        }

        function renderPalette() {
            let html = '';
            questions.forEach((q, i) => {
                html += `<button id="pal_${i}" class="exam-q-btn" onclick="showQuestion(${i})">${i + 1}</button>`;
            });
            $('#qPalette').html(html);
        }

        function updatePaletteActive() {
            questions.forEach((q, i) => {
                const btn = $(`#pal_${i}`);
                btn.removeClass('is-current is-answered');

                if (i === currentIndex) {
                    btn.addClass('is-current');
                } else if (userAnswers[q.id]) {
                    btn.addClass('is-answered');
                }
            });
        }

        function startTimer() {
            if (timerInterval) return;
            renderTimer();
            timerInterval = setInterval(() => {
                timerSeconds--;
                if (timerSeconds <= 0) {
                    timerSeconds = 0;
                    clearInterval(timerInterval);
                    timerInterval = null;
                    autoSubmit();
                }
                renderTimer();

                if (timerSeconds < 300) { // Red timer if < 5 mins
                    $('#timerWrap').addClass('time-critical');
                }
            }, 1000);
        }

        function renderTimer() {
            const m = Math.floor(timerSeconds / 60);
            const s = timerSeconds % 60;
            $('#timer').text(`${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`);
        }

        function startAutoSave() {
            if (autoSaveInterval) {
                clearInterval(autoSaveInterval);
            }

            autoSaveInterval = setInterval(async () => {
                await flushDirtyAnswers();
                await drainOfflineQueue();
            }, AUTO_SAVE_INTERVAL_MS);
        }

        function stopAutoSave() {
            if (autoSaveInterval) {
                clearInterval(autoSaveInterval);
                autoSaveInterval = null;
            }
        }

        async function saveAnswersToServer(answers, questionTimestamps, clientTimestamp) {
            const controller = new AbortController();
            const timeoutHandle = setTimeout(() => controller.abort(), SAVE_TIMEOUT_MS);
            try {
                return await authFetch(`/api/tests/sessions/${sessionId}/save-answer`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        answers,
                        clientTimestamp,
                        questionClientTimestamps: questionTimestamps
                    }),
                    signal: controller.signal
                });
            } finally {
                clearTimeout(timeoutHandle);
            }
        }

        function removeQueueEntriesByTimestampMap(questionTimestampMap) {
            const queue = OfflineQueue.load().filter(entry => {
                const syncTs = questionTimestampMap[entry.questionId];
                if (!syncTs) return true;
                return String(entry.timestamp || '') > String(syncTs);
            });
            OfflineQueue.save(queue);
        }

        function enqueueAnswerForSync(questionId, answerValue, timestamp, keepRetry = false) {
            if (!questionId) return;
            const queue = OfflineQueue.load();
            const existing = queue.find(x => x.questionId === questionId);

            if (existing && existing.timestamp === timestamp && existing.answerId === (answerValue ?? '')) {
                return;
            }

            const filtered = queue.filter(x => x.questionId !== questionId);
            filtered.push({
                sessionId,
                questionId,
                answerId: answerValue ?? '',
                timestamp: timestamp ?? new Date().toISOString(),
                retryCount: keepRetry && existing ? Number(existing.retryCount || 0) : 0
            });
            OfflineQueue.save(filtered);
            updateSyncStatusIndicator();
        }

        function markQueueEntryRetry(entry, forceFail) {
            const queue = OfflineQueue.load();
            const idx = queue.findIndex(x =>
                x.questionId === entry.questionId &&
                x.timestamp === entry.timestamp);
            if (idx < 0) return;

            const current = queue[idx];
            current.retryCount = Number(current.retryCount || 0) + 1;
            if (forceFail || current.retryCount >= MAX_RETRY_COUNT) {
                current.failed = true;
                showToast(`Không thể đồng bộ câu ${current.questionId} sau ${current.retryCount} lần thử.`, 'warn');
            }

            queue[idx] = current;
            OfflineQueue.save(queue);
            updateSyncStatusIndicator();
        }

        function markAllPendingAsFailed() {
            const queue = OfflineQueue.load().map(entry => {
                if (entry.failed) return entry;
                return {
                    ...entry,
                    failed: true,
                    retryCount: Math.max(Number(entry.retryCount || 0), MAX_RETRY_COUNT)
                };
            });
            OfflineQueue.save(queue);
            updateSyncStatusIndicator();
        }

        function removeQueueEntry(entry) {
            const queue = OfflineQueue.load().filter(x =>
                !(x.questionId === entry.questionId && x.timestamp === entry.timestamp));
            OfflineQueue.save(queue);
            updateSyncStatusIndicator();
        }

        async function flushDirtyAnswers() {
            if (!sessionId || isSubmitting) return;

            const dirtyEntries = Object.entries(dirtyAnswerTimestamps);
            if (!dirtyEntries.length) return;

            if (!navigator.onLine) {
                dirtyEntries.forEach(([qid, ts]) => {
                    enqueueAnswerForSync(qid, userAnswers[qid] ?? '', ts);
                });
                return;
            }

            const answersPayload = {};
            const timestampsPayload = {};
            dirtyEntries.forEach(([qid, ts]) => {
                answersPayload[qid] = userAnswers[qid] ?? '';
                timestampsPayload[qid] = ts;
            });
            const newestTimestamp = dirtyEntries.map(x => x[1]).sort().slice(-1)[0];

            try {
                const response = await saveAnswersToServer(answersPayload, timestampsPayload, newestTimestamp);

                if (response.ok) {
                    dirtyEntries.forEach(([qid, ts]) => {
                        if (dirtyAnswerTimestamps[qid] === ts) {
                            delete dirtyAnswerTimestamps[qid];
                        }
                    });
                    removeQueueEntriesByTimestampMap(timestampsPayload);
                    DraftStore.save();
                    updateSyncStatusIndicator();
                    return;
                }

                if (response.status === 409) {
                    let message = 'Phiên làm bài đã được nộp trên thiết bị khác.';
                    try {
                        const payload = await response.json();
                        message = payload?.message || message;
                    } catch (_) {}
                    showToast(message, 'warn');
                    markAllPendingAsFailed();
                    return;
                }

                const nonRetryable = response.status >= 400 && response.status < 500;
                dirtyEntries.forEach(([qid, ts]) => {
                    enqueueAnswerForSync(qid, userAnswers[qid] ?? '', ts);
                });
                if (nonRetryable) {
                    dirtyEntries.forEach(([qid, ts]) => {
                        markQueueEntryRetry({ questionId: qid, timestamp: ts }, true);
                    });
                }
            } catch (_) {
                dirtyEntries.forEach(([qid, ts]) => {
                    enqueueAnswerForSync(qid, userAnswers[qid] ?? '', ts);
                });
            }

            updateSyncStatusIndicator();
        }

        async function processQueueEntry(entry) {
            try {
                const response = await saveAnswersToServer(
                    { [entry.questionId]: entry.answerId ?? '' },
                    { [entry.questionId]: entry.timestamp },
                    entry.timestamp
                );

                if (response.ok) {
                    removeQueueEntry(entry);
                    if (dirtyAnswerTimestamps[entry.questionId] === entry.timestamp) {
                        delete dirtyAnswerTimestamps[entry.questionId];
                    }
                    DraftStore.save();
                    return 'success';
                }

                if (response.status === 409) {
                    let code = '';
                    let message = 'Phiên làm bài đã được nộp trên thiết bị khác.';
                    try {
                        const payload = await response.json();
                        code = payload?.code || '';
                        message = payload?.message || message;
                    } catch (_) {}

                    markQueueEntryRetry(entry, true);
                    if (code === 'SESSION_ALREADY_SUBMITTED') {
                        markAllPendingAsFailed();
                    }
                    if (!submittedConflictNotified) {
                        submittedConflictNotified = true;
                        showToast(message, 'warn');
                    }
                    return 'stop';
                }

                const nonRetryable = response.status >= 400 && response.status < 500;
                markQueueEntryRetry(entry, nonRetryable);
                return 'stop';
            } catch (_) {
                markQueueEntryRetry(entry, false);
                return 'stop';
            }
        }

        async function drainOfflineQueue() {
            if (!sessionId || !navigator.onLine) {
                updateSyncStatusIndicator();
                return;
            }

            if (isDrainingQueue) {
                queueSyncRequested = true;
                return;
            }

            isDrainingQueue = true;
            try {
                while (navigator.onLine) {
                    const next = OfflineQueue.load().find(x => !x.failed);
                    if (!next) break;

                    const state = await processQueueEntry(next);
                    if (state !== 'success') break;
                }
            } finally {
                isDrainingQueue = false;
                updateSyncStatusIndicator();
                if (queueSyncRequested) {
                    queueSyncRequested = false;
                    setTimeout(drainOfflineQueue, 300);
                }
            }
        }

        async function ensureQueueSyncedBeforeSubmit() {
            if (!navigator.onLine) {
                showToast('Không thể nộp bài khi đang offline. Vui lòng kết nối mạng để đồng bộ.', 'warn');
                return false;
            }

            await flushDirtyAnswers();
            await drainOfflineQueue();

            const { pendingCount, failedCount } = getQueueStats();
            if (pendingCount > 0 || failedCount > 0) {
                showToast('Còn câu trả lời chưa đồng bộ. Vui lòng đợi đồng bộ xong trước khi nộp.', 'warn');
                return false;
            }

            return true;
        }

        function clearSessionLocalData() {
            DraftStore.clear();
            OfflineQueue.clear();
            dirtyAnswerTimestamps = {};
        }

        function confirmSubmit() {
            if (confirm('Are you sure you want to submit your test? You cannot make changes after submission.')) {
                submitTest();
            }
        }

        async function submitTest() {
            if (isSubmitting || !sessionId) return;

            isSubmitting = true;
            $('#submitBtn').prop('disabled', true);

            try {
                const canSubmit = await ensureQueueSyncedBeforeSubmit();
                if (!canSubmit) return;

                const response = await authFetch(`/api/tests/sessions/${sessionId}/submit`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ answers: userAnswers })
                });

                if (!response.ok) {
                    if (response.status === 409) {
                        showToast('Phiên làm bài đã được nộp ở thiết bị khác.', 'warn');
                        return;
                    }

                    showToast('Nộp bài thất bại. Vui lòng thử lại.', 'warn');
                    return;
                }

                const result = await response.json();
                clearInterval(timerInterval);
                stopAutoSave();
                clearSessionLocalData();
                window.location.href = `/Student/ResultDetail/${result.id}`;
            } catch (_) {
                showToast('Nộp bài thất bại do lỗi mạng.', 'warn');
            } finally {
                isSubmitting = false;
                $('#submitBtn').prop('disabled', false);
            }
        }

        function autoSubmit() {
            showToast('Hết giờ làm bài. Hệ thống đang tự động nộp bài.', 'warn');
            submitTest();
        }

        function initAntiCheat() {
            document.addEventListener('contextmenu', e => e.preventDefault());

            document.addEventListener('copy', e => {
                e.preventDefault();
                logCheatEvent('Copy', 'Attempted to copy content');
            });
            document.addEventListener('paste', e => {
                e.preventDefault();
                logCheatEvent('Paste', 'Attempted to paste content');
            });

            // Detect Window Blur (Tab switching)
            let blurCount = 0;
            $(window).on('blur', function() {
                blurCount++;
                logCheatEvent('TabSwitch', `User left the exam tab (Occurrence: ${blurCount})`);
                new bootstrap.Modal('#cheatModal').show();
            });

            document.addEventListener('keydown', e => {
                if (e.keyCode == 123 || 
                    (e.ctrlKey && e.shiftKey && (e.keyCode == 73 || e.keyCode == 74)) || 
                    (e.ctrlKey && e.keyCode == 85)) {
                    e.preventDefault();
                    logCheatEvent('DevTools', 'Attempted to open Developer Tools');
                }

                if (e.keyCode == 44) {
                    logCheatEvent('PrintScreen', 'Print screen detected');
                }
            });
        }

        function logCheatEvent(type, detail) {
            if (!sessionId) return;
            $.ajax({
                url: `/api/tests/sessions/${sessionId}/log`,
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ actionType: type, detail: detail }),
                global: false
            });
        }
    </script>
    
