@{
    ViewData["Title"] = "Available Tests";
    Layout = "_UserLayout";
}

<div class="container">
    <div class="row">
        <div class="col-12">
            <h2>Available Tests</h2>
            <p class="text-muted">Participate in company Tests and provide feedback</p>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div id="TestsList">
                <div class="text-center">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading Tests...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            loadTests();
        });

        function loadTests() {
            const token = localStorage.getItem('jwtToken');
            
            $.ajax({
                url: '/api/user/tests/Tests',
                method: 'GET',
                headers: {
                    'Authorization': 'Bearer ' + token
                },
                success: function(Tests) {
                    displayTests(Tests);
                },
                error: function() {
                    $('#TestsList').html('<div class="alert alert-warning">Unable to load Tests. Please try again later.</div>');
                }
            });
        }

        function displayTests(Tests) {
            if (Tests.length === 0) {
                $('#TestsList').html('<div class="alert alert-info">No Tests available at the moment.</div>');
                return;
            }

            let html = '<div class="row">';
            
            Tests.forEach(Test => {
                html += `
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5 class="card-title">${Test.title}</h5>
                                <p class="card-text">
                                    <small class="text-muted">
                                        <i class="bi bi-clock"></i> ${Test.durationMinutes} minutes
                                    </small>
                                </p>
                                <button class="btn btn-success" onclick="startTest('${Test.id}')">
                                    Take Test
                                </button>
                            </div>
                        </div>
                    </div>
                `;
            });
            
            html += '</div>';
            $('#TestsList').html(html);
        }

        function startTest(TestId) {
            const token = localStorage.getItem('jwtToken');
            
            $.ajax({
                url: `/api/user/tests/${TestId}/start`,
                method: 'POST',
                headers: {
                    'Authorization': 'Bearer ' + token
                },
                success: function(response) {
                    window.location.href = `/User/TakeTest?testId=${TestId}&sessionId=${response.sessionId}`;
                },
                error: function(xAdmin) {
                    const error = xAdmin.responseJSON?.message || 'Failed to start Test';
                    alert(error);
                }
            });
        }
    </script>
}
