@{
    ViewData["Title"] = "Result Details";
    Layout = "_UserLayout";
    var resultId = ViewBag.ResultId as string;
}

<div class="container">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2>Result Details</h2>
                <a href="/User/Results" class="btn btn-secondary">Back to Results</a>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div id="resultDetails">
                <div class="text-center">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading result details...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            const resultId = '@resultId';
            if (resultId) {
                loadResultDetails(resultId);
            } else {
                $('#resultDetails').html('<div class="alert alert-danger">Result ID not found.</div>');
            }
        });

        function loadResultDetails(resultId) {
            const token = localStorage.getItem('jwtToken');
            
            $.ajax({
                url: `/api/user/tests/results/${resultId}`,
                method: 'GET',
                headers: {
                    'Authorization': 'Bearer ' + token
                },
                success: function(result) {
                    displayResultDetails(result);
                },
                error: function() {
                    $('#resultDetails').html('<div class="alert alert-danger">Unable to load result details. Please try again later.</div>');
                }
            });
        }

        function displayResultDetails(result) {
            const percentage = Math.round((result.score / result.maxScore) * 100);
            const date = new Date(result.submitTime).toLocaleDateString();
            const typeBadge = result.type === 'Test' ? 
                '<span class="badge bg-primary">Test</span>' : 
                '<span class="badge bg-success">Test</span>';
            
            const scoreColor = percentage >= 80 ? 'text-success' : percentage >= 60 ? 'text-warning' : 'text-danger';
            const progressColor = percentage >= 80 ? 'bg-success' : percentage >= 60 ? 'bg-warning' : 'bg-danger';
            
            const html = `
                <div class="card">
                    <div class="card-header">
                        <h3>${result.title} ${typeBadge}</h3>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <h5>Score Summary</h5>
                                <div class="mb-3">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="fw-bold">Your Score:</span>
                                        <span class="${scoreColor} fs-4">${result.score} / ${result.maxScore}</span>
                                    </div>
                                    <div class="progress mt-2">
                                        <div class="progress-bar ${progressColor}" role="progressbar" style="width: ${percentage}%">
                                            ${percentage}%
                                        </div>
                                    </div>
                                </div>
                                <p><strong>Status:</strong> <span class="badge bg-success">${result.status}</span></p>
                                <p><strong>Completed:</strong> ${date}</p>
                            </div>
                            <div class="col-md-6">
                                <h5>Performance</h5>
                                <div class="alert alert-info">
                                    <h6>Great job!</h6>
                                    <p>You have successfully completed this ${result.type.toLowerCase()}.</p>
                                    ${percentage >= 80 ? '<p class="mb-0"><strong>Excellent performance!</strong></p>' : 
                                      percentage >= 60 ? '<p class="mb-0"><strong>Good job!</strong> Keep practicing to improve.</p>' : 
                                      '<p class="mb-0"><strong>Keep practicing!</strong> Review the material and try again.</p>'}
                                </div>
                            </div>
                        </div>
                        
                        <div class="mt-4">
                            <h5>Actions</h5>
                            <div class="d-flex gap-2">
                                <a href="/User/Tests" class="btn btn-primary">Take Another Test</a>
                                <a href="/User/Tests" class="btn btn-success">Take Test</a>
                                <a href="/User/Results" class="btn btn-secondary">View All Results</a>
                            </div>
                        </div>
                    </div>
                </div>
            `;
            
            $('#resultDetails').html(html);
        }
    </script>
}
