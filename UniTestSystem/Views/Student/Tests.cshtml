@{
    ViewData["Title"] = "Available Tests";
    Layout = "_UserLayout";
}

<div class="container">
    <div class="row">
        <div class="col-12">
            <h2>Available Tests</h2>
            <p class="text-muted">Select a test to begin your assessment</p>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div id="testsList">
                <div class="text-center">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading tests...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            loadTests();
        });

        function loadTests() {
            const token = localStorage.getItem('jwtToken');
            
            $.ajax({
                url: '/api/user/tests',
                method: 'GET',
                headers: {
                    'Authorization': 'Bearer ' + token
                },
                success: function(tests) {
                    displayTests(tests);
                },
                error: function() {
                    $('#testsList').html('<div class="alert alert-warning">Unable to load tests. Please try again later.</div>');
                }
            });
        }

        function displayTests(tests) {
            if (tests.length === 0) {
                $('#testsList').html('<div class="alert alert-info">No tests available at the moment.</div>');
                return;
            }

            let html = '<div class="row">';
            
            tests.forEach(test => {
                html += `
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5 class="card-title">${test.title}</h5>
                                <p class="card-text">
                                    <small class="text-muted">
                                        <i class="bi bi-clock"></i> ${test.durationMinutes} minutes<br>
                                        <i class="bi bi-trophy"></i> ${test.totalMaxScore} points
                                    </small>
                                </p>
                                <button class="btn btn-primary" onclick="startTest('${test.id}')">
                                    Start Test
                                </button>
                            </div>
                        </div>
                    </div>
                `;
            });
            
            html += '</div>';
            $('#testsList').html(html);
        }

        function startTest(testId) {
            const token = localStorage.getItem('jwtToken');
            
            $.ajax({
                url: `/api/user/tests/${testId}/start`,
                method: 'POST',
                headers: {
                    'Authorization': 'Bearer ' + token
                },
                success: function(response) {
                    window.location.href = `/User/TakeTest?testId=${testId}&sessionId=${response.sessionId}`;
                },
                error: function(xAdmin) {
                    const error = xAdmin.responseJSON?.message || 'Failed to start test';
                    alert(error);
                }
            });
        }
    </script>
}
