@model List<UniTestSystem.Domain.UserSession>
@{
    ViewData["Title"] = "Phiên làm việc";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Phiên làm việc đang hoạt động</h2>
        <form asp-action="RevokeAll" method="post">
            <button class="btn btn-danger">Đăng xuất khỏi tất cả thiết bị</button>
        </form>
    </div>

    <div class="card shadow">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Thiết bị / Trình duyệt</th>
                        <th>Địa chỉ IP</th>
                        <th>Hoạt động cuối</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td>
                                <div class="text-truncate" style="max-width: 300px;" title="@s.UserAgent">
                                    @s.UserAgent
                                </div>
                            </td>
                            <td>@s.IpAddress</td>
                            <td>@s.LastActivityAt.ToString("g")</td>
                            <td>
                                <form asp-action="Revoke" method="post" class="d-inline">
                                    <input type="hidden" name="sessionId" value="@s.Id" />
                                    <button class="btn btn-sm btn-outline-danger">Đăng xuất</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
