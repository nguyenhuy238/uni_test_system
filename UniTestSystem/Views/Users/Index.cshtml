@using UniTestSystem.Domain
@model List<UniTestSystem.Domain.User>
@{
    ViewData["Title"] = "User Management";
    var classes = (IEnumerable<UniTestSystem.Domain.StudentClass>)ViewBag.Classes ?? new List<UniTestSystem.Domain.StudentClass>();
    string q = ViewBag.Query as string ?? "";
    string classId = ViewBag.ClassId as string ?? "";
    Role? role = ViewBag.Role as Role?;
}

<h2>User Management</h2>

@if (TempData["Msg"] != null)
{
    <div class="alert alert-success">@TempData["Msg"]</div>
}
@if (TempData["Err"] != null)
{
    <div class="alert alert-danger">@TempData["Err"]</div>
}

<form method="get" class="row g-2 mb-3">
    <div class="col-md-3">
        <input name="q" class="form-control" value="@q" placeholder="Search name/email/code..." />
    </div>

    <div class="col-md-3">
        <select name="classId" class="form-select">
            <option value="">-- All Classes --</option>
            @foreach (var t in classes)
            {
                <option value="@t.Id" selected="@(classId == t.Id ? "selected" : null)">@t.Name</option>
            }
        </select>
    </div>

    <div class="col-md-3">
        <select name="role" class="form-select">
            <option value="">-- All Roles --</option>
            @foreach (Role r in Enum.GetValues(typeof(Role)))
            {
                <option value="@r" selected="@(role.HasValue && role.Value == r ? "selected" : null)">@r</option>
            }
        </select>
    </div>

    <div class="col-md-3">
        <button class="btn btn-primary">Filter</button>
        <a class="btn btn-secondary" asp-action="Index">Reset</a>
        <a class="btn btn-success" asp-action="Create">+ Create User</a>
    </div>
</form>

<div class="card shadow-sm">
    <div class="card-body table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Code</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Year</th>
                    <th>Class</th>
                    <th>Faculty</th>
                    <th style="width:260px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td>@u.Name</td>
                        @{
                            var stu = u as Student;
                            var lec = u as Lecturer;
                        }
                        <td><span class="badge bg-light text-dark">@(stu?.StudentCode ?? lec?.LecturerCode ?? "-")</span></td>
                        <td>@u.Email</td>
                        <td>@u.Role</td>
                        <td>@(stu?.AcademicYear ?? "-")</td>
                        <td>@(stu != null ? (classes.FirstOrDefault(c => c.Id == stu.StudentClassId)?.Name ?? "-") : "-")</td>
                        <td>@(lec?.FacultyId ?? "-")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@u.Id">Edit</a>

                            <form asp-action="ResetPassword" asp-route-id="@u.Id" method="post" class="d-inline" asp-antiforgery="true">
                                <input name="newPassword" class="form-control form-control-sm d-inline-block" style="width:100px" placeholder="New pass" />
                                <button class="btn btn-sm btn-outline-warning">Reset</button>
                            </form>

                            <form asp-action="Delete" asp-route-id="@u.Id" method="post" class="d-inline" asp-antiforgery="true" onsubmit="return confirm('Delete this user?');">
                                <button class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
