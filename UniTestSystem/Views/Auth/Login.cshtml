@{
    Layout = "_Layout";
    ViewData["Title"] = "Login";
}

<div class="uts-auth-shell">
    <aside class="uts-auth-visual">
        <div>
            <h2 class="fw-bold mb-3">UniTestSystem</h2>
            <p class="mb-2">Nền tảng khảo thí và quản lý đào tạo chuẩn đại học.</p>
            <ul class="mb-0 ps-3">
                <li>Làm bài thi online ổn định, dễ thao tác</li>
                <li>Giám sát phiên thi minh bạch</li>
                <li>Báo cáo kết quả học thuật tập trung</li>
            </ul>
        </div>
    </aside>

    <section class="uts-auth-form">
        <h3 class="fw-bold mb-2">Đăng nhập</h3>
        <p class="text-muted mb-4">Sử dụng tài khoản đã được cấp bởi nhà trường.</p>

        <partial name="~/Views/Shared/_Flash.cshtml" />

        <form method="post" action="/auth/login" novalidate>
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
            <div class="mb-3">
                <label class="form-label fw-semibold">Email</label>
                <input name="email" class="form-control" autocomplete="username" placeholder="lecturer@university.edu.vn" value="admin@local" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Mật khẩu</label>
                <input name="password" type="password" class="form-control" autocomplete="current-password" />
            </div>
            <div class="mb-3 form-check">
                <input name="rememberMe" type="checkbox" class="form-check-input" id="rememberMe" value="true" />
                <label class="form-check-label" for="rememberMe">Ghi nhớ đăng nhập</label>
            </div>
            <button class="btn btn-primary w-100">Đăng nhập</button>
            <div class="text-danger mt-2">@ViewBag.Error</div>
        </form>

        <div class="mt-3 d-flex flex-wrap gap-2">
            <a class="btn btn-link p-0" href="/auth/forgot">Quên mật khẩu?</a>
            <span class="text-muted">|</span>
            <a class="btn btn-link p-0" href="/auth/register">Đăng ký tài khoản</a>
        </div>

        <div class="mt-4 pt-3 border-top">
            <div class="small text-muted mb-2">Chưa nhận email xác nhận?</div>
            <form method="post" action="/auth/resend-confirmation" class="row g-2">
                @Html.AntiForgeryToken()
                <div class="col-12 col-lg-8">
                    <input name="email" type="email" class="form-control" placeholder="Nhập email để gửi lại link xác nhận" />
                </div>
                <div class="col-12 col-lg-4 d-grid">
                    <button class="btn btn-outline-secondary">Gửi lại</button>
                </div>
            </form>
        </div>
    </section>
</div>
