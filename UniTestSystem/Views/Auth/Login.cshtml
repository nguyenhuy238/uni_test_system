@{
    Layout = "_Layout";
    ViewData["Title"] = "Login";
}
<h2>Đăng nhập</h2>

<partial name="~/Views/Shared/_Flash.cshtml" />

<form method="post" action="/auth/login">
    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
    <div class="mb-3">
        <label class="form-label">Email</label>
        <input name="email" class="form-control" value="admin@local" />
    </div>
    <div class="mb-3">
        <label class="form-label">Mật khẩu</label>
        <input name="password" type="password" class="form-control" />
    </div>
    <div class="mb-3 form-check">
        <input name="rememberMe" type="checkbox" class="form-check-input" id="rememberMe" value="true" />
        <label class="form-check-label" for="rememberMe">Ghi nhớ đăng nhập</label>
    </div>
    <button class="btn btn-primary">Login</button>
    <div class="text-danger mt-2">@ViewBag.Error</div>
</form>

<div class="mt-3">
    <a href="/auth/forgot">Quên mật khẩu?</a> | <a href="/auth/register">Đăng ký tài khoản</a>
</div>

<div class="mt-3">
    <form method="post" action="/auth/resend-confirmation" class="row g-2">
        @Html.AntiForgeryToken()
        <div class="col-md-4">
            <input name="email" type="email" class="form-control" placeholder="Nhập email để gửi lại link xác nhận" />
        </div>
        <div class="col-auto">
            <button class="btn btn-outline-secondary">Gửi lại email xác nhận</button>
        </div>
    </form>
</div>
