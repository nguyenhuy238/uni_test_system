@using UniTestSystem.Application.Interfaces;
@using System.Security.Claims
@using UniTestSystem.Domain
@using UniTestSystem.Application

@inject UniTestSystem.Application.Interfaces.ISettingsService SettingsService
@inject UniTestSystem.Application.IPermissionService PermissionService

@{
    var isAuth = User?.Identity?.IsAuthenticated ?? false;
    var role = User?.FindFirst(ClaimTypes.Role)?.Value;
    var name = User?.Identity?.Name ?? "Guest";

    // Settings
    var settings = SettingsService.GetAsync().GetAwaiter().GetResult();
    var systemName = string.IsNullOrWhiteSpace(settings.SystemName) ? "UniTestSystem" : settings.SystemName;
    var logoUrl = settings.LogoUrl;

    // Permissions
    bool canViewReports = isAuth && PermissionService.HasAsync(User!, PermissionCodes.Reports_View).GetAwaiter().GetResult();
    bool canEditSettings = isAuth && PermissionService.HasAsync(User!, PermissionCodes.Settings_Edit).GetAwaiter().GetResult();
    bool canManagePerms = isAuth && PermissionService.HasAsync(User!, PermissionCodes.Roles_Assign).GetAwaiter().GetResult();
    bool canViewAudit = isAuth && PermissionService.HasAsync(User!, PermissionCodes.Audit_View).GetAwaiter().GetResult();
    bool canViewOrg = isAuth && (
        PermissionService.HasAsync(User!, PermissionCodes.Org_View).GetAwaiter().GetResult() ||
        PermissionService.HasAsync(User!, PermissionCodes.Org_Manage).GetAwaiter().GetResult()
    );

    ViewData["Title"] ??= systemName;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @systemName</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/UniTestSystem.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index" title="@systemName">
                    @if (!string.IsNullOrWhiteSpace(logoUrl))
                    {
                        <img src="@logoUrl" alt="Logo" style="height:28px" />
                    }
                    <span>@systemName</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div id="mainNav" class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <!-- LEFT -->
                     <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacy</a></li>

                        @if (isAuth)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="MyTests" asp-action="Index">My Tests</a></li>
                            
                            @if (canViewOrg || canViewReports || canEditSettings || canManagePerms)
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" id="manageMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        Management
                                    </a>
                                    <ul class="dropdown-menu" aria-labelledby="manageMenu">
                                        @if (role == "Admin")
                                        {
                                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="Dashboard">Admin Dashboard</a></li>
                                            <li><a class="dropdown-item" asp-controller="Users" asp-action="Index">User Management</a></li>
                                        }
                                        @if (canViewOrg)
                                        {
                                            <li><hr class="dropdown-divider" /></li>
                                            <li><a class="dropdown-item" asp-controller="Faculties" asp-action="Index">Faculties</a></li>
                                            <li><a class="dropdown-item" asp-controller="Classes" asp-action="Index">Classes</a></li>
                                        }
                                        @if (canViewReports)
                                        {
                                            <li><hr class="dropdown-divider" /></li>
                                            <li><a class="dropdown-item" asp-controller="Reports" asp-action="Index">Reports</a></li>
                                        }
                                        @if (canEditSettings || canManagePerms)
                                        {
                                            <li><hr class="dropdown-divider" /></li>
                                            @if (canEditSettings)
                                            {
                                                <li><a class="dropdown-item" asp-controller="Settings" asp-action="Index">Settings</a></li>
                                            }
                                            @if (canManagePerms)
                                            {
                                                <li><a class="dropdown-item" asp-controller="Roles" asp-action="Index">Permissions</a></li>
                                            }
                                        }
                                    </ul>
                                </li>
                            }
                        }
                    </ul>

                    <!-- RIGHT -->
                    <ul class="navbar-nav mb-2 mb-lg-0">

                        @if (!isAuth)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Auth" asp-action="Login">Login</a></li>
                        }
                        else
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="userMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    @name (@role)
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
                                    <li><a class="dropdown-item" asp-controller="Profile" asp-action="Edit">Profile</a></li>
                                    <li><a class="dropdown-item" asp-controller="Profile" asp-action="ChangePassword">Change password</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <form method="post" action="/auth/logout" class="px-3">
                                            <button type="submit" class="btn btn-link p-0">Logout</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        @if (TempData["Msg"] is string msg)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @msg <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Err"] is string err)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @err <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Info"] is string inf)
        {
            <div class="alert alert-info alert-dismissible fade show" role="alert">
                @inf <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container py-3">
            &copy; @DateTime.Now.Year - @systemName -
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
