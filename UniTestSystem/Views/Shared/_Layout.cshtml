@using UniTestSystem.Application.Interfaces;
@using System.Security.Claims
@using UniTestSystem.Domain
@using UniTestSystem.Application

@inject UniTestSystem.Application.Interfaces.ISettingsService SettingsService
@inject UniTestSystem.Application.IPermissionService PermissionService

@{
    var isAuth = User?.Identity?.IsAuthenticated ?? false;
    var role = User?.FindFirst(ClaimTypes.Role)?.Value;
    var name = User?.Identity?.Name ?? "Guest";
    var brandController = "Home";
    var brandAction = "Index";

    if (isAuth)
    {
        switch (role)
        {
            case nameof(Role.Admin):
                brandController = "Admin";
                brandAction = "Dashboard";
                break;
            case nameof(Role.Staff):
                brandController = "Staff";
                brandAction = "Dashboard";
                break;
            case nameof(Role.Lecturer):
                brandController = "Lecturer";
                brandAction = "Dashboard";
                break;
            case nameof(Role.Student):
                brandController = "MyTests";
                brandAction = "Index";
                break;
        }
    }

    // Settings
    var settings = SettingsService.GetAsync().GetAwaiter().GetResult();
    var systemName = string.IsNullOrWhiteSpace(settings.SystemName) ? "UniTestSystem" : settings.SystemName;
    var logoUrl = settings.LogoUrl;

    // Permissions
    bool canViewReports = isAuth && PermissionService.HasAsync(User!, PermissionCodes.Reports_View).GetAwaiter().GetResult();
    bool canEditSettings = isAuth && PermissionService.HasAsync(User!, PermissionCodes.Settings_Edit).GetAwaiter().GetResult();
    bool canManagePerms = isAuth && PermissionService.HasAsync(User!, PermissionCodes.Roles_Assign).GetAwaiter().GetResult();
    bool canViewAudit = isAuth && PermissionService.HasAsync(User!, PermissionCodes.Audit_View).GetAwaiter().GetResult();
    bool canViewOrg = isAuth && (
        PermissionService.HasAsync(User!, PermissionCodes.Org_View).GetAwaiter().GetResult() ||
        PermissionService.HasAsync(User!, PermissionCodes.Org_Manage).GetAwaiter().GetResult()
    );

    ViewData["Title"] ??= systemName;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @systemName</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/UniTestSystem.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark uts-app-navbar shadow-sm mb-3">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="@brandController" asp-action="@brandAction" title="@systemName">
                    @if (!string.IsNullOrWhiteSpace(logoUrl))
                    {
                        <img src="@logoUrl" alt="Logo" style="height:28px" />
                    }
                    <span>@systemName</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div id="mainNav" class="navbar-collapse collapse justify-content-between">
                    <!-- LEFT -->
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Privacy">Chính sách</a></li>

                        @if (isAuth && role == Role.Student.ToString())
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="MyTests" asp-action="Index">Bài thi của tôi</a></li>
                            <li class="nav-item"><a class="nav-link fw-semibold" asp-controller="Exams" asp-action="MyExams">Lịch thi</a></li>
                            <li class="nav-item"><a class="nav-link fw-semibold" asp-controller="Transcripts" asp-action="MyTranscript">Bảng điểm</a></li>
                        }

                        @if (role == "Admin" || role == "Lecturer" || (role != "Staff" && (canViewOrg || canViewReports || canEditSettings || canManagePerms)))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="manageMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Quản trị
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="manageMenu">
                                    @if (role == "Admin")
                                    {
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Dashboard">Admin Dashboard</a></li>
                                        <li><a class="dropdown-item" asp-controller="Users" asp-action="Index">Người dùng</a></li>
                                        <li><a class="dropdown-item" asp-controller="Transcripts" asp-action="Index">Bảng điểm sinh viên</a></li>
                                    }
                                    @if (role == "Lecturer")
                                    {
                                        <li><a class="dropdown-item" asp-controller="Lecturer" asp-action="Dashboard">Lecturer Dashboard</a></li>
                                        <li><a class="dropdown-item" asp-controller="Questions" asp-action="Index">Ngân hàng câu hỏi</a></li>
                                        <li><a class="dropdown-item" asp-controller="Tests" asp-action="Index">Quản lý bài thi</a></li>
                                    }
                                    @if (role == "Admin" || role == "Staff")
                                    {
                                        <li><a class="dropdown-item" asp-controller="Exams" asp-action="Index">Lập lịch thi</a></li>
                                    }
                                    @if (canViewOrg)
                                    {
                                        <li><hr class="dropdown-divider" /></li>
                                        <li><a class="dropdown-item" asp-controller="Faculties" asp-action="Index">Khoa</a></li>
                                        <li><a class="dropdown-item" asp-controller="Classes" asp-action="Index">Lớp</a></li>
                                    }
                                    @if (canViewReports)
                                    {
                                        <li><hr class="dropdown-divider" /></li>
                                        <li><a class="dropdown-item" asp-controller="Reports" asp-action="Index">Báo cáo</a></li>
                                    }
                                    @if (canEditSettings || canManagePerms)
                                    {
                                        <li><hr class="dropdown-divider" /></li>
                                        @if (canEditSettings)
                                        {
                                            <li><a class="dropdown-item" asp-controller="Settings" asp-action="Index">Cài đặt</a></li>
                                        }
                                        @if (canManagePerms)
                                        {
                                            <li><a class="dropdown-item" asp-controller="Roles" asp-action="Index">Phân quyền</a></li>
                                        }
                                    }
                                </ul>
                            </li>
                        }

                        @if (isAuth && role == "Staff")
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="staffMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Staff
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="staffMenu">
                                    <li><a class="dropdown-item" asp-controller="Staff" asp-action="Dashboard">Staff Dashboard</a></li>
                                    <li><a class="dropdown-item" asp-controller="Users" asp-action="Index">Người dùng</a></li>
                                    <li><a class="dropdown-item" asp-controller="Transcripts" asp-action="Index">Bảng điểm sinh viên</a></li>
                                    <li><a class="dropdown-item" asp-controller="Exams" asp-action="Index">Lập lịch thi</a></li>
                                    @if (canViewOrg)
                                    {
                                        <li><hr class="dropdown-divider" /></li>
                                        <li><a class="dropdown-item" asp-controller="Faculties" asp-action="Index">Khoa</a></li>
                                        <li><a class="dropdown-item" asp-controller="Classes" asp-action="Index">Lớp</a></li>
                                    }
                                    @if (canViewReports)
                                    {
                                        <li><hr class="dropdown-divider" /></li>
                                        <li><a class="dropdown-item" asp-controller="Reports" asp-action="Index">Báo cáo</a></li>
                                    }
                                </ul>
                            </li>
                        }
                    </ul>

                    <!-- RIGHT -->
                    <ul class="navbar-nav mb-2 mb-lg-0">

                        @if (!isAuth)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Auth" asp-action="Login">Đăng nhập</a></li>
                        }
                        else
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="userMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    @name (@role)
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
                                    <li><a class="dropdown-item" asp-controller="Profile" asp-action="Edit">Hồ sơ</a></li>
                                    <li><a class="dropdown-item" asp-controller="Profile" asp-action="ChangePassword">Đổi mật khẩu</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <form method="post" action="/auth/logout" class="px-3">
                                            <button type="submit" class="btn btn-link p-0">Đăng xuất</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container uts-page-wrap">
        @if (TempData["Msg"] is string msg)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @msg <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Err"] is string err)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @err <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["ErrDetail"] is string errDetail)
        {
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                <div class="fw-semibold mb-1">Chi tiết lỗi import</div>
                <pre class="mb-0 small" style="white-space: pre-wrap; max-height: 280px; overflow: auto;">@errDetail</pre>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Info"] is string inf)
        {
            <div class="alert alert-info alert-dismissible fade show" role="alert">
                @inf <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container py-3 uts-footer">
            &copy; @DateTime.Now.Year - @systemName -
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
