@model UniTestSystem.ViewModels.ErrorViewModel
@{
    ViewData["Title"] = $"Error {Model.StatusCode}";
}

<div class="container py-5">
    <h1 class="text-danger mb-3">Error @Model.StatusCode</h1>
    <p class="lead mb-4">@Model.Message</p>

    @if (Model.ShowRequestId)
    {
        <p class="text-muted mb-4">
            Request ID: <code>@Model.RequestId</code>
        </p>
    }

    <a class="btn btn-primary" href="/">Back to home</a>
</div>
