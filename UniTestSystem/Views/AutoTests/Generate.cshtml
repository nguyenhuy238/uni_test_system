@model UniTestSystem.Application.AutoTestOptions
@{
    ViewData["Title"] = "Auto Generate Test";
    var faculties = (IEnumerable<string>)(ViewBag.Faculties ?? new List<string>());
}
<partial name="~/Views/Shared/_Flash.cshtml" />

<h2 class="mb-3">Auto Generate Test</h2>

<div class="alert alert-info">
    <div><strong>Ghi chú:</strong> Khi bấm Generate, hệ thống sẽ <u>cá nhân hoá</u> đề thi cho từng sinh viên:</div>
    <ul class="mb-0">
        <li>Tự động ưu tiên <b>Môn học</b> theo <code>User.Major</code> (nếu bạn không nhập Subject tay).</li>
        <li>Tự động lọc <b>Độ khó</b> phù hợp với <code>User.AcademicYear</code> (Năm 1/2/3/4).</li>
        <li>Các sinh viên có thể nhận các <b>đề khác nhau</b> để phù hợp với năng lực.</li>
        <li>Kết quả tạo ra là <b>Test ở trạng thái Draft</b> để xem trước; bạn có thể Assign từng đề hoặc Assign All ở trang kết quả.</li>
    </ul>
</div>

<form asp-action="Generate" asp-controller="AutoTests" method="post" class="row g-3" id="autoGenForm">
    @Html.AntiForgeryToken()

    <div class="col-md-3">
        <label class="form-label">Chế độ (Mode)</label>
        <select class="form-select" asp-for="Mode" id="modeSelect">
            <option value="Faculty">Faculty (Khoa)</option>
            <option value="Users">Users (ids)</option>
        </select>
    </div>

    <div class="col-md-3" id="deptBlock">
        <label class="form-label">Khoa (Faculty)</label>
        <select class="form-select" asp-for="FacultyName">
            <option value="">-- chọn Khoa --</option>
            @foreach (var d in faculties)
            {
                <option value="@d">@d</option>
            }
        </select>
        <div class="form-text">Dùng khi Mode = Faculty</div>
    </div>

    <div class="col-md-6" id="usersBlock" style="display:none;">
        <label class="form-label">UserIds</label>
        <textarea class="form-control" id="userIdsTextarea" rows="4"
                  placeholder="Nhập nhiều UserId, mỗi dòng 1 id"></textarea>
        <div class="form-text">Dùng khi Mode = Users. Mỗi dòng 1 UserId.</div>
    </div>

    <div class="col-md-6">
        <label class="form-label">Môn học (Subjects - dấu phẩy)</label>
        <input class="form-control" id="skillsCsv" placeholder="Programming, Math" />
        <small class="text-muted">Để trống = tự động lấy theo chuyên ngành của sinh viên.</small>
    </div>

    <div class="col-md-3">
        <label class="form-label">Chính sách độ khó</label>
        <select class="form-select" asp-for="DifficultyPolicy" id="diffPolicySelect">
            <option value="ByYear">ByYear (phù hợp năm học sinh viên)</option>
            <option value="Matrix">Matrix (Cấu hình chi tiết số câu mỗi mức)</option>
            <option value="Any">Bất kỳ</option>
        </select>
    </div>

    <div class="col-md-6">
        <label class="form-label">Tags (vd: Chương 1, Bài 2 - dấu phẩy)</label>
        <input class="form-control" id="tagsCsv" placeholder="Chương 1, Bài 2" />
        <div class="form-text">Lọc câu hỏi theo Tags (OR). Để trống = lấy tất cả.</div>
    </div>

    <!-- Matrix configuration (hidden by default) -->
    <div class="col-12" id="matrixBlock" style="display:none;">
        <div class="card card-body bg-light border-primary p-3">
            <h6 class="text-primary fw-bold mb-3"><i class="bi bi-grid-3x3"></i> Difficulty Matrix (Ma trận số lượng câu hỏi theo độ khó)</h6>
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label small">Easy Count</label>
                    <input type="number" class="form-control form-control-sm matrix-input" data-diff="Easy" value="0" min="0" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small">Medium Count</label>
                    <input type="number" class="form-control form-control-sm matrix-input" data-diff="Medium" value="0" min="0" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small">Hard Count</label>
                    <input type="number" class="form-control form-control-sm matrix-input" data-diff="Hard" value="0" min="0" />
                </div>
            </div>
            <div class="form-text mt-2">Khi chọn Matrix, hệ thống sẽ ưu tiên bốc chính xác số câu theo độ khó này. Các ràng buộc về loại câu hỏi (MCQ, TF) vẫn được áp dụng song song nếu có thể.</div>
        </div>
    </div>

    <div class="col-12"><hr /></div>

    <div class="col-md-2">
        <label class="form-label">MCQ</label>
        <input type="number" class="form-control" asp-for="McqCount" min="0" />
    </div>
    <div class="col-md-2">
        <label class="form-label">True/False</label>
        <input type="number" class="form-control" asp-for="TfCount" min="0" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Matching</label>
        <input type="number" class="form-control" asp-for="MatchingCount" min="0" />
    </div>
    <div class="col-md-2">
        <label class="form-label">DragDrop</label>
        <input type="number" class="form-control" asp-for="DragDropCount" min="0" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Essay</label>
        <input type="number" class="form-control" asp-for="EssayCount" min="0" />
    </div>

    <div class="col-md-2">
        <label class="form-label">Total Score</label>
        <input type="number" class="form-control" asp-for="TotalScore" min="1" step="0.01" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Essay Reserved</label>
        <input type="number" class="form-control" asp-for="EssayReserved" min="0" step="0.01" />
        <div class="form-text">Để 0: auto mặc định 2.0 khi có Essay</div>
    </div>

    <div class="col-md-3">
        <label class="form-label">Start (UTC)</label>
        <input type="datetime-local" class="form-control" asp-for="StartAtUtc" />
    </div>
    <div class="col-md-3">
        <label class="form-label">End (UTC)</label>
        <input type="datetime-local" class="form-control" asp-for="EndAtUtc" />
    </div>

    <div class="col-12">
        <button class="btn btn-primary">Generate (Preview)</button>
        <a class="btn btn-secondary" href="/Tests">Back</a>
    </div>
</form>

@section Scripts {
    <script>
        // Toggle Department / Users theo Mode
        const modeSel = document.getElementById('modeSelect');
        const deptBlock = document.getElementById('deptBlock');
        const usersBlock = document.getElementById('usersBlock');

        function toggleBlocks(){
          const mode = modeSel ? modeSel.value : 'Department';
          if(mode === 'Users'){
            usersBlock.style.display = '';
            deptBlock.style.display = 'none';
          } else {
            usersBlock.style.display = 'none';
            deptBlock.style.display = '';
          }
        }
        if(modeSel){ modeSel.addEventListener('change', toggleBlocks); toggleBlocks(); }
        
        // Toggle Matrix block
        const diffPolicySelect = document.getElementById('diffPolicySelect');
        const matrixBlock = document.getElementById('matrixBlock');
        function toggleMatrix(){
            if(diffPolicySelect && matrixBlock){
                matrixBlock.style.display = (diffPolicySelect.value === 'Matrix') ? '' : 'none';
            }
        }
        if(diffPolicySelect){ diffPolicySelect.addEventListener('change', toggleMatrix); toggleMatrix(); }

        // Chuyển Skills (Subjects) CSV -> nhiều input hidden name="Subjects"
        const skillsCsv = document.getElementById('skillsCsv');
        function syncSubjects(){
          document.querySelectorAll('input[name="Subjects"]').forEach(el => el.remove());
          if(!skillsCsv || !skillsCsv.value) return;
          const arr = skillsCsv.value.split(',')
                       .map(s => s.trim())
                       .filter(Boolean);
          const form = document.getElementById('autoGenForm');
          arr.forEach(v => {
            const i = document.createElement('input');
            i.type = 'hidden'; i.name = 'Subjects'; i.value = v;
            form.appendChild(i);
          });
        }
        
        // Chuyển Tags CSV -> nhiều input hidden name="Tags"
        const tagsCsv = document.getElementById('tagsCsv');
        function syncTags(){
          document.querySelectorAll('input[name="Tags"]').forEach(el => el.remove());
          if(!tagsCsv || !tagsCsv.value) return;
          const arr = tagsCsv.value.split(',')
                       .map(s => s.trim())
                       .filter(Boolean);
          const form = document.getElementById('autoGenForm');
          arr.forEach(v => {
            const i = document.createElement('input');
            i.type = 'hidden'; i.name = 'Tags'; i.value = v;
            form.appendChild(i);
          });
        }

        // Chuyển Difficulty Matrix inputs -> hiddden inputs
        function syncMatrix(){
          document.querySelectorAll('input[name^="DifficultyMatrix"]').forEach(el => el.remove());
          if(!diffPolicySelect || diffPolicySelect.value !== 'Matrix') return;
          const inputs = document.querySelectorAll('.matrix-input');
          const form = document.getElementById('autoGenForm');
          let idx = 0;
          inputs.forEach(inp => {
            const count = parseInt(inp.value);
            if(count > 0){
                const idInput = document.createElement('input');
                idInput.type = 'hidden'; idInput.name = `DifficultyMatrix[${idx}].DifficultyLevelId`; idInput.value = inp.dataset.diff;
                const countInput = document.createElement('input');
                countInput.type = 'hidden'; countInput.name = `DifficultyMatrix[${idx}].Count`; countInput.value = count;
                form.appendChild(idInput);
                form.appendChild(countInput);
                idx++;
            }
          });
        }

        // Chuyển UserIds (mỗi dòng) -> nhiều input hidden name="UserIds"
        const userIdsTextarea = document.getElementById('userIdsTextarea');
        function syncUserIds(){
          document.querySelectorAll('input[name="UserIds"]').forEach(el => el.remove());
          if(!userIdsTextarea || !userIdsTextarea.value) return;
          const arr = userIdsTextarea.value.split(/\r?\n/)
                       .map(s => s.trim())
                       .filter(Boolean);
          const form = document.getElementById('autoGenForm');
          arr.forEach(v => {
            const i = document.createElement('input');
            i.type = 'hidden'; i.name = 'UserIds'; i.value = v;
            form.appendChild(i);
          });
        }

        // Trước khi submit: sync hết các hidden inputs
        const formEl = document.getElementById('autoGenForm');
        if(formEl){
          formEl.addEventListener('submit', function(){
            syncSubjects();
            syncUserIds();
            syncTags();
            syncMatrix();
          });
        }

        // Đồng bộ theo thao tác người dùng (không bắt buộc)
        if(skillsCsv){
          skillsCsv.addEventListener('change', syncSubjects);
          skillsCsv.addEventListener('keyup', syncSubjects);
        }
    </script>
}
