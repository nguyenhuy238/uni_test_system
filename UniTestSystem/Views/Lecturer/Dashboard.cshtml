@{
    ViewData["Title"] = "Lecturer Dashboard";
    Layout = "_Layout";
    var name = User.Identity?.Name ?? "Lecturer";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Chào mừng Giảng viên, @name!</h2>
        <p class="text-muted">UniTestSystem Lecturer Dashboard</p>
    </div>
    <div class="text-end">
        <span class="badge bg-success">Lecturer</span>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0 bg-primary bg-opacity-10 text-primary">
            <div class="card-body text-center py-4">
                <i class="bi bi-question-circle fs-1 mb-2"></i>
                <h3 class="display-6 fw-bold">@ViewBag.TotalQuestions</h3>
                <p class="card-text fw-bold">Tổng số Câu hỏi</p>
                <a href="/questions" class="btn btn-primary btn-sm mt-2">Quản lý câu hỏi</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0 bg-info bg-opacity-10 text-info">
            <div class="card-body text-center py-4">
                <i class="bi bi-file-earmark-text fs-1 mb-2"></i>
                <h3 class="display-6 fw-bold">@ViewBag.TotalTests</h3>
                <p class="card-text fw-bold">Bài thi đã tạo</p>
                <a href="/tests" class="btn btn-info btn-sm text-white mt-2">Quản lý bài thi</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0 bg-warning bg-opacity-10 text-warning">
            <div class="card-body text-center py-4">
                <i class="bi bi-clock-history fs-1 mb-2"></i>
                <h3 class="display-6 fw-bold">@ViewBag.PendingQuestions</h3>
                <p class="card-text fw-bold">Câu hỏi chờ duyệt</p>
                <a href="/questions?Status=Pending" class="btn btn-warning btn-sm text-white mt-2">Xem danh sách</a>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-bottom-0 pt-4">
                <h5 class="card-title"><i class="bi bi-lightning-charge me-2 text-primary"></i>Thao tác nhanh</h5>
            </div>
            <div class="card-body">
                <div class="list-group list-group-flush">
                    <a href="/questions/create" class="list-group-item list-group-item-action border-0 px-0">
                        <i class="bi bi-plus-circle me-2"></i>Tạo câu hỏi mới
                    </a>
                    <a href="/tests/create" class="list-group-item list-group-item-action border-0 px-0">
                        <i class="bi bi-file-plus me-2"></i>Thiết kế bài thi mới
                    </a>
                    <a href="/reports" class="list-group-item list-group-item-action border-0 px-0">
                        <i class="bi bi-bar-chart me-2"></i>Xem báo cáo học thuật
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
