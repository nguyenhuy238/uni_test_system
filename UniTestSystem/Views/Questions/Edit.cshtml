@model UniTestSystem.Domain.Question
@using UniTestSystem.Domain
@using UniTestSystem.Application
@inject UniTestSystem.Application.IPermissionService PermissionService
@{
    var versions = ViewBag.QuestionVersions as List<AuditEntry> ?? new List<AuditEntry>();
    var canApproveQuestion = PermissionService.HasAsync(User!, PermissionCodes.Question_Approve).GetAwaiter().GetResult();
}
<h2>Edit Question</h2>

@if (TempData["Msg"] != null)
{
    <div class="alert alert-success">@TempData["Msg"]</div>
}
@if (TempData["Err"] != null)
{
    <div class="alert alert-danger">@TempData["Err"]</div>
}
@if (TempData["ErrDetail"] != null)
{
    <pre class="alert alert-warning" style="white-space:pre-wrap">@TempData["ErrDetail"]</pre>
}

<form asp-controller="Questions"
      asp-action="Edit"
      asp-route-id="@Model.Id"
      method="post"
      enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>

    <partial name="_Form" model="Model" />

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        
        @if (Model.Status == QuestionStatus.Draft || Model.Status == QuestionStatus.Rejected)
        {
            <button type="submit" asp-action="Submit" class="btn btn-info ms-2">Submit for Approval</button>
        }

        @if (Model.Status == QuestionStatus.Pending && canApproveQuestion)
        {
            <button type="submit" asp-action="Approve" class="btn btn-success ms-2">Approve</button>
            <button type="button" class="btn btn-danger ms-2" data-bs-toggle="collapse" data-bs-target="#rejectBlock">Reject</button>
        }

        <a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
    </div>
</form>

@if (canApproveQuestion)
{
    <div id="rejectBlock" class="collapse mt-3 alert alert-danger">
        <form asp-action="Reject" asp-route-id="@Model.Id" method="post">
            <label>Reason for Rejection:</label>
            <textarea name="reason" class="form-control mb-2" required></textarea>
            <button class="btn btn-danger">Confirm Reject</button>
        </form>
    </div>
}

@if (versions.Any())
{
    <div class="card mt-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span class="fw-bold">Version History (Audit)</span>
            <span class="text-muted small">Last @versions.Count entries</span>
        </div>
        <div class="card-body p-0">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-3">At (UTC)</th>
                        <th>Actor</th>
                        <th>Action</th>
                        <th class="text-end pe-3">Restore</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in versions)
                    {
                        <tr>
                            <td class="ps-3">@v.At.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td>@v.Actor</td>
                            <td>@v.Action</td>
                            <td class="text-end pe-3">
                                <form asp-action="RestoreVersion" asp-route-id="@Model.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="auditId" value="@v.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning" onclick="return confirm('Restore this version? Current content will be replaced.')">
                                        Restore
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (Model.Media?.Any() ?? false)
{
    ViewBag.AllowDeleteMedia = true;
    ViewBag.QuestionId = Model.Id;
    <div class="mt-3">
        <partial name="~/Views/Shared/_MediaViewer.cshtml" model="Model.Media" />
    </div>
}
