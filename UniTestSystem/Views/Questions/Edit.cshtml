@model UniTestSystem.Domain.Question
@using UniTestSystem.Domain
@{
    var versions = ViewBag.QuestionVersions as List<AuditEntry> ?? new List<AuditEntry>();
    bool canSubmitQuestion = (ViewBag.CanSubmitQuestion as bool?) ?? false;
    bool canApproveQuestion = (ViewBag.CanApproveQuestion as bool?) ?? false;
}
<h2>Edit Question</h2>

@if (TempData["Msg"] != null)
{
    <div class="alert alert-success">@TempData["Msg"]</div>
}
@if (TempData["Err"] != null)
{
    <div class="alert alert-danger">@TempData["Err"]</div>
}
@if (TempData["ErrDetail"] != null)
{
    <pre class="alert alert-warning" style="white-space:pre-wrap">@TempData["ErrDetail"]</pre>
}

<form asp-controller="Questions"
      asp-action="Edit"
      asp-route-id="@Model.Id"
      method="post"
      enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>

    <partial name="_Form" model="Model" />

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
    </div>
</form>

<div class="mt-3 d-flex gap-2 flex-wrap">
        @if (canSubmitQuestion && (Model.Status == QuestionStatus.Draft || Model.Status == QuestionStatus.Rejected))
        {
                <form asp-action="Submit" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-outline-warning" onclick="return confirm('Gửi câu hỏi này để duyệt?')">Submit For Review</button>
                </form>
        }

        @if (canApproveQuestion && Model.Status == QuestionStatus.Pending)
        {
                <form asp-action="Approve" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-outline-success" onclick="return confirm('Phê duyệt câu hỏi này?')">Approve</button>
                </form>

                <form asp-action="Reject" method="post" class="d-inline" id="rejectForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="reason" id="rejectReason" value="" />
                        <button type="submit" class="btn btn-outline-danger">Reject</button>
                </form>
        }
</div>

<script>
    (function() {
        const rejectForm = document.getElementById('rejectForm');
        if (!rejectForm) {
            return;
        }

        rejectForm.addEventListener('submit', function(event) {
            const reason = prompt('Nhập lý do từ chối câu hỏi:', 'Rejected by reviewer');
            if (reason === null) {
                event.preventDefault();
                return;
            }

            const input = document.getElementById('rejectReason');
            if (input) {
                input.value = reason.trim();
            }
        });
    })();
</script>

@if (versions.Any())
{
    <div class="card mt-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span class="fw-bold">Version History (Audit)</span>
            <span class="text-muted small">Last @versions.Count entries</span>
        </div>
        <div class="card-body p-0">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-3">At (UTC)</th>
                        <th>Actor</th>
                        <th>Action</th>
                        <th class="text-end pe-3">Restore</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in versions)
                    {
                        <tr>
                            <td class="ps-3">@v.At.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td>@v.Actor</td>
                            <td>@v.Action</td>
                            <td class="text-end pe-3">
                                <form asp-action="RestoreVersion" asp-route-id="@Model.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="auditId" value="@v.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning" onclick="return confirm('Restore this version? Current content will be replaced.')">
                                        Restore
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (Model.Media?.Any() ?? false)
{
    ViewBag.AllowDeleteMedia = true;
    ViewBag.QuestionId = Model.Id;
    <div class="mt-3">
        <partial name="~/Views/Shared/_MediaViewer.cshtml" model="Model.Media" />
    </div>
}
