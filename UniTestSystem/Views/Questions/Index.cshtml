@using UniTestSystem.Application
@using UniTestSystem.Domain
@using Microsoft.AspNetCore.Mvc.Rendering
@model PagedResult<Question>

@{
    var subjectFilterOptions = ViewBag.SubjectFilterOptions as IEnumerable<SelectListItem> ?? new List<SelectListItem>();
    var difficultyLevelFilterOptions = ViewBag.DifficultyLevelFilterOptions as IEnumerable<SelectListItem> ?? new List<SelectListItem>();
    var subjectNameMap = ViewBag.SubjectNameMap as IDictionary<string, string> ?? new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
    var difficultyNameMap = ViewBag.DifficultyLevelNameMap as IDictionary<string, string> ?? new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
    var f = new QuestionFilter
    {
        Keyword = Context.Request.Query["Keyword"],
        SubjectId = Context.Request.Query["SubjectId"],
        DifficultyLevelId = Context.Request.Query["DifficultyLevelId"],
        TagsCsv = Context.Request.Query["TagsCsv"],
        Page = int.TryParse(Context.Request.Query["Page"], out var p) ? p : 1,
        PageSize = int.TryParse(Context.Request.Query["PageSize"], out var s) ? s : 20
    };
    bool canSubmitQuestion = (ViewBag.CanSubmitQuestion as bool?) ?? false;
    bool canApproveQuestion = (ViewBag.CanApproveQuestion as bool?) ?? false;
}

<h2>Question Bank</h2>

<form method="get" class="row g-2 mb-2">
    <div class="col"><input name="Keyword" value="@f.Keyword" class="form-control" placeholder="Search content..." /></div>
    <div class="col">
        <select name="Type" class="form-select">
            <option value="">--Type--</option>
            @foreach (var t in Enum.GetNames(typeof(QType)))
            {
                if (Context.Request.Query["Type"] == t)
                {
                    <option value="@t" selected>@t</option>
                }
                else
                {
                    <option value="@t">@t</option>
                }
            }
        </select>
    </div>
    <div class="col">
        <select name="SubjectId" class="form-select" asp-items="subjectFilterOptions"></select>
    </div>
    <div class="col">
        <select name="DifficultyLevelId" class="form-select" asp-items="difficultyLevelFilterOptions"></select>
    </div>
    <div class="col">
        <select name="Status" class="form-select">
            <option value="">--Status--</option>
            @foreach (var statusName in Enum.GetNames(typeof(QuestionStatus)))
            {
                if (Context.Request.Query["Status"] == statusName)
                {
                    <option value="@statusName" selected>@statusName</option>
                }
                else
                {
                    <option value="@statusName">@statusName</option>
                }
            }
        </select>
    </div>
    <div class="col"><input name="TagsCsv" value="@f.TagsCsv" class="form-control" placeholder="Tags" /></div>
    <div class="col-1"><button class="btn btn-primary w-100">Filter</button></div>
</form>

<div class="d-flex gap-2 mb-2">
    <a class="btn btn-success" href="/Questions/Create">Create</a>
    <a class="btn btn-outline-secondary" href="/Questions/ExportExcel">Export</a>
    <form asp-action="ImportExcel" method="post" enctype="multipart/form-data">
        <div class="input-group">
            <input type="file" name="file" class="form-control" accept=".xlsx,.xls" />
            <button class="btn btn-outline-primary">Import</button>
        </div>
    </form>
</div>

<table class="table table-striped">
    <thead><tr><th>Nội dung</th><th>Loại</th><th>Trạng thái</th><th>Môn học</th><th>Độ khó</th><th>Tags</th><th></th></tr></thead>
    <tbody>
        @foreach (var q in Model.Items)
        {
            <tr>
                <td>@q.Content</td>
                <td>@q.Type</td>
                <td>
                    @{
                        var color = q.Status switch {
                            QuestionStatus.Approved => "success",
                            QuestionStatus.Pending => "warning",
                            QuestionStatus.Rejected => "danger",
                            _ => "secondary"
                        };
                    }
                    <span class="badge bg-@color">@q.Status</span>
                </td>
                <td>@(subjectNameMap.TryGetValue(q.SubjectId, out var subjectName) ? subjectName : q.SubjectId)</td>
                <td>@(difficultyNameMap.TryGetValue(q.DifficultyLevelId, out var difficultyName) ? difficultyName : q.DifficultyLevelId)</td>
                <td>@string.Join(", ", q.Tags)</td>
                <td class="text-nowrap">
                    <a class="btn btn-sm btn-outline-primary" href="/Questions/Edit/@q.Id">Edit</a>
                    @if (canSubmitQuestion && (q.Status == QuestionStatus.Draft || q.Status == QuestionStatus.Rejected))
                    {
                        <form asp-action="Submit" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@q.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-warning" onclick="return confirm('Gửi câu hỏi này để duyệt?')">Submit</button>
                        </form>
                    }
                    @if (canApproveQuestion && q.Status == QuestionStatus.Pending)
                    {
                        <form asp-action="Approve" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@q.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-success" onclick="return confirm('Phê duyệt câu hỏi này?')">Approve</button>
                        </form>
                        <form asp-action="Reject" method="post" class="d-inline reject-form" data-question-id="@q.Id">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@q.Id" />
                            <input type="hidden" name="reason" value="" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Reject</button>
                        </form>
                    }
                    <form asp-action="Clone" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@q.Id" /><button class="btn btn-sm btn-outline-secondary">Clone</button>
                    </form>
                    <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Delete?')">
                        <input type="hidden" name="id" value="@q.Id" /><button class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@{
    var totalPages = (int)Math.Ceiling(Model.Total / (double)Model.PageSize);
}
<nav>
    <ul class="pagination">
        @for (int i = 1; i <= totalPages; i++)
        {
            var active = i == Model.Page ? "active" : "";
            <li class="page-item @active">
                <a class="page-link" href="@Context.Request.Path?@($"Page={i}&PageSize={Model.PageSize}&Keyword={f.Keyword}&Type={Context.Request.Query["Type"]}&SubjectId={f.SubjectId}&DifficultyLevelId={f.DifficultyLevelId}&Status={Context.Request.Query["Status"]}&TagsCsv={f.TagsCsv}")">@i</a>
            </li>
        }
    </ul>
</nav>

<script>
    document.querySelectorAll('.reject-form').forEach(function(form) {
        form.addEventListener('submit', function(event) {
            const reason = prompt('Nhập lý do từ chối câu hỏi:', 'Rejected by reviewer');
            if (reason === null) {
                event.preventDefault();
                return;
            }

            form.querySelector('input[name="reason"]').value = reason.trim();
        });
    });
</script>
