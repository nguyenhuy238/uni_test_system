@model UniTestSystem.Domain.Question
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    var subjectOptions = ViewBag.SubjectOptions as IEnumerable<SelectListItem> ?? new List<SelectListItem>();
    var difficultyLevelOptions = ViewBag.DifficultyLevelOptions as IEnumerable<SelectListItem> ?? new List<SelectListItem>();
    var skillOptions = ViewBag.SkillOptions as IEnumerable<SelectListItem> ?? new List<SelectListItem>();
    var questionBankOptions = ViewBag.QuestionBankOptions as IEnumerable<SelectListItem> ?? new List<SelectListItem>();
}

<!-- Hidden ID để POST giữ đúng bản ghi -->
<input type="hidden" name="Id" value="@Model.Id" />
<input type="hidden" name="Status" value="@Model.Status" />

<div class="mb-2">
    <label>Current Status:</label>
    <strong>@Model.Status</strong>
</div>

<div class="mb-2">
    <label>Content</label>
    <textarea name="Content" class="form-control" required>@Model.Content</textarea>
</div>

<div class="mb-2">
    <label>Type</label>
    <select asp-for="Type" id="qType" class="form-select" asp-items="Html.GetEnumSelectList<UniTestSystem.Domain.QType>()"></select>
</div>

<div id="mcqBlock" class="mb-2">
    <label>Options (each line)</label>
    <textarea name="Options" class="form-control">@string.Join('\n', Model.Options.Select(o => o.Content))</textarea>
    <label class="mt-1">Correct Keys (A hoặc A|C hoặc True)</label>
    <input name="CorrectKeys" value="@string.Join('|', Model.Options.Where(o => o.IsCorrect).Select(o => o.Content))" class="form-control" />
</div>

<div id="essayBlock" class="mb-2">
    <label>Min words</label>
    <input asp-for="EssayMinWords" type="number" min="0" class="form-control" />
</div>

<div id="matchingBlock" class="mb-2">
    <label>Matching Pairs (Left|Right per line)</label>
    <textarea name="MatchingPairsRaw" class="form-control">@string.Join('\n', (Model.MatchingPairs ?? new()).Select(p => $"{p.L}|{p.R}"))</textarea>
</div>

<div id="dragDropBlock" class="mb-2">
    <label>Tokens (|)</label>
    <input name="DragTokens" value="@string.Join('|', Model.DragDrop?.Tokens ?? new())" class="form-control" />
    <label class="mt-1">Slots (Name=Answer per line)</label>
    <textarea name="DragSlotsRaw" class="form-control">@string.Join('\n', (Model.DragDrop?.Slots ?? new()).Select(s => $"{s.Name}={s.Answer}"))</textarea>
</div>

<div class="row g-2">
    <div class="col-md-3">
        <label>Question Bank</label>
        <select asp-for="QuestionBankId" class="form-select" asp-items="questionBankOptions" required>
            <option value="">-- Select question bank --</option>
        </select>
    </div>
    <div class="col-md-3">
        <label>Subject</label>
        <select asp-for="SubjectId" class="form-select" asp-items="subjectOptions" required>
            <option value="">-- Select subject --</option>
        </select>
    </div>
    <div class="col-md-3">
        <label>Difficulty</label>
        <select asp-for="DifficultyLevelId" class="form-select" asp-items="difficultyLevelOptions" required>
            <option value="">-- Select difficulty --</option>
        </select>
    </div>
    <div class="col-md-3">
        <label>Skill</label>
        <select asp-for="SkillId" class="form-select" asp-items="skillOptions">
            <option value="">-- None --</option>
        </select>
    </div>
</div>

<div class="mb-2">
    <label>Tags (comma)</label>
    <input name="TagsCsv" value="@string.Join(',', Model.Tags)" class="form-control" />
</div>

<div class="mb-2">
    <label>Upload media (multi)</label>
    <input type="file" name="mediaFiles" multiple class="form-control" />
</div>

<script>
    function normalizeQuestionType(selectElement) {
      if (!selectElement) return '';
      const rawValue = (selectElement.value || '').toString().trim();
      const enumMap = {
        '0': 'MCQ',
        '1': 'TrueFalse',
        '2': 'Essay',
        '3': 'Matching',
        '4': 'DragDrop'
      };
      if (enumMap[rawValue]) return enumMap[rawValue];

      const selected = selectElement.options[selectElement.selectedIndex];
      const text = (selected?.text || '').toString().trim();
      return text || rawValue;
    }

    function toggleBlocks(){
      const select = document.getElementById('qType');
      const t = normalizeQuestionType(select);
      document.getElementById('mcqBlock').style.display = (t==='MCQ'||t==='TrueFalse')?'block':'none';
      document.getElementById('essayBlock').style.display = (t==='Essay')?'block':'none';
      document.getElementById('matchingBlock').style.display = (t==='Matching')?'block':'none';
      document.getElementById('dragDropBlock').style.display = (t==='DragDrop')?'block':'none';
    }
    const qType = document.getElementById('qType');
    if (qType) {
      qType.addEventListener('change', toggleBlocks);
    }
    toggleBlocks();
</script>
