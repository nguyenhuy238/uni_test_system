@model UniTestSystem.ViewModels.Tests.CreateTestViewModel
@using UniTestSystem.Domain
@using System
@{
    var hasSelectedCourse = !string.IsNullOrWhiteSpace(Model.CourseId);
    var selectedCourseName = (string?)ViewBag.SelectedCourseName ?? "N/A";
    var questionSelectionMode = string.Equals(
        Model.QuestionSelectionMode,
        CreateTestViewModel.RandomByTypeSelectionMode,
        StringComparison.OrdinalIgnoreCase)
        ? CreateTestViewModel.RandomByTypeSelectionMode
        : CreateTestViewModel.ManualSelectionMode;
    var isRandomByType = questionSelectionMode == CreateTestViewModel.RandomByTypeSelectionMode;
    var mcqCountValue = Model.McqCount.ToString();
    var tfCountValue = Model.TfCount.ToString();
    var essayCountValue = Model.EssayCount.ToString();
    var matchingCountValue = Model.MatchingCount.ToString();
    var dragDropCountValue = Model.DragDropCount.ToString();
}

<h2>Create Test</h2>

<div class="alert alert-info">
    <i class="bi bi-info-circle"></i>
    <strong>Lưu ý:</strong> Chọn chế độ lấy câu hỏi:
    <em>Thủ công</em> để tick checkbox theo ý bạn, hoặc <em>Random theo loại</em> để hệ thống tự bốc câu hỏi khi Save.
</div>

<!-- FORM GET: lọc/paging -->
<form method="get" class="d-flex align-items-center mb-2" style="gap:.5rem;">
    <input name="Keyword" value="@Model.Filter.Keyword" type="text" class="form-control" placeholder="Search keyword..." style="max-width: 220px;" />
    <select name="PageSize" class="form-select" style="max-width: 130px;">
        @{
            var sizes = new[] { 10, 20, 50, 100 };
            var current = Model.Filter.PageSize > 0 ? Model.Filter.PageSize : 20;
        }
        @foreach (var s in sizes)
        {
            <option value="@s" selected="@(current == s)">@s / page</option>
        }
        <option value="all" selected="@(Model.Filter.PageSize == int.MaxValue)">All</option>
    </select>

    <!-- NEW: carry left-form values across paging -->
    <input type="hidden" id="q_Title" name="Title" value="@Model.Title" />
    <input type="hidden" id="q_CourseId" name="CourseId" value="@Model.CourseId" />
    <input type="hidden" id="q_DurationMinutes" name="DurationMinutes" value="@Model.DurationMinutes" />
    <input type="hidden" id="q_PassScore" name="PassScore" value="@Model.PassScore" />
    <input type="hidden" id="q_AssessmentType" name="AssessmentType" value="@Model.AssessmentType" />
    <input type="hidden" id="q_ShuffleQuestions" name="ShuffleQuestions" value="@Model.ShuffleQuestions.ToString().ToLower()" />
    <input type="hidden" id="q_ShuffleOptions" name="ShuffleOptions" value="@Model.ShuffleOptions.ToString().ToLower()" />
    <input type="hidden" id="q_QuestionSelectionMode" name="QuestionSelectionMode" value="@questionSelectionMode" />
    <input type="hidden" id="q_McqCount" name="McqCount" value="@mcqCountValue" />
    <input type="hidden" id="q_TfCount" name="TfCount" value="@tfCountValue" />
    <input type="hidden" id="q_EssayCount" name="EssayCount" value="@essayCountValue" />
    <input type="hidden" id="q_MatchingCount" name="MatchingCount" value="@matchingCountValue" />
    <input type="hidden" id="q_DragDropCount" name="DragDropCount" value="@dragDropCountValue" />

    <button class="btn btn-outline-secondary" type="submit">Apply</button>
</form>

<!-- FORM POST: lưu Test -->
<form method="post" asp-action="Create" id="createForm">
    @Html.AntiForgeryToken()

    <!-- hidden để nhét các lựa chọn từ localStorage khi submit -->
    <div id="persistedSelections"></div>

    <div class="row">
        <div class="col-md-5">
            <div class="mb-2">
                <label class="form-label">Title</label>
                <input name="Title" value="@Model.Title" class="form-control" />
            </div>
            <div class="mb-2">
                <label class="form-label">Course</label>
                <select name="CourseId" class="form-select" asp-items="ViewBag.Courses" required>
                    <option value="">-- Chọn Course --</option>
                </select>
            </div>
            <div class="mb-2">
                <label class="form-label">DurationMinutes</label>
                <input name="DurationMinutes" type="number" value="@Model.DurationMinutes" class="form-control" />
            </div>
            <div class="mb-2">
                <label class="form-label">PassScore</label>
                <input name="PassScore" type="number" value="@Model.PassScore" class="form-control" />
            </div>
            <div class="mb-2">
                <label class="form-label">Assessment Type</label>
                <select name="AssessmentType" class="form-select">
                    @foreach (var type in Enum.GetValues<AssessmentType>())
                    {
                        <option value="@type" selected="@(Model.AssessmentType == type)">@type</option>
                    }
                </select>
            </div>

            <div class="mb-2">
                <label class="form-label">Chế độ chọn câu hỏi</label>
                <input type="hidden" id="QuestionSelectionMode" name="QuestionSelectionMode" value="@questionSelectionMode" />
                <div class="btn-group w-100" role="group" aria-label="Question selection mode">
                    <button type="button"
                            class="btn @(isRandomByType ? "btn-outline-secondary" : "btn-primary")"
                            id="btnModeManual"
                            data-mode="@CreateTestViewModel.ManualSelectionMode">
                        Chọn thủ công
                    </button>
                    <button type="button"
                            class="btn @(!isRandomByType ? "btn-outline-secondary" : "btn-primary")"
                            id="btnModeRandom"
                            data-mode="@CreateTestViewModel.RandomByTypeSelectionMode">
                        Random theo loại
                    </button>
                </div>
                <div class="form-text" id="selectionModeHint">
                    @(isRandomByType
                        ? "Hệ thống sẽ tự bốc câu hỏi đúng theo số lượng từng loại khi bạn bấm Save."
                        : "Bạn tự tick checkbox câu hỏi ở bảng bên phải.")
                </div>
            </div>

            <div class="mb-2" id="randomConfigBlock" style="display:@(isRandomByType ? "block" : "none");">
                <label class="form-label">Cấu hình random theo loại câu hỏi</label>
                <div class="small text-muted mb-2">
                    Nhập số câu cần lấy cho từng loại. Giá trị <strong>0</strong> nghĩa là bỏ qua loại đó.
                </div>
                <div class="row g-2">
                    <div class="col-md-6">
                        <label class="form-label mb-1">MCQ (Trắc nghiệm 1 đáp án đúng)</label>
                        <input name="McqCount" type="number" min="0" value="@mcqCountValue" class="form-control" placeholder="Ví dụ: 5" />
                        <div class="form-text mt-1">Hiện có trong Course: @Model.MCQQuestions.Count câu.</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label mb-1">True/False (Đúng/Sai)</label>
                        <input name="TfCount" type="number" min="0" value="@tfCountValue" class="form-control" placeholder="Ví dụ: 3" />
                        <div class="form-text mt-1">Hiện có trong Course: @Model.TFQuestions.Count câu.</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label mb-1">Essay (Tự luận)</label>
                        <input name="EssayCount" type="number" min="0" value="@essayCountValue" class="form-control" placeholder="Ví dụ: 1" />
                        <div class="form-text mt-1">Hiện có trong Course: @Model.EssayQuestions.Count câu.</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label mb-1">Matching (Nối cặp)</label>
                        <input name="MatchingCount" type="number" min="0" value="@matchingCountValue" class="form-control" placeholder="Ví dụ: 2" />
                        <div class="form-text mt-1">Hiện có trong Course: @Model.MatchingQuestions.Count câu.</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label mb-1">Drag & Drop (Kéo thả)</label>
                        <input name="DragDropCount" type="number" min="0" value="@dragDropCountValue" class="form-control" placeholder="Ví dụ: 2" />
                        <div class="form-text mt-1">Hiện có trong Course: @Model.DragDropQuestions.Count câu.</div>
                    </div>
                </div>
            </div>
            <div class="mb-2 form-check">
                <input type="checkbox" name="ShuffleQuestions" value="true" checked="@Model.ShuffleQuestions" class="form-check-input" />
                <label class="form-check-label">Shuffle Questions (Xáo trộn thứ tự câu hỏi)</label>
            </div>
            <div class="mb-2 form-check">
                <input type="checkbox" name="ShuffleOptions" value="true" checked="@Model.ShuffleOptions" class="form-check-input" />
                <label class="form-check-label">Shuffle Options (Xáo trộn thứ tự đáp án)</label>
            </div>

            <div class="mt-3 d-flex align-items-center gap-2">
                <button class="btn btn-primary" type="submit" id="btnSaveCreate">Save</button>
                <button class="btn btn-outline-info @(isRandomByType ? "" : "d-none")" type="button" id="btnPreviewQuestions">🔍 Preview Questions</button>
                <span class="small text-muted">Đã chọn: <span id="selectedCount">0</span> câu hỏi.</span>
            </div>

            <div class="text-danger mt-2">
                @Html.ValidationSummary()
            </div>
        </div>

        <div class="col-md-7">
            @if (!hasSelectedCourse)
            {
                <div class="alert alert-warning mb-0">Vui lòng chọn Course để xem câu hỏi</div>
            }
            else
            {
                <div class="small text-muted mb-2">
                    Hiển thị @Model.Page.Total câu hỏi từ Question Bank: @selectedCourseName
                </div>

                <ul class="nav nav-tabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-mcq" type="button" role="tab">
                            MCQ (@Model.MCQQuestions.Count)
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-tf" type="button" role="tab">
                            True/False (@Model.TFQuestions.Count)
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-essay" type="button" role="tab">
                            Essay (@Model.EssayQuestions.Count)
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-matching" type="button" role="tab">
                            Matching (@Model.MatchingQuestions.Count)
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-drag" type="button" role="tab">
                            Drag & Drop (@Model.DragDropQuestions.Count)
                        </button>
                    </li>
                </ul>

                <div class="tab-content border border-top-0 p-2" style="max-height: 520px; overflow:auto;">
                    <div class="tab-pane fade show active" id="tab-mcq" role="tabpanel">
                        <partial name="_QuestionTablePartial"
                                 model="(IEnumerable<UniTestSystem.Domain.Question>)Model.MCQQuestions"
                                 view-data='new ViewDataDictionary(ViewData) { { "Selected", Model.SelectedQuestionIds } }' />
                    </div>
                    <div class="tab-pane fade" id="tab-tf" role="tabpanel">
                        <partial name="_QuestionTablePartial"
                                 model="(IEnumerable<UniTestSystem.Domain.Question>)Model.TFQuestions"
                                 view-data='new ViewDataDictionary(ViewData) { { "Selected", Model.SelectedQuestionIds } }' />
                    </div>
                    <div class="tab-pane fade" id="tab-essay" role="tabpanel">
                        <partial name="_QuestionTablePartial"
                                 model="(IEnumerable<UniTestSystem.Domain.Question>)Model.EssayQuestions"
                                 view-data='new ViewDataDictionary(ViewData) { { "Selected", Model.SelectedQuestionIds } }' />
                    </div>
                    <div class="tab-pane fade" id="tab-matching" role="tabpanel">
                        <partial name="_QuestionTablePartial"
                                 model="(IEnumerable<UniTestSystem.Domain.Question>)Model.MatchingQuestions"
                                 view-data='new ViewDataDictionary(ViewData) { { "Selected", Model.SelectedQuestionIds } }' />
                    </div>
                    <div class="tab-pane fade" id="tab-drag" role="tabpanel">
                        <partial name="_QuestionTablePartial"
                                 model="(IEnumerable<UniTestSystem.Domain.Question>)Model.DragDropQuestions"
                                 view-data='new ViewDataDictionary(ViewData) { { "Selected", Model.SelectedQuestionIds } }' />
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-2">
                    <div class="small text-muted">Tổng đã chọn: <span id="selectedCountBottom">0</span></div>
                    <partial name="_Pager" model="Model.Page" />
                </div>
            }
        </div>
    </div>
</form>

<div class="modal fade" id="previewQuestionsModal" tabindex="-1" aria-labelledby="previewQuestionsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="previewQuestionsModalLabel">Preview Questions</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="previewWarning" class="alert alert-warning d-none"></div>
                <div id="previewSummary" class="small text-muted mb-2"></div>
                <div class="table-responsive">
                    <table class="table table-sm table-bordered align-middle">
                        <thead>
                            <tr>
                                <th style="width:80px;">STT</th>
                                <th>Nội dung</th>
                                <th style="width:130px;">Loại</th>
                                <th style="width:140px;">Độ khó</th>
                                <th style="width:130px;">Điểm dự kiến</th>
                            </tr>
                        </thead>
                        <tbody id="previewQuestionsBody">
                            <tr>
                                <td colspan="5" class="text-muted text-center">Bấm "Preview Questions" để xem danh sách câu hỏi.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" id="btnRandomPreview">🔄 Random lại</button>
                <button type="button" class="btn btn-success" id="btnConfirmPreview">✓ Xác nhận</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ===== SYNC left form -> hidden (GET form) & patch pager links =====
        (function(){
          const manualMode = '@CreateTestViewModel.ManualSelectionMode';
          const randomMode = '@CreateTestViewModel.RandomByTypeSelectionMode';
          const selectionModeInput = document.querySelector('#createForm input[name="QuestionSelectionMode"]');
          const randomConfigBlock = document.getElementById('randomConfigBlock');
          const modeManualButton = document.getElementById('btnModeManual');
          const modeRandomButton = document.getElementById('btnModeRandom');
          const modeHint = document.getElementById('selectionModeHint');
          const previewButton = document.getElementById('btnPreviewQuestions');

          function normalizeMode(mode){
            return String(mode || '').toLowerCase() === randomMode.toLowerCase() ? randomMode : manualMode;
          }

          window.isRandomSelectionMode = function(){
            return normalizeMode(selectionModeInput?.value) === randomMode;
          };

          function setModeButtonStyle(button, isPrimary){
            if (!button) return;
            button.classList.toggle('btn-primary', isPrimary);
            button.classList.toggle('btn-outline-secondary', !isPrimary);
          }

          function applySelectionModeUI(){
            const isRandom = window.isRandomSelectionMode();
            if (randomConfigBlock){
                randomConfigBlock.style.display = isRandom ? '' : 'none';
            }
            if (previewButton){
                previewButton.classList.toggle('d-none', !isRandom);
            }
            if (modeHint){
                modeHint.textContent = isRandom
                  ? 'Hệ thống sẽ tự bốc câu hỏi đúng theo số lượng từng loại khi bạn bấm Save.'
                  : 'Bạn tự tick checkbox câu hỏi ở bảng bên phải.';
            }
            setModeButtonStyle(modeManualButton, !isRandom);
            setModeButtonStyle(modeRandomButton, isRandom);
          }

          const map = {
            Title:           {src:'#createForm input[name="Title"]',            hid:'#q_Title'},
            CourseId:        {src:'#createForm select[name="CourseId"]',        hid:'#q_CourseId'},
            DurationMinutes: {src:'#createForm input[name="DurationMinutes"]',  hid:'#q_DurationMinutes'},
            PassScore:       {src:'#createForm input[name="PassScore"]',        hid:'#q_PassScore'},
            AssessmentType:  {src:'#createForm select[name="AssessmentType"]',  hid:'#q_AssessmentType'},
            ShuffleQuestions:{src:'#createForm input[name="ShuffleQuestions"]', hid:'#q_ShuffleQuestions', isCheckbox:true},
            ShuffleOptions:  {src:'#createForm input[name="ShuffleOptions"]',   hid:'#q_ShuffleOptions', isCheckbox:true},
            QuestionSelectionMode:{src:'#createForm input[name="QuestionSelectionMode"]', hid:'#q_QuestionSelectionMode'},
            McqCount:        {src:'#createForm input[name="McqCount"]',         hid:'#q_McqCount'},
            TfCount:         {src:'#createForm input[name="TfCount"]',          hid:'#q_TfCount'},
            EssayCount:      {src:'#createForm input[name="EssayCount"]',       hid:'#q_EssayCount'},
            MatchingCount:   {src:'#createForm input[name="MatchingCount"]',    hid:'#q_MatchingCount'},
            DragDropCount:   {src:'#createForm input[name="DragDropCount"]',    hid:'#q_DragDropCount'}
          };

          function syncHidden(){
            Object.values(map).forEach(m=>{
              const src = document.querySelector(m.src);
              const hid = document.querySelector(m.hid);
              if (src && hid) {
                  hid.value = m.isCheckbox ? (src.checked ? 'true' : 'false') : src.value;
              }
            });
          }

          function patchPagerLinks(){
            const getForm = document.querySelector('form[method="get"]');
            if (!getForm) return;
            const params = new URLSearchParams(new FormData(getForm));
            document.querySelectorAll('a[href*="Page="], a[href*="page="]').forEach(a=>{
              try{
                const url = new URL(a.getAttribute('href'), window.location.origin);
                params.forEach((v,k)=> url.searchParams.set(k,v));
                a.setAttribute('href', url.pathname + '?' + url.searchParams.toString());
              }catch{}
            });
          }

          function setSelectionMode(mode){
            if (!selectionModeInput) return;
            selectionModeInput.value = normalizeMode(mode);
            applySelectionModeUI();
            syncHidden();
            patchPagerLinks();
          }

          // init
          if (selectionModeInput){
            selectionModeInput.value = normalizeMode(selectionModeInput.value);
          }
          applySelectionModeUI();
          syncHidden();
          patchPagerLinks();

          // react to changes
          Object.values(map).forEach(m=>{
            const src = document.querySelector(m.src);
            if (src){
              src.addEventListener('input', ()=>{ syncHidden(); patchPagerLinks(); });
              src.addEventListener('change', ()=>{ syncHidden(); patchPagerLinks(); });
            }
          });
          document.querySelector('select[name="PageSize"]')?.addEventListener('change', patchPagerLinks);
          document.querySelector('input[name="Keyword"]')?.addEventListener('input', patchPagerLinks);
          modeManualButton?.addEventListener('click', ()=> setSelectionMode(manualMode));
          modeRandomButton?.addEventListener('click', ()=> setSelectionMode(randomMode));

          const courseSelect = document.querySelector('#createForm select[name="CourseId"]');
          if (courseSelect){
            courseSelect.addEventListener('change', ()=>{
              syncHidden();
              localStorage.removeItem(LS_KEY);
              const getForm = document.querySelector('form[method="get"]');
              if (getForm) getForm.submit();
            });
          }
        })();

        // ===== Persist selection via localStorage =====
        const LS_KEY = "tests_create_selected_ids";
        function getSel(){ try { return JSON.parse(localStorage.getItem(LS_KEY) || "[]"); } catch { return []; } }
        function setSel(arr){ localStorage.setItem(LS_KEY, JSON.stringify(Array.from(new Set(arr)))); updateSelectedCount(); }
        function updateSelectedCount(){
          const n = getSel().length;
          const el1 = document.getElementById('selectedCount');
          const el2 = document.getElementById('selectedCountBottom');
          if (el1) el1.innerText = n;
          if (el2) el2.innerText = n;
        }
        function applyFromStorageToDOM(){
          const set = new Set(getSel());
          document.querySelectorAll('input[name="SelectedQuestionIds"]').forEach(cb => { cb.checked = set.has(cb.value); });
        }
        function injectHiddenInputs(){
          const holder = document.getElementById('persistedSelections'); holder.innerHTML = '';
          if (typeof window.isRandomSelectionMode === 'function' && window.isRandomSelectionMode()) {
            return;
          }
          getSel().forEach(id => {
            const i = document.createElement('input'); i.type='hidden'; i.name='SelectedQuestionIds'; i.value=id; holder.appendChild(i);
          });
        }

        document.addEventListener('change', function(e){
          if (e.target && e.target.name === 'SelectedQuestionIds') {
            const list = getSel();
            if (e.target.checked) setSel([...list, e.target.value]);
            else setSel(list.filter(x => x !== e.target.value));
          }
        });

        applyFromStorageToDOM(); updateSelectedCount();
        document.getElementById('btnSaveCreate')?.addEventListener('click', injectHiddenInputs);
        document.getElementById('createForm')?.addEventListener('submit', injectHiddenInputs);

        // ===== Preview random questions =====
        let previewModal = null;
        let latestPreviewIds = [];

        function toInt(value) {
          const parsed = Number.parseInt(value, 10);
          return Number.isNaN(parsed) ? 0 : Math.max(0, parsed);
        }

        function escapeHtml(value) {
          return (value ?? '')
            .toString()
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#039;');
        }

        function buildPreviewRequest() {
          const form = document.getElementById('createForm');
          return {
            courseId: form?.querySelector('select[name="CourseId"]')?.value?.trim() ?? '',
            assessmentType: form?.querySelector('select[name="AssessmentType"]')?.value ?? 'Quiz',
            mcqCount: toInt(form?.querySelector('input[name="McqCount"]')?.value),
            tfCount: toInt(form?.querySelector('input[name="TfCount"]')?.value),
            essayCount: toInt(form?.querySelector('input[name="EssayCount"]')?.value),
            matchingCount: toInt(form?.querySelector('input[name="MatchingCount"]')?.value),
            dragDropCount: toInt(form?.querySelector('input[name="DragDropCount"]')?.value)
          };
        }

        function requestedTotal(request) {
          return request.mcqCount + request.tfCount + request.essayCount + request.matchingCount + request.dragDropCount;
        }

        function renderPreviewResult(payload) {
          const warningEl = document.getElementById('previewWarning');
          const summaryEl = document.getElementById('previewSummary');
          const bodyEl = document.getElementById('previewQuestionsBody');
          const questions = Array.isArray(payload?.questions) ? payload.questions : [];
          const warnings = Array.isArray(payload?.warnings) ? payload.warnings : [];

          latestPreviewIds = questions.map(q => q.id).filter(Boolean);

          if (summaryEl) {
            const requested = payload?.requestedTotal ?? 0;
            const actual = payload?.actualTotal ?? 0;
            summaryEl.textContent = `Đã random ${actual}/${requested} câu hỏi theo cấu hình hiện tại.`;
          }

          if (warningEl) {
            if (warnings.length > 0) {
              warningEl.classList.remove('d-none');
              warningEl.innerHTML = `
                <div><strong>${escapeHtml(payload?.warning ?? 'Cảnh báo')}</strong></div>
                <ul class="mb-0 mt-1">${warnings.map(x => `<li>${escapeHtml(x)}</li>`).join('')}</ul>
              `;
            } else {
              warningEl.classList.add('d-none');
              warningEl.innerHTML = '';
            }
          }

          if (bodyEl) {
            if (questions.length === 0) {
              bodyEl.innerHTML = '<tr><td colspan="5" class="text-muted text-center">Không có câu hỏi phù hợp để preview.</td></tr>';
            } else {
              bodyEl.innerHTML = questions.map(q => `
                <tr>
                  <td>${escapeHtml(q.stt)}</td>
                  <td>${escapeHtml(q.content)}</td>
                  <td>${escapeHtml(q.type)}</td>
                  <td>${escapeHtml(q.difficulty)}</td>
                  <td>${escapeHtml(q.estimatedPoints)}</td>
                </tr>
              `).join('');
            }
          }
        }

        async function loadPreviewQuestions() {
          if (typeof window.isRandomSelectionMode === 'function' && !window.isRandomSelectionMode()) {
            alert('Hãy chọn chế độ "Random theo loại" trước khi preview.');
            return;
          }

          const request = buildPreviewRequest();
          if (!request.courseId) {
            alert('Vui lòng chọn Course trước khi preview câu hỏi.');
            return;
          }

          if (requestedTotal(request) <= 0) {
            alert('Vui lòng nhập số lượng câu hỏi random lớn hơn 0.');
            return;
          }

          const previewButton = document.getElementById('btnPreviewQuestions');
          const rerollButton = document.getElementById('btnRandomPreview');
          const token = document.querySelector('#createForm input[name="__RequestVerificationToken"]')?.value ?? '';

          try {
            if (previewButton) previewButton.disabled = true;
            if (rerollButton) rerollButton.disabled = true;

            const response = await fetch('/Tests/PreviewQuestions', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
              },
              body: JSON.stringify(request)
            });

            const payload = await response.json().catch(() => ({}));
            if (!response.ok) {
              alert(payload?.message ?? 'Không thể preview câu hỏi. Vui lòng thử lại.');
              return;
            }

            renderPreviewResult(payload);
            if (!previewModal) {
              previewModal = new bootstrap.Modal(document.getElementById('previewQuestionsModal'));
            }
            previewModal.show();
          } catch {
            alert('Không thể kết nối tới API preview. Vui lòng thử lại.');
          } finally {
            if (previewButton) previewButton.disabled = false;
            if (rerollButton) rerollButton.disabled = false;
          }
        }

        document.getElementById('btnPreviewQuestions')?.addEventListener('click', loadPreviewQuestions);
        document.getElementById('btnRandomPreview')?.addEventListener('click', loadPreviewQuestions);
        document.getElementById('btnConfirmPreview')?.addEventListener('click', function() {
          if (latestPreviewIds.length === 0) {
            alert('Chưa có câu hỏi để xác nhận. Vui lòng preview trước.');
            return;
          }

          setSel(latestPreviewIds);
          applyFromStorageToDOM();
          injectHiddenInputs();
          previewModal?.hide();
        });
    </script>
}
