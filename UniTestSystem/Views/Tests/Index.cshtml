@using UniTestSystem.Domain
@model IEnumerable<Test>

@{
    ViewData["Title"] = "Tests";
    var tests = Model?.ToList() ?? new List<Test>();
    var currentStatus = Context.Request.Query["status"].ToString();
    var currentKeyword = Context.Request.Query["keyword"].ToString();
    var currentAssessmentTypeRaw = Context.Request.Query["assessmentType"].ToString();
    var currentSort = Context.Request.Query["sort"].ToString();
    AssessmentType? currentAssessmentType = null;
    if (Enum.TryParse<AssessmentType>(currentAssessmentTypeRaw, true, out var parsedAssessmentType))
    {
        currentAssessmentType = parsedAssessmentType;
    }

    string BuildStatusUrl(string? statusValue)
    {
        return Url.Action("Index", "Tests", new
        {
            status = statusValue,
            keyword = string.IsNullOrWhiteSpace(currentKeyword) ? null : currentKeyword,
            assessmentType = currentAssessmentType?.ToString(),
            sort = string.IsNullOrWhiteSpace(currentSort) ? null : currentSort
        }) ?? "/Tests";
    }
}

<h2 class="mb-3">Tests</h2>

<div class="d-flex flex-wrap align-items-center gap-2 mb-3">
    <a class="btn btn-success btn-sm" href="/Tests/Create">Create</a>

    <div class="btn-group btn-group-sm ms-2">
        <a href="@BuildStatusUrl(null)" class="btn btn-outline-secondary @(string.IsNullOrWhiteSpace(currentStatus) ? "active" : "")">All</a>
        <a href="@BuildStatusUrl("Draft")" class="btn btn-outline-secondary @(currentStatus == "Draft" ? "active" : "")">Draft</a>
        <a href="@BuildStatusUrl("Published")" class="btn btn-outline-secondary @(currentStatus == "Published" ? "active" : "")">Published</a>
        <a href="@BuildStatusUrl("Archived")" class="btn btn-outline-secondary @(currentStatus == "Archived" ? "active" : "")">Archived</a>
    </div>

    <form method="get" action="/Tests" class="d-flex flex-wrap align-items-end gap-2 ms-auto">
        @if (!string.IsNullOrWhiteSpace(currentStatus))
        {
            <input type="hidden" name="status" value="@currentStatus" />
        }
        <div>
            <label class="form-label mb-1 small">Từ khóa</label>
            <input name="keyword" class="form-control form-control-sm" value="@currentKeyword" placeholder="Tên bài test hoặc môn học" />
        </div>
        <div>
            <label class="form-label mb-1 small">Loại bài</label>
            <select name="assessmentType" class="form-select form-select-sm">
                <option value="">Tất cả loại</option>
                @foreach (var type in Enum.GetValues<AssessmentType>())
                {
                    var selected = currentAssessmentType.HasValue && currentAssessmentType.Value == type;
                    <option value="@type" selected="@selected">@type</option>
                }
            </select>
        </div>
        <div>
            <label class="form-label mb-1 small">Sắp xếp</label>
            <select name="sort" class="form-select form-select-sm">
                <option value="published_desc" selected="@(currentSort == "published_desc" || string.IsNullOrWhiteSpace(currentSort))">Mới publish trước</option>
                <option value="published_asc" selected="@(currentSort == "published_asc")">Cũ publish trước</option>
                <option value="title_asc" selected="@(currentSort == "title_asc")">Tên A-Z</option>
                <option value="title_desc" selected="@(currentSort == "title_desc")">Tên Z-A</option>
                <option value="duration_asc" selected="@(currentSort == "duration_asc")">Thời lượng tăng dần</option>
                <option value="duration_desc" selected="@(currentSort == "duration_desc")">Thời lượng giảm dần</option>
            </select>
        </div>
        <button type="submit" class="btn btn-primary btn-sm">Tìm</button>
        <a class="btn btn-outline-secondary btn-sm" href="@(Url.Action("Index", "Tests", new { status = string.IsNullOrWhiteSpace(currentStatus) ? null : currentStatus }))">Đặt lại lọc</a>
    </form>
</div>

<div class="text-muted small mb-2">Hiển thị @tests.Count bài test.</div>

<table class="table table-hover align-middle" id="testsTable">
    <thead>
        <tr>
            <th>Title</th>
            <th>Duration</th>
            <th>Pass</th>
            <th>Assessment Type</th>
            <th>Status</th>
            <th>Published At</th>
            <th style="width:320px;">Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var t in tests)
        {
            <tr data-test-id="@t.Id">
                <td>@t.Title</td>
                <td>@t.DurationMinutes min</td>
                <td>@t.PassScore</td>
                <td>@t.AssessmentType</td>
                <td>
                    @if (t.IsPublished)
                    {
                        <span class="badge bg-success">Published</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Draft</span>
                    }
                </td>
                <td>@(t.PublishedAt?.ToLocalTime().ToString("g") ?? "-")</td>
                <td class="text-nowrap">
                    <a class="btn btn-outline-primary btn-sm" href="/Tests/Assign/@t.Id">Assign Users</a>
                    <a class="btn btn-outline-secondary btn-sm" href="/Tests/Edit/@t.Id">Sửa</a>

                    <form class="d-inline" method="post" action="/Tests/Clone">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@t.Id" />
                        <button class="btn btn-outline-info btn-sm">Clone</button>
                    </form>

                    <form class="d-inline" method="post" action="/Tests/ToggleStatus">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@t.Id" />
                        @if (!t.IsPublished)
                        {
                            <button class="btn btn-success btn-sm">Publish</button>
                        }
                        else
                        {
                            <button class="btn btn-outline-warning btn-sm">Unpublish</button>
                        }
                    </form>

                    @if (!t.IsArchived)
                    {
                        <form class="d-inline" method="post" action="/Tests/Archive">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@t.Id" />
                            <button class="btn btn-outline-dark btn-sm">Archive</button>
                        </form>
                    }
                    else
                    {
                        <form class="d-inline" method="post" action="/Tests/Unarchive">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@t.Id" />
                            <button class="btn btn-outline-secondary btn-sm">Unarchive</button>
                        </form>
                    }

                </td>
            </tr>
        }
    </tbody>
</table>
