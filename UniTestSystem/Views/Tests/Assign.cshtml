@model UniTestSystem.ViewModels.Tests.AssignUsersViewModel
@{
    ViewData["Title"] = "Assign Students";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-people me-2"></i>Giao bài thi cho sinh viên</h2>
        <a class="btn btn-outline-secondary" href="/Tests"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
    </div>

    @if (TempData["Err"] is string err)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@err
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Msg"] is string m)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@m
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="alert alert-info shadow-sm">
        <i class="bi bi-info-circle-fill me-2"></i>
        <strong>Lưu ý:</strong> Bài thi sẽ được tự động chuyển sang trạng thái <b>Published</b> khi giao.
        Nếu không chọn thời gian, bài thi sẽ có hiệu lực từ thời điểm hiện tại đến 30 ngày tới.
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">Thông tin bài thi: <span class="text-primary">@Model.TestTitle</span></h5>
        </div>
        <div class="card-body">
            <!-- Bộ lọc Faculty (GET) -->
            <form method="get" action="/Tests/Assign" class="row g-3 align-items-end mb-4 border-bottom pb-4">
                <input type="hidden" name="id" value="@Model.TestId" />
                <div class="col-md-4">
                    <label class="form-label fw-bold">Lọc theo Khoa (Faculty)</label>
                    <select name="faculty" class="form-select">
                        <option value="">-- Tất cả các khoa --</option>
                        @foreach (var d in Model.Faculties)
                        {
                            var isSelected = string.Equals(d ?? "", Model.SelectedFaculty ?? "", StringComparison.OrdinalIgnoreCase);
                            <option value="@d" selected="@(isSelected ? "selected" : null)">
                                @(string.IsNullOrEmpty(d) ? "(Trống)" : d)
                            </option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <button class="btn btn-primary px-4"><i class="bi bi-filter me-1"></i>Lọc</button>
                    @if (!string.IsNullOrEmpty(Model.SelectedFaculty))
                    {
                        <a href="/Tests/Assign?id=@Model.TestId" class="btn btn-link text-decoration-none">Xóa lọc</a>
                    }
                </div>
            </form>

            <!-- Giao cho toàn bộ Faculty (POST) -->
            <form method="post" asp-action="AssignByFaculty" asp-controller="Tests" class="row g-3 align-items-end mb-4 bg-light p-3 rounded border">
                @Html.AntiForgeryToken()
                <input type="hidden" name="testId" value="@Model.TestId" />
                <div class="col-md-4">
                    <label class="form-label fw-bold"><i class="bi bi-building me-1"></i>Giao theo Khoa</label>
                    <select name="faculty" class="form-select" required>
                        <option value="">-- Chọn Khoa để giao bài --</option>
                        @foreach (var d in Model.Faculties)
                        {
                            var isSelected = string.Equals(d ?? "", Model.SelectedFaculty ?? "", StringComparison.OrdinalIgnoreCase);
                            <option value="@d" selected="@(isSelected ? "selected" : null)">
                                @(string.IsNullOrEmpty(d) ? "(Trống)" : d)
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Bắt đầu (UTC)</label>
                    <input type="datetime-local" class="form-control" name="startAt"
                           value="@DateTime.UtcNow.AddDays(-1).ToString("yyyy-MM-ddTHH:mm")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Kết thúc (UTC)</label>
                    <input type="datetime-local" class="form-control" name="endAt"
                           value="@DateTime.UtcNow.AddDays(30).ToString("yyyy-MM-ddTHH:mm")" />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-danger w-100"><i class="bi bi-check-all me-1"></i>Giao cho Khoa</button>
                </div>
            </form>

            <!-- Giao cho từng sinh viên (POST) -->
            <form method="post" action="/Tests/Assign">
                @Html.AntiForgeryToken()
                <input type="hidden" name="testId" value="@Model.TestId" />

                <div class="d-flex justify-content-between align-items-end mb-3">
                    <div class="row g-2 flex-grow-1 me-3">
                        <div class="col-md-5">
                            <label class="form-label fw-bold">Bắt đầu (UTC)</label>
                            <input type="datetime-local" class="form-control" name="startAt"
                                   value="@DateTime.UtcNow.AddDays(-1).ToString("yyyy-MM-ddTHH:mm")" />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label fw-bold">Kết thúc (UTC)</label>
                            <input type="datetime-local" class="form-control" name="endAt"
                                   value="@DateTime.UtcNow.AddDays(30).ToString("yyyy-MM-ddTHH:mm")" />
                        </div>
                    </div>
                    <button class="btn btn-success px-4"><i class="bi bi-save me-1"></i>Lưu danh sách</button>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle border">
                        <thead class="table-light">
                            <tr>
                                <th style="width:40px" class="text-center">
                                    <input type="checkbox" id="selectAll" class="form-check-input" />
                                </th>
                                <th>Họ tên</th>
                                <th>Email</th>
                                <th>Lớp</th>
                                <th>Khoa</th>
                                <th>Năm học</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Users.Any())
                            {
                                @foreach (var u in Model.Users)
                                {
                                    var isChecked = Model.AssignedUserIds.Contains(u.Id);
                                    <tr>
                                        <td class="text-center">
                                            <input type="checkbox" name="userIds[]" value="@u.Id" checked="@(isChecked ? "checked" : null)" class="form-check-input user-cb" />
                                        </td>
                                        <td><span class="fw-bold">@u.Name</span></td>
                                        <td>@u.Email</td>
                                        @{
                                            var stu = u as Student;
                                        }
                                        <td><span class="badge bg-secondary">@(stu?.StudentClassId ?? "-")</span></td>
                                        <td>-</td>
                                        <td>@(stu?.AcademicYear ?? "-")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">Không tìm thấy sinh viên nào phù hợp.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('selectAll')?.addEventListener('change', function() {
            const isChecked = this.checked;
            document.querySelectorAll('.user-cb').forEach(cb => cb.checked = isChecked);
        });
    </script>
}
