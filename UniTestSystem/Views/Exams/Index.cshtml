@model List<UniTestSystem.Domain.ExamSchedule>
@{
    ViewData["Title"] = "Exam Schedules";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Exam Schedules</h2>
    <div class="d-flex gap-2">
        <a asp-action="ExportCsv" class="btn btn-outline-success">
            <i class="bi bi-download me-1"></i> Export CSV
        </a>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> Create New Schedule
        </a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4">Course</th>
                    <th>Test Title</th>
                    <th>Room</th>
                    <th>Start Time</th>
                    <th>End Time</th>
                    <th>Type</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center py-5 text-muted">
                            No exam schedules found. <a asp-action="Create">Create one now.</a>
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="fw-bold">@item.Course?.Name</div>
                            <small class="text-muted">@item.Course?.Code</small>
                        </td>
                        <td>@item.Test?.Title</td>
                        <td><span class="badge bg-secondary">@item.Room</span></td>
                        <td>@item.StartTime.ToString("MMM dd, yyyy HH:mm")</td>
                        <td>@item.EndTime.ToString("HH:mm")</td>
                        <td>
                            <span class="badge @(item.ExamType == "Final" ? "bg-info" : "bg-primary")">
                                @item.ExamType
                            </span>
                        </td>
                        <td class="text-end pe-4">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-1">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this schedule?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
