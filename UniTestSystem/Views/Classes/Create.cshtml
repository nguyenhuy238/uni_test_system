@model UniTestSystem.Domain.StudentClass
@{
    ViewData["Title"] = "Create Class";
    var faculties = ViewBag.Faculties as List<UniTestSystem.Domain.Faculty>
                ?? new List<UniTestSystem.Domain.Faculty>();
}
<h2>Create Class</h2>

<form method="post">
    @Html.AntiForgeryToken()
    <div class="mb-3">
        <label class="form-label">Name</label>
        <input class="form-control" name="Name" value="@Model.Name" required minlength="2" />
        @Html.ValidationMessage("Name", null, new { @class = "text-danger" })
    </div>
    <div class="mb-3">
        <label class="form-label">Faculty</label>
        <select class="form-select" name="FacultyId">
            <option value="">(None)</option>
            @foreach (var d in faculties)
            {
                <option value="@d.Id">@d.Name</option>
            }
        </select>
    </div>
    <button class="btn btn-primary">Save</button>
    <a class="btn btn-link" href="/classes">Cancel</a>
</form>
