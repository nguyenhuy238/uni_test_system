@model UniTestSystem.ViewModels.Grading.GradeSessionViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Grading Session";
    bool isLocked = (bool)(ViewBag.IsLocked ?? false);
    bool hasPendingRegrade = (bool)(ViewBag.HasPendingRegrade ?? false);
    string pendingReason = (string?)(ViewBag.PendingRegradeReason) ?? "";
    var moderationLogs = ViewBag.ModerationLogs as List<UniTestSystem.Domain.SessionLog> ?? new List<UniTestSystem.Domain.SessionLog>();
    bool canModerateLock =
        User.IsInRole(UniTestSystem.Domain.Role.Admin.ToString()) ||
        User.IsInRole(UniTestSystem.Domain.Role.Staff.ToString()) ||
        User.IsInRole(UniTestSystem.Domain.Role.Lecturer.ToString());
}

<div class="container py-4">
    @if (TempData["Msg"] != null)
    {
        <div class="alert alert-success">@TempData["Msg"]</div>
    }
    @if (TempData["Err"] != null)
    {
        <div class="alert alert-danger">@TempData["Err"]</div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h2 class="mb-1"><i class="bi bi-person-badge me-2 text-primary"></i>Grading: @Model.Session.User?.Name</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/grading/pending">Grading Queue</a></li>
                    <li class="breadcrumb-item active">@Model.Test.Title</li>
                </ol>
            </nav>
        </div>
        <div class="text-end">
            <div class="fs-4 fw-bold">Current Score: @Model.Session.TotalScore / @Model.Session.MaxScore</div>
            <span class="badge @(Model.Session.Status == SessionStatus.Graded ? "bg-success" : "bg-warning text-dark")">@Model.Session.Status</span>
            @if (isLocked)
            {
                <span class="badge bg-dark ms-1">Grade Locked</span>
            }
        </div>
    </div>

    @if (hasPendingRegrade)
    {
        <div class="alert alert-warning">
            <b>Pending regrade request:</b> @pendingReason
        </div>
    }

    @if (isLocked)
    {
        <div class="alert alert-dark">
            Grade is currently locked. Unlock to edit scores.
        </div>
    }

    @if (canModerateLock)
    {
        <div class="mb-3 d-flex gap-2">
            @if (!isLocked)
            {
                <form method="post" action="/grading/@Model.Session.Id/lock" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-dark">Lock Grade</button>
                </form>
            }
            else
            {
                <form method="post" action="/grading/@Model.Session.Id/unlock" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-secondary">Unlock Grade</button>
                </form>
            }
        </div>
    }

    @if (Model.Answers.Count == 0)
    {
        <div class="alert alert-info shadow-sm border-0 d-flex align-items-center">
            <i class="bi bi-info-circle-fill fs-4 me-3"></i>
            This session does not contain any answer rows.
        </div>
    }
    else
    {
        <form method="post">
            @Html.AntiForgeryToken()

            @foreach (var item in Model.Answers)
            {
                var maxText = item.MaxPoints.ToString("0.##", CultureInfo.InvariantCulture);
                var valText = item.GivenScore.ToString("0.##", CultureInfo.InvariantCulture);
                <div class="card shadow-sm border-0 mb-4 overflow-hidden">
                    <div class="card-header bg-primary text-white py-3">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div class="fw-bold">@item.TypeLabel</div>
                            <div>
                                @if (item.IsAutoGradable)
                                {
                                    <span class="badge bg-light text-dark">Auto-gradable</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Manual</span>
                                }
                                @if (item.IsManuallyGraded)
                                {
                                    <span class="badge bg-dark ms-1">Manually updated</span>
                                }
                                <span class="badge bg-white text-primary ms-1">Max: @maxText pts</span>
                            </div>
                        </div>
                    </div>
                    <div class="card-body p-4">
                        <div class="bg-light p-3 rounded mb-3 border-start border-4 border-primary" style="white-space: pre-wrap;">@item.Content</div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Student Answer</label>
                                <pre class="form-control" style="min-height: 90px; white-space: pre-wrap;">@item.UserAnswerDisplay</pre>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Expected / Correct Answer</label>
                                <pre class="form-control bg-light" style="min-height: 90px; white-space: pre-wrap;">@item.CorrectAnswerDisplay</pre>
                            </div>
                        </div>

                        <div class="row g-3 align-items-end">
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Assigned Score</label>
                                <div class="input-group">
                                    <input type="number"
                                           class="form-control"
                                           name="scores[@item.QuestionId]"
                                           step="0.01" min="0" max="@maxText"
                                           value="@valText" required @(isLocked ? "disabled" : "") />
                                    <span class="input-group-text">/ @maxText</span>
                                </div>
                                @if (item.AutoSuggestedScore.HasValue)
                                {
                                    <div class="form-text">Auto score suggestion: @item.AutoSuggestedScore.Value.ToString("0.##", CultureInfo.InvariantCulture) / @maxText</div>
                                }
                            </div>
                            <div class="col-md-8">
                                <label class="form-label fw-bold">Feedback / Comments (Optional)</label>
                                <input type="text"
                                       class="form-control"
                                       name="comments[@item.QuestionId]"
                                       value="@item.Comment"
                                       placeholder="Provide feedback to the student..."
                                       @(isLocked ? "disabled" : "") />
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="card shadow-sm border-0 sticky-bottom py-3 bg-light border-top">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <a href="/grading/pending" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-arrow-left me-1"></i> Back to Queue
                    </a>
                    <div class="d-flex gap-2">
                        <button type="submit" name="finalize" value="false" class="btn btn-outline-primary px-4" @(isLocked ? "disabled" : "")>
                            <i class="bi bi-save me-1"></i> Save as Draft
                        </button>
                        <button type="submit" name="finalize" value="true" class="btn btn-success px-4" onclick="return confirm('Finalize grading for this session? This will mark it as Graded.')" @(isLocked ? "disabled" : "")>
                            <i class="bi bi-check2-all me-1"></i> Finalize Grading
                        </button>
                    </div>
                </div>
            </div>
        </form>
    }

    @if (moderationLogs.Any())
    {
        <div class="card mt-4 shadow-sm border-0">
            <div class="card-header fw-bold">Moderation Logs</div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th class="ps-3">At (UTC)</th>
                            <th>Action</th>
                            <th class="pe-3">Detail</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in moderationLogs)
                        {
                            <tr>
                                <td class="ps-3">@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td>@log.ActionType</td>
                                <td class="pe-3">@log.Detail</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
