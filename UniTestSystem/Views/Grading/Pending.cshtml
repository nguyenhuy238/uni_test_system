@model IEnumerable<UniTestSystem.Domain.Session>
@{
    ViewData["Title"] = "Essay Grading Queue";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-pen me-2"></i>Essay Grading Queue</h2>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Student</th>
                        <th>Test Title</th>
                        <th>Ended At</th>
                        <th>Score (Auto/Manual)</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="bi bi-clipboard-check fs-2 mb-2 d-block"></i>
                                No sessions pending grading.
                            </td>
                        </tr>
                    }
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold">@s.User?.Name</div>
                                <small class="text-muted">ID: @s.UserId</small>
                            </td>
                            <td>
                                <div class="fw-semibold">@s.Test?.Title</div>
                                <small class="text-muted">@s.TestId</small>
                            </td>
                            <td>@s.EndAt?.ToString("MMM dd, yyyy HH:mm")</td>
                            <td>
                                <span class="badge bg-secondary">Auto: @s.AutoScore</span>
                                <span class="badge bg-info text-dark">Man: @s.ManualScore</span>
                            </td>
                            <td>
                                <div class="fw-bold fs-5">@s.TotalScore <small class="text-muted fs-6">/ @s.MaxScore</small></div>
                            </td>
                            <td>
                                <span class="badge @(s.Status == SessionStatus.Graded ? "bg-success" : "bg-warning text-dark")">
                                    @s.Status
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <a class="btn btn-sm @(s.Status == SessionStatus.Graded ? "btn-outline-primary" : "btn-primary") px-3" href="/grading/@s.Id">
                                    <i class="bi bi-pencil-square me-1"></i> @(s.Status == SessionStatus.Graded ? "Edit Grades" : "Grade Now")
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
