<Window x:Class="UniTestSystem.AdminApp.Views.CreateQuestionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Question"
        Height="700"
        Width="620"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Create Question" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Foreground="#556070" TextWrapping="Wrap"
                           Text="For Matching use lines like: term|definition. For DragDrop, options are tokens and correct keys are slot answers." Margin="0,0,0,12"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Content" VerticalAlignment="Top" Margin="0,4,8,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="ContentTextBox" Height="90" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Type" VerticalAlignment="Center" Margin="0,10,8,0"/>
                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="TypeComboBox" Margin="0,10,0,0"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Skill" VerticalAlignment="Center" Margin="0,10,8,0"/>
                <ComboBox Grid.Row="3" Grid.Column="1" x:Name="SkillComboBox" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,10,0,0"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Difficulty" VerticalAlignment="Center" Margin="0,10,8,0"/>
                <ComboBox Grid.Row="4" Grid.Column="1" x:Name="DifficultyComboBox" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,10,0,0"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Subject" VerticalAlignment="Center" Margin="0,10,8,0"/>
                <ComboBox Grid.Row="5" Grid.Column="1" x:Name="SubjectComboBox" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,10,0,0"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Question Bank" VerticalAlignment="Center" Margin="0,10,8,0"/>
                <ComboBox Grid.Row="6" Grid.Column="1" x:Name="QuestionBankComboBox" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,10,0,0"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="Options" VerticalAlignment="Top" Margin="0,10,8,0"/>
                <TextBox Grid.Row="7" Grid.Column="1" x:Name="OptionsTextBox" Height="140" Margin="0,10,0,0" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                <TextBlock Grid.Row="8" Grid.Column="0" Text="Correct Keys" VerticalAlignment="Top" Margin="0,10,8,0"/>
                <TextBox Grid.Row="8" Grid.Column="1" x:Name="CorrectKeysTextBox" Height="80" Margin="0,10,0,0" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                <TextBlock Grid.Row="9" Grid.Column="0" Text="Media URL" VerticalAlignment="Center" Margin="0,10,8,0"/>
                <TextBox Grid.Row="9" Grid.Column="1" x:Name="MediaUrlTextBox" Margin="0,10,0,0"/>

                <TextBlock Grid.Row="10" Grid.Column="0" Text="Status" VerticalAlignment="Center" Margin="0,10,8,0"/>
                <TextBox Grid.Row="10" Grid.Column="1" Text="Draft" IsReadOnly="True" Margin="0,10,0,0"/>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Create" Width="90" Margin="0,0,8,0" Click="CreateButton_Click" Background="#2196F3" Foreground="White"/>
            <Button Content="Cancel" Width="90" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
