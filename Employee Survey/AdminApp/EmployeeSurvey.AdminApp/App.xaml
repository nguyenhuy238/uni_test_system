<Application x:Class="EmployeeSurvey.AdminApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:EmployeeSurvey.AdminApp"
             xmlns:vm="clr-namespace:EmployeeSurvey.AdminApp.ViewModels"
             xmlns:views="clr-namespace:EmployeeSurvey.AdminApp.Views">
    <Application.Resources>
        <!-- Converters -->
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>

        <!-- Data Templates for Navigation -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SessionsViewModel}">
            <views:SessionsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
            <views:ReportsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DraftsViewModel}">
            <views:DraftsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:QuestionsViewModel}">
            <views:QuestionsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:QuestionEditorViewModel}">
            <views:QuestionEditorView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TestsViewModel}">
            <views:TestsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TestEditorViewModel}">
            <views:TestEditorView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AutoGenerateViewModel}">
            <views:AutoGenerateView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UsersViewModel}">
            <views:UsersView/>
        </DataTemplate>

        <!-- Sidebar Button Style -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#334155"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>
