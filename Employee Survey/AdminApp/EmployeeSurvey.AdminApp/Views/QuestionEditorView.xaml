<UserControl x:Class="EmployeeSurvey.AdminApp.Views.QuestionEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EmployeeSurvey.AdminApp.Views"
             xmlns:models="clr-namespace:EmployeeSurvey.AdminApp.Models"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Background="White">
        <Border Margin="40" Background="White" CornerRadius="12" BorderThickness="1" BorderBrush="#E2E8F0">
            <DockPanel Margin="30">
                <TextBlock DockPanel.Dock="Top" Text="{Binding Title}" FontSize="24" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,30"/>
                
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#10B981" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <Button Content="Save as Draft" Padding="20,10" Background="#F4F7F9" Foreground="#475569" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,10,0" Command="{Binding SaveDraftCommand}"/>
                    <Button Content="Cancel" Padding="20,10" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,10,0"
                            Command="{Binding GoBackCommand}"/>
                    <Button Content="Save Question" Padding="25,10" Background="#0EA5E9" Foreground="White" BorderThickness="0" Command="{Binding SaveCommand}"/>
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Content" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                        <TextBox Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}" Height="100" TextWrapping="Wrap" AcceptsReturn="True" 
                                 Padding="10" BorderBrush="#E2E8F0" Margin="0,0,0,20"/>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Skill / Category" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding Skill}" Padding="10" BorderBrush="#E2E8F0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="Difficulty" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                                <ComboBox SelectedValue="{Binding Difficulty}" Padding="10">
                                    <ComboBoxItem Content="Junior"/>
                                    <ComboBoxItem Content="Middle"/>
                                    <ComboBoxItem Content="Senior"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Question Type" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                        <ComboBox SelectedItem="{Binding Type}" Padding="10" Margin="0,0,0,20">
                            <ComboBox.ItemsSource>
                                <CompositeCollection>
                                    <models:QType>MCQ</models:QType>
                                    <models:QType>TrueFalse</models:QType>
                                    <models:QType>Essay</models:QType>
                                </CompositeCollection>
                            </ComboBox.ItemsSource>
                        </ComboBox>

                        <TextBlock Text="Options (for MCQ)" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding Options}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding ., UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5" Padding="8" BorderBrush="#F1F5F9"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
