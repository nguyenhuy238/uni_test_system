<UserControl x:Class="EmployeeSurvey.AdminApp.Views.AutoGenerateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </UserControl.Resources>
    
    <Grid Background="White">
        <Border Margin="20" Background="White" CornerRadius="12" BorderThickness="1" BorderBrush="#E2E8F0">
            <DockPanel Margin="30">
                <TextBlock DockPanel.Dock="Top" Text="Smart Test Generation" FontSize="24" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,30"/>

                <!-- Wizard Footer -->
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#10B981" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <Button Content="Cancel" Padding="25,10" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,10,0" 
                            Command="{Binding CancelCommand}"/>
                    
                    <Button Content="Back" Padding="25,10" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,10,0"
                            Visibility="{Binding IsPreviewMode, Converter={StaticResource BoolToVis}}"
                            Command="{Binding BackToOptionsCommand}"/>
                    
                    <Button Content="Generate Preview" Padding="25,10" Background="#0EA5E9" Foreground="White" BorderThickness="0"
                            Visibility="{Binding IsPreviewMode, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"
                            Command="{Binding GeneratePreviewCommand}"/>
                    
                    <Button Content="Confirm &amp; Assign All" Padding="25,10" Background="#10B981" Foreground="White" BorderThickness="0"
                            Visibility="{Binding IsPreviewMode, Converter={StaticResource BoolToVis}}"
                            Command="{Binding AssignAllCommand}"/>
                </StackPanel>

                <!-- Step 1: Options -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding IsPreviewMode, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="Target Group" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                            
                            <TextBlock Text="Department" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Departments}" SelectedValue="{Binding Options.Department}" Padding="10" Margin="0,0,0,20"/>

                            <TextBlock Text="Difficulty Policy" Style="{StaticResource LabelStyle}"/>
                            <ComboBox SelectedValue="{Binding Options.DifficultyPolicy}" SelectedValuePath="Content" Padding="10" Margin="0,0,0,20">
                                <ComboBoxItem Content="ByLevel"/>
                                <ComboBoxItem Content="Any"/>
                            </ComboBox>

                            <TextBlock Text="Total Score" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding Options.TotalScore}" Padding="10" Margin="0,0,0,20"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="20,0,0,0">
                            <TextBlock Text="Question Rules" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                            
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="MCQ Questions" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding Options.McqCount}" Padding="5" TextAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="True/False Questions" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding Options.TfCount}" Padding="5" TextAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Essay Questions" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding Options.EssayCount}" Padding="5" TextAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- Step 2: Preview -->
                <Grid Visibility="{Binding IsPreviewMode, Converter={StaticResource BoolToVis}}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Generated Personalized Tests" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                        <DataGrid ItemsSource="{Binding Results}" AutoGenerateColumns="False" 
                                  CanUserAddRows="False" IsReadOnly="True" BorderThickness="1" BorderBrush="#E2E8F0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Employee" Binding="{Binding User.Name}" Width="*"/>
                                <DataGridTextColumn Header="Department" Binding="{Binding User.Department}" Width="150"/>
                                <DataGridTextColumn Header="Generated Test ID" Binding="{Binding Test.Id}" Width="*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Test.Type}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
