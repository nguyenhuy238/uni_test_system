<UserControl x:Class="EmployeeSurvey.AdminApp.Views.TestEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:models="clr-namespace:EmployeeSurvey.AdminApp.Models"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900">
    <Grid Background="White">
        <Border Margin="20" Background="White" CornerRadius="12" BorderThickness="1" BorderBrush="#E2E8F0">
            <DockPanel Margin="20">
                <TextBlock DockPanel.Dock="Top" Text="{Binding Title}" FontSize="24" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,20"/>

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#10B981" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <Button Content="Save as Draft" Padding="20,10" Background="#F4F7F9" Foreground="#475569" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,10,0" Command="{Binding SaveDraftCommand}"/>
                    <Button Content="Cancel" Padding="20,10" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,10,0" Command="{Binding GoBackCommand}"/>
                    <Button Content="Save Test" Padding="25,10" Background="#0EA5E9" Foreground="White" BorderThickness="0" Command="{Binding SaveCommand}"/>
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="Basic Info" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="Test Title" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                        <TextBox Text="{Binding TestTitle, UpdateSourceTrigger=PropertyChanged}" Padding="10" BorderBrush="#E2E8F0" Margin="0,0,0,20"/>

                        <TextBlock Text="Type" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                        <ComboBox SelectedItem="{Binding Type}" Padding="10" Margin="0,0,0,20">
                            <ComboBox.ItemsSource>
                                <CompositeCollection>
                                    <models:TestType>Test</models:TestType>
                                    <models:TestType>Survey</models:TestType>
                                </CompositeCollection>
                            </ComboBox.ItemsSource>
                        </ComboBox>

                        <TextBlock Text="Duration (Minutes)" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                        <TextBox Text="{Binding DurationMinutes}" Padding="10" BorderBrush="#E2E8F0" Margin="0,0,0,20"/>

                        <CheckBox IsChecked="{Binding IsPublished}" Content="Published" VerticalContentAlignment="Center" Margin="0,0,0,20"/>
                    </StackPanel>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0">
                            <TextBlock DockPanel.Dock="Top" Text="Available Questions" FontWeight="Bold" Margin="0,0,0,10"/>
                            <ListBox ItemsSource="{Binding AvailableQuestions}" SelectedItem="{Binding SelectedAvailable}" 
                                     DisplayMemberPath="Content" BorderBrush="#E2E8F0">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="10"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </DockPanel>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                            <Button Content="↓ Add Selected" Padding="15,5" Command="{Binding AddQuestionCommand}" 
                                    CommandParameter="{Binding SelectedAvailable}"/>
                            <Button Content="↑ Remove Selected" Padding="15,5" Margin="10,0" Command="{Binding RemoveQuestionCommand}"
                                    CommandParameter="{Binding SelectedSelected}"/>
                        </StackPanel>

                        <DockPanel Grid.Row="2">
                            <TextBlock DockPanel.Dock="Top" Text="Selected Questions" FontWeight="Bold" Margin="0,0,0,10"/>
                            <ListBox ItemsSource="{Binding SelectedQuestions}" SelectedItem="{Binding SelectedSelected}"
                                     DisplayMemberPath="Content" BorderBrush="#E2E8F0">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="10"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </DockPanel>
                    </Grid>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
