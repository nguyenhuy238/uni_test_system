@using Employee_Survey.Models
@model (RoleReportVm roleVm, LevelReportVm levelVm)
@{
    ViewData["Title"] = "Reports";
    var from = (string)ViewBag.From;
    var to = (string)ViewBag.To;
    bool canExport = (bool)(ViewBag.CanExport ?? false);
}
<h2 class="mb-3">Reports</h2>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <label class="form-label">From</label>
        <input type="date" name="from" class="form-control" value="@from" />
    </div>
    <div class="col-auto">
        <label class="form-label">To</label>
        <input type="date" name="to" class="form-control" value="@to" />
    </div>
    <div class="col-auto align-self-end">
        <button class="btn btn-primary">Apply</button>
        @if (canExport)
        {
            <a class="btn btn-outline-success" href="/reports/export/xlsx?from=@from&to=@to">Export Excel</a>
            <a class="btn btn-outline-danger" href="/reports/export/pdf?from=@from&to=@to">Export PDF</a>
        }
    </div>
</form>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm mb-3">
            <div class="card-header fw-bold">Overview by Role</div>
            <div class="card-body table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr><th>Role</th><th>#Users</th><th>#Submissions</th><th>AvgScore</th><th>Pass%</th><th>Last</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.roleVm.Rows)
                        {
                            <tr>
                                <td>@r.Role</td>
                                <td>@r.UserCount</td>
                                <td>@r.SubmissionCount</td>
                                <td>@r.AvgScore</td>
                                <td>@r.PassRatePercent</td>
                                <td>@(r.LastSubmissionAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm mb-3">
            <div class="card-header fw-bold">Overview by Level</div>
            <div class="card-body table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr><th>Level</th><th>#Users</th><th>#Submissions</th><th>AvgScore</th><th>Pass%</th><th>Last</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.levelVm.Rows)
                        {
                            <tr>
                                <td>@r.Level</td>
                                <td>@r.UserCount</td>
                                <td>@r.SubmissionCount</td>
                                <td>@r.AvgScore</td>
                                <td>@r.PassRatePercent</td>
                                <td>@(r.LastSubmissionAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
