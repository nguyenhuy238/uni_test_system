@using System.Security.Claims
@using Employee_Survey.Domain
@using Employee_Survey.Application
@inject Employee_Survey.Application.IPermissionService PermissionService

@{
    ViewData["Title"] = "Admin Dashboard";
    var name = User?.Identity?.Name ?? "Admin";
    var role = User?.FindFirst(ClaimTypes.Role)?.Value ?? "Admin";

    // Cho phép Admin nhìn thấy luôn; các role khác thì theo permission
    var isAdmin = string.Equals(role, "Admin", System.StringComparison.OrdinalIgnoreCase);
    bool hasOrgPerm = isAdmin || (
        PermissionService.HasAsync(User!, PermissionCodes.Org_View).GetAwaiter().GetResult() ||
        PermissionService.HasAsync(User!, PermissionCodes.Org_Manage).GetAwaiter().GetResult()
    );
    bool canViewReports = isAdmin || PermissionService.HasAsync(User!, PermissionCodes.Reports_View).GetAwaiter().GetResult();
    bool canManagePerms = isAdmin || PermissionService.HasAsync(User!, PermissionCodes.Perms_Manage).GetAwaiter().GetResult();
    bool canEditSettings = isAdmin || PermissionService.HasAsync(User!, PermissionCodes.Settings_Edit).GetAwaiter().GetResult();
    bool canViewAudit = isAdmin || PermissionService.HasAsync(User!, PermissionCodes.Audit_View).GetAwaiter().GetResult();
}

<h2>Welcome @name</h2>
<p>Đi tới quản trị câu hỏi, bài test, phân công…</p>

<div class="row g-3">
    @if (hasOrgPerm)
    {
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header fw-semibold">Organization</div>
                <div class="card-body">
                    <p class="text-muted mb-3">Quản lý phòng ban và team.</p>
                    <a class="btn btn-primary me-2" href="/departments">Departments</a>
                    <a class="btn btn-outline-primary" href="/teams">Teams</a>
                </div>
            </div>
        </div>
    }

    @if (canViewReports)
    {
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header fw-semibold">Reports</div>
                <div class="card-body">
                    <p class="text-muted mb-3">Thống kê theo role/level, năng lực theo kỹ năng, xuất Excel/PDF.</p>
                    <a class="btn btn-primary" href="/reports">Open Reports</a>
                </div>
            </div>
        </div>
    }

    @if (canManagePerms)
    {
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header fw-semibold">Permissions</div>
                <div class="card-body">
                    <p class="text-muted mb-3">Phân quyền chi tiết cho từng vai trò, gán role cho user.</p>
                    <a class="btn btn-primary" href="/roles">Open Permissions</a>
                </div>
            </div>
        </div>
    }

    @if (canEditSettings)
    {
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header fw-semibold">Settings</div>
                <div class="card-body">
                    <p class="text-muted mb-3">Cấu hình logo, tên hệ thống, email…</p>
                    <a class="btn btn-primary" href="/settings">Open Settings</a>
                </div>
            </div>
        </div>
    }

    @if (canViewAudit)
    {
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header fw-semibold">Audit Logs</div>
                <div class="card-body">
                    <p class="text-muted mb-3">Lịch sử hoạt động hệ thống.</p>
                    <a class="btn btn-primary" href="/audit">Open Audit</a>
                </div>
            </div>
        </div>
    }

    <div class="col-12">
        <div class="card mt-3 shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Maintenance</h5>
                <p class="card-text">
                    Thao tác này sẽ <strong>ghi rỗng toàn bộ file dữ liệu (*.json)</strong> trong thư mục <code>App_Data</code>
                    (Assignment, AuditLog, Feedback, Notification, PasswordReset, Question, Session, Team, Test, User, …)
                    và <strong>seed lại dữ liệu mặc định</strong> (Admin/HR/Manager/Alice, Team A, câu hỏi &amp; test mẫu).
                </p>

                <form asp-action="ResetData" asp-controller="Admin" method="post" class="d-inline"
                      onsubmit="return confirm('Bạn có chắc chắn muốn RESET TOÀN BỘ dữ liệu về mặc định?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        Reset toàn bộ dữ liệu
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
