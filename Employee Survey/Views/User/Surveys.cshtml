@{
    ViewData["Title"] = "Available Surveys";
    Layout = "_UserLayout";
}

<div class="container">
    <div class="row">
        <div class="col-12">
            <h2>Available Surveys</h2>
            <p class="text-muted">Participate in company surveys and provide feedback</p>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div id="surveysList">
                <div class="text-center">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading surveys...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            loadSurveys();
        });

        function loadSurveys() {
            const token = localStorage.getItem('jwtToken');
            
            $.ajax({
                url: '/api/user/tests/surveys',
                method: 'GET',
                headers: {
                    'Authorization': 'Bearer ' + token
                },
                success: function(surveys) {
                    displaySurveys(surveys);
                },
                error: function() {
                    $('#surveysList').html('<div class="alert alert-warning">Unable to load surveys. Please try again later.</div>');
                }
            });
        }

        function displaySurveys(surveys) {
            if (surveys.length === 0) {
                $('#surveysList').html('<div class="alert alert-info">No surveys available at the moment.</div>');
                return;
            }

            let html = '<div class="row">';
            
            surveys.forEach(survey => {
                html += `
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5 class="card-title">${survey.title}</h5>
                                <p class="card-text">
                                    <small class="text-muted">
                                        <i class="bi bi-clock"></i> ${survey.durationMinutes} minutes
                                    </small>
                                </p>
                                <button class="btn btn-success" onclick="startSurvey('${survey.id}')">
                                    Take Survey
                                </button>
                            </div>
                        </div>
                    </div>
                `;
            });
            
            html += '</div>';
            $('#surveysList').html(html);
        }

        function startSurvey(surveyId) {
            const token = localStorage.getItem('jwtToken');
            
            $.ajax({
                url: `/api/user/tests/${surveyId}/start`,
                method: 'POST',
                headers: {
                    'Authorization': 'Bearer ' + token
                },
                success: function(response) {
                    window.location.href = `/User/TakeTest?testId=${surveyId}&sessionId=${response.sessionId}`;
                },
                error: function(xhr) {
                    const error = xhr.responseJSON?.message || 'Failed to start survey';
                    alert(error);
                }
            });
        }
    </script>
}
