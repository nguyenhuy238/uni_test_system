@model Employee_Survey.Domain.Team
@{
    ViewData["Title"] = "Edit Team";
    // SỬA: không dùng new() target-typed với dynamic
    var depts = ViewBag.Departments as List<Employee_Survey.Domain.Department>
                ?? new List<Employee_Survey.Domain.Department>();
}
<h2>Edit Team</h2>

<form method="post">
    @Html.AntiForgeryToken()
    <div class="mb-3">
        <label class="form-label">Name</label>
        <input class="form-control" name="Name" value="@Model.Name" required minlength="2" />
        @Html.ValidationMessage("Name", null, new { @class = "text-danger" })
    </div>
    <div class="mb-3">
        <label class="form-label">Department</label>
        <select class="form-select" name="DepartmentId">
            <option value="">(None)</option>
            @foreach (var d in depts)
            {
                
                <option value="@d.Id" selected="@(d.Id == Model.DepartmentId ? "selected" : null)">@d.Name</option>
            }
        </select>
    </div>
    <button class="btn btn-primary">Save</button>
    <a class="btn btn-link" href="/teams">Cancel</a>
</form>
